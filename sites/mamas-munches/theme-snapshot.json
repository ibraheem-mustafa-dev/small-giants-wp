{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "Mama's Munches",
  "description": "Bundled preset — colour + typography combined. For independent axes use colours/mamas-munches and typography/mamas-munches.",
  "settings": {
    "color": {
      "palette": [
        {
          "slug": "primary",
          "color": "#E68A95",
          "name": "Primary (Coral Pink)"
        },
        {
          "slug": "primary-dark",
          "color": "#C56A7A",
          "name": "Primary Dark (Coral Hover)"
        },
        {
          "slug": "surface-pink",
          "color": "#F5C2C8",
          "name": "Soft Pink (Hero / Trust Bar)"
        },
        {
          "slug": "surface",
          "color": "#FBF3DC",
          "name": "Surface (Cream)"
        },
        {
          "slug": "surface-alt",
          "color": "#FFF9F0",
          "name": "Surface Alt (Warm Off-white)"
        },
        {
          "slug": "accent",
          "color": "#F5D050",
          "name": "Accent (Warm Yellow)"
        },
        {
          "slug": "accent-text",
          "color": "#7A6500",
          "name": "Accent Text (WCAG AA on White)"
        },
        {
          "slug": "text",
          "color": "#3A2E26",
          "name": "Text (Choc-chip Charcoal)"
        },
        {
          "slug": "text-muted",
          "color": "#6B5C50",
          "name": "Text Muted (Warm Mid-brown)"
        },
        {
          "slug": "text-inverse",
          "color": "#FFFAF5",
          "name": "Text Inverse (Off-white)"
        },
        {
          "slug": "cookie-brown",
          "color": "#8B6F4E",
          "name": "Cookie Brown (Decorative)"
        },
        {
          "slug": "border-subtle",
          "color": "#E8D5C0",
          "name": "Border (Warm Beige)"
        },
        {
          "slug": "success",
          "color": "#2E7D4F",
          "name": "Success"
        },
        {
          "slug": "footer-bg",
          "color": "#3A2E26",
          "name": "Footer Background"
        },
        {
          "slug": "surface-peach",
          "color": "#FAC47E",
          "name": "Surface Peach (brand-source warm tone)"
        },
        {
          "slug": "surface-cream-warm",
          "color": "#E3B78B",
          "name": "Surface Cream Warm (brand-source warm tone)"
        },
        {
          "slug": "border-warm",
          "color": "#DAAA92",
          "name": "Border Warm (brand-source warm tone)"
        },
        {
          "slug": "cookie-brown-warm",
          "color": "#BE7B52",
          "name": "Cookie Brown Warm (brand-source warm tone)"
        },
        {
          "slug": "client-surface-pink",
          "color": "surface-pink"
        },
        {
          "slug": "client-text",
          "color": "text"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "Fraunces, 'DM Serif Display', Georgia, serif",
          "slug": "heading",
          "name": "Heading (Fraunces)",
          "fontFace": [
            {
              "fontFamily": "Fraunces",
              "fontWeight": "100 900",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": [
                "file:./assets/fonts/fraunces/Fraunces[opsz,wght].woff2"
              ]
            }
          ]
        },
        {
          "fontFamily": "Inter, system-ui, -apple-system, sans-serif",
          "slug": "body",
          "name": "Body (Inter)",
          "fontFace": [
            {
              "fontFamily": "Inter",
              "fontWeight": "100 900",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": [
                "file:./assets/fonts/inter-variable-latin.woff2"
              ]
            }
          ]
        }
      ],
      "fontSizes": [
        {
          "slug": "px",
          "size": "px"
        }
      ]
    },
    "custom": {
      "buttonPresets": {
        "primary": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--text)",
          "border": "var(--wp--preset--color--primary)",
          "border-width": "2px",
          "border-radius": "24px",
          "padding": "14px 28px 14px 28px",
          "font-size": "15px",
          "font-weight": "600",
          "min-height": "48px",
          "hover-background": "var(--wp--preset--color--text)",
          "hover-text": "var(--wp--preset--color--text-inverse)",
          "hover-border": "var(--wp--preset--color--text)"
        },
        "secondary": {
          "background": "transparent",
          "text": "var(--wp--preset--color--text)",
          "border": "var(--wp--preset--color--primary)",
          "border-width": "2px",
          "border-radius": "24px",
          "padding": "14px 28px 14px 28px",
          "font-size": "15px",
          "font-weight": "600",
          "min-height": "48px",
          "hover-background": "var(--wp--preset--color--text)",
          "hover-text": "var(--wp--preset--color--text-inverse)",
          "hover-border": "var(--wp--preset--color--text)"
        }
      },
      "maxWidth": {
        "narrow-420": "420px"
      },
      "sgs": {
        "headerPattern": "sgs/framework-header-default",
        "footerPattern": "sgs/framework-footer-default"
      }
    },
    "spacing": {
      "spacingSizes": [
        {
          "slug": "28",
          "size": "28px",
          "name": "28px"
        },
        {
          "slug": "px",
          "size": "px"
        }
      ]
    },
    "layout": {
      "contentSize": "960px",
      "wideSize": "1280px"
    }
  },
  "styles": {
    "css": "*:focus-visible { outline: 2px solid var(--wp--preset--color--text); outline-offset: 2px; border-radius: 4px; } .sgs-button.is-style-primary { background-color: var(--wp--preset--color--primary) !important; color: var(--wp--preset--color--text) !important; border-color: var(--wp--preset--color--primary) !important; line-height: 1.6 !important; } .sgs-button.is-style-primary:hover { background-color: var(--wp--preset--color--text) !important; color: var(--wp--preset--color--text-inverse) !important; border-color: var(--wp--preset--color--text) !important; } .sgs-button.is-style-secondary { background-color: transparent !important; color: var(--wp--preset--color--text) !important; border-color: var(--wp--preset--color--primary) !important; line-height: 1.6 !important; } .sgs-button.is-style-secondary:hover { background-color: var(--wp--preset--color--text) !important; color: var(--wp--preset--color--text-inverse) !important; border-color: var(--wp--preset--color--text) !important; } @media (max-width: 767px) { .sgs-hero__ctas .wp-block-sgs-multi-button, .sgs-hero__ctas .sgs-button-wrapper, .sgs-hero__ctas .sgs-button { width: 100% !important; box-sizing: border-box; } .sgs-hero__ctas .wp-block-sgs-multi-button .wp-block-sgs-multi-button { display: flex !important; flex-direction: column !important; gap: 10px !important; } } @media (min-width: 768px) { .sgs-hero__ctas { flex-direction: row; gap: 12px; align-items: center; flex-wrap: wrap; } .sgs-hero__ctas .sgs-button-wrapper, .sgs-hero__ctas .wp-block-sgs-multi-button { width: auto !important; } .sgs-hero__ctas .sgs-multi-button > .wp-block-sgs-multi-button { display: flex !important; flex-direction: row !important; gap: 12px !important; align-items: center !important; flex-wrap: wrap !important; } } .page-id-29 .wp-block-post-title { display: none; } /* TEMP 2026-05-27: Hide Phase-1-out-of-scope malformed header wrap that post-Spec-22-Fix-1 now correctly applies its mockup  rule to. Remove when Phase-2 header/footer cloner ships per .claude/plans/2026-05-24-phase-2-header-footer-cloner.md. */ .page-id-144 .wp-block-sgs-container.sgs-header { display: none !important; } :root { --sgs-product-card-btn-text: #3A2E26; --sgs-op-sel-text: #3A2E26; --sgs-product-card-btn-hover-bg: #8B3A47; }",
    "blocks": {
      "sgs/hero": {
        "css": ".sgs-hero__label{display:block;font-family:var(--wp--preset--font-family--body);font-size:clamp(0.75rem,1.5vw,0.875rem);font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--wp--preset--color--primary);margin-bottom:0.5rem;line-height:1.2}.sgs-hero__headline{text-wrap:balance}"
      }
    },
    "typography": {
      "fontFamily": "var:preset|font-family|body",
      "fontSize": "1rem",
      "lineHeight": "1.65",
      "fontWeight": "400"
    },
    "color": {
      "background": "var:preset|color|surface",
      "text": "var:preset|color|text"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontWeight": "700",
          "lineHeight": "1.15",
          "letterSpacing": "-0.022em"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontWeight": "600",
          "lineHeight": "1.2",
          "letterSpacing": "-0.015em"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontWeight": "500",
          "lineHeight": "1.2"
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var:preset|font-family|body",
          "fontWeight": "600",
          "lineHeight": "1.3"
        }
      },
      "link": {
        "color": {
          "text": "var:preset|color|primary-dark"
        },
        ":hover": {
          "color": {
            "text": "var:preset|color|text"
          }
        }
      },
      "button": {
        "color": {
          "background": "var:preset|color|primary",
          "text": "var:preset|color|text"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|body",
          "fontWeight": "600",
          "fontSize": "0.95rem"
        },
        "border": {
          "radius": "10px",
          "width": "2px",
          "color": "var:preset|color|primary",
          "style": "solid"
        },
        "spacing": {
          "padding": {
            "top": "14px",
            "bottom": "14px",
            "left": "24px",
            "right": "24px"
          }
        },
        ":hover": {
          "color": {
            "background": "var:preset|color|text",
            "text": "var:preset|color|text-inverse"
          },
          "border": {
            "color": "var:preset|color|text"
          }
        }
      }
    }
  }
}