{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "SGS Professional Colours",
	"description": "Colour-only axis — deep navy and burgundy/plum. Combine with any typography preset.",
	"settings": {
		"color": {
			"palette": [
				{
					"slug": "primary",
					"color": "#1E2D5E",
					"name": "Primary (Deep Navy)"
				},
				{
					"slug": "primary-dark",
					"color": "#131D3E",
					"name": "Primary Dark"
				},
				{
					"slug": "accent",
					"color": "#8B4A6B",
					"name": "Accent (Burgundy/Plum)"
				},
				{
					"slug": "accent-light",
					"color": "#F0E0EA",
					"name": "Accent Light"
				},
				{
					"slug": "error",
					"color": "#DC2626",
					"name": "Error"
				},
				{
					"slug": "surface",
					"color": "#FFFFFF",
					"name": "Surface (White)"
				},
				{
					"slug": "surface-alt",
					"color": "#F8F7F9",
					"name": "Surface Alt (Lavender Tint)"
				},
				{
					"slug": "footer-bg",
					"color": "#1E2D5E",
					"name": "Footer Background"
				},
				{
					"slug": "text-primary",
					"color": "#1E2D5E",
					"name": "Text Primary"
				},
				{
					"slug": "text-secondary",
					"color": "#4A4A6A",
					"name": "Text Secondary"
				},
				{
					"slug": "text-muted",
					"color": "#7A7A9A",
					"name": "Text Muted"
				},
				{
					"slug": "text-inverse",
					"color": "#FFFFFF",
					"name": "Text Inverse (White)"
				},
				{
					"slug": "border-subtle",
					"color": "#8B4A6B",
					"name": "Border Subtle (Plum)"
				},
				{
					"slug": "border-light",
					"color": "#E5E7EB",
					"name": "Border Light"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--surface)",
			"text": "var(--wp--preset--color--text-primary)"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--accent)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--primary)"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--accent)",
					"text": "var(--wp--preset--color--text-inverse)"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--primary)",
						"text": "var(--wp--preset--color--text-inverse)"
					}
				}
			},
			"h5": { "color": { "text": "var(--wp--preset--color--accent)" } },
			"h6": { "color": { "text": "var(--wp--preset--color--text-secondary)" } }
		}
	}
}
