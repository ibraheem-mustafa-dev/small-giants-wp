{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Indus Foods Colours",
	"description": "Colour-only axis — teal and gold palette. Combine with any typography preset.",
	"settings": {
		"color": {
			"palette": [
				{
					"slug": "primary",
					"color": "#0A7EA8",
					"name": "Primary (Dark Blue)"
				},
				{
					"slug": "primary-dark",
					"color": "#075E80",
					"name": "Primary Dark"
				},
				{
					"slug": "accent",
					"color": "#D8CA50",
					"name": "Accent (Dark Gold)"
				},
				{
					"slug": "accent-text",
					"color": "#7A6B00",
					"name": "Accent Text (Dark Gold — WCAG AA on white)"
				},
				{
					"slug": "accent-light",
					"color": "#E7D768",
					"name": "Accent Light (Light Gold)"
				},
				{
					"slug": "border-subtle",
					"color": "#2EADE2",
					"name": "Light Blue"
				},
				{
					"slug": "success",
					"color": "#2E7D4F",
					"name": "Success"
				},
				{
					"slug": "error",
					"color": "#DC2626",
					"name": "Error"
				},
				{
					"slug": "whatsapp",
					"color": "#25D366",
					"name": "WhatsApp"
				},
				{
					"slug": "surface",
					"color": "#FFFFFF",
					"name": "Surface"
				},
				{
					"slug": "surface-alt",
					"color": "#F8F7F4",
					"name": "Surface Alt"
				},
				{
					"slug": "text",
					"color": "#2C3E50",
					"name": "Text"
				},
				{
					"slug": "text-muted",
					"color": "#5A6070",
					"name": "Text Muted"
				},
				{
					"slug": "text-inverse",
					"color": "#FFFFFF",
					"name": "Text Inverse"
				},
				{
					"slug": "border-light",
					"color": "#E5E7EB",
					"name": "Border Light"
				},
				{
					"slug": "footer-bg",
					"color": "#2C3E50",
					"name": "Footer Background"
				}
			]
		}
	},
	"styles": {
		"elements": {
			"heading": {
				"color": {
					"text": "var:preset|color|primary"
				}
			},
			"link": {
				"color": {
					"text": "var:preset|color|primary"
				},
				":hover": {
					"color": {
						"text": "var:preset|color|primary-dark"
					}
				}
			},
			"button": {
				"color": {
					"background": "var:preset|color|primary",
					"text": "var:preset|color|surface"
				},
				":hover": {
					"color": {
						"background": "var:preset|color|primary-dark",
						"text": "var:preset|color|surface"
					}
				}
			}
		}
	}
}
