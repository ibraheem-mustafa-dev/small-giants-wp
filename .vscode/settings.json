{
  "sonarlint.connectedMode.project": {
    "connectionId": "smallgiantsstudioltd",
    "projectKey": "ibraheem-mustafa-dev_small-giants-wp"
  },

  // ── PHP / Intelephense ────────────────────────────────────────────────────
  // WordPress + WP-CLI symbol resolution for Intelephense.
  // Strategy: project-level stubs in vendor/php-stubs/ override Intelephense's
  // bundled "wordpress" stub. Bundled stubs lag behind WP core (e.g. miss
  // get_block_wrapper_attributes, wp_unique_id, modern block-editor APIs).
  // Composer-installed stubs match WP 6.9.1 (same as palestine-lives.org).
  // Run `php composer.phar update` periodically to refresh.
  "intelephense.environment.phpVersion": "8.2.0",
  "intelephense.environment.includePaths": [
    "vendor/php-stubs/wordpress-stubs",
    "vendor/php-stubs/wp-cli-stubs"
  ],
  // Silence P1010 false positives on WordPress core functions called from inside
  // a `namespace SGS\Theme;` block. PHP's global-fallback resolution makes calls
  // like `add_action(...)` work at runtime, but intelephense doesn't always apply
  // the fallback even with stubs loaded — so it flags every WP core call as
  // "Undefined function 'SGS\Theme\add_action'". Stubs still drive autocomplete
  // and signature help; only the noisy diagnostic is silenced.
  "intelephense.diagnostics.undefinedFunctions": false,
  "intelephense.stubs": [
    "apache",
    "bcmath",
    "bz2",
    "calendar",
    "com_dotnet",
    "Core",
    "ctype",
    "curl",
    "date",
    "dba",
    "dom",
    "enchant",
    "exif",
    "FFI",
    "fileinfo",
    "filter",
    "fpm",
    "ftp",
    "gd",
    "gettext",
    "gmp",
    "hash",
    "iconv",
    "imap",
    "intl",
    "json",
    "ldap",
    "libxml",
    "mbstring",
    "meta",
    "mysqli",
    "oci8",
    "odbc",
    "openssl",
    "pcntl",
    "pcre",
    "PDO",
    "pdo_ibm",
    "pdo_mysql",
    "pdo_pgsql",
    "pdo_sqlite",
    "pgsql",
    "Phar",
    "posix",
    "pspell",
    "readline",
    "Reflection",
    "session",
    "shmop",
    "SimpleXML",
    "snmp",
    "soap",
    "sockets",
    "sodium",
    "SPL",
    "sqlite3",
    "standard",
    "superglobals",
    "sysvmsg",
    "sysvsem",
    "sysvshm",
    "tidy",
    "tokenizer",
    "xml",
    "xmlreader",
    "xmlrpc",
    "xmlwriter",
    "xsl",
    "Zend OPcache",
    "zip",
    "zlib",
    "wordpress"
  ],

  // ── phpcs integration ─────────────────────────────────────────────────────
  "phpcs.standard": "WordPress-Extra",
  "phpcs.errorSeverity": 5,
  "phpcs.warningSeverity": 5
}
