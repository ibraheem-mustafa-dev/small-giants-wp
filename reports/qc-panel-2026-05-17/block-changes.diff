+/**
+ * sgs/text — block editor styles.
+ *
+ * Keeps the editor canvas presentation consistent with the frontend.
+ * Inspector control row layout helpers (shared across SGS blocks).
+ */
+
+.wp-block-sgs-text {
+	/* Prevent the editor wrapping an empty block with unexpected height. */
+	min-height: 1em;
+}
+
+/* Shared inspector row helper — side-by-side controls (value + unit). */
+.sgs-inspector-row {
+	display: flex;
+	flex-wrap: wrap;
+	gap: 8px;
+	align-items: flex-end;
+	margin-bottom: 8px;
+}
+
+.sgs-inspector-row > * {
+	flex: 1 1 80px;
+	min-width: 60px;
+}
+
+/* Section label within inspector panels. */
+.sgs-inspector-label {
+	font-size: 11px;
+	font-weight: 500;
+	text-transform: uppercase;
+	color: #757575;
+	margin: 12px 0 4px;
+}
