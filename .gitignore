# theme/sgs-theme/styles/ is no longer used for variation JSONs.
theme/sgs-theme/styles/*.json
theme/sgs-theme/styles/colours/
theme/sgs-theme/styles/typography/

# Python bytecode caches
**/__pycache__/
*.pyc

