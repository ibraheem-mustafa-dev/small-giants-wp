{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/accordion",
	"version": "0.2.0",
	"title": "SGS Accordion",
	"category": "sgs-interactive",
	"description": "Expandable content sections â€” ideal for FAQs, product details, and policies. Optional FAQ Schema for SEO.",
	"keywords": [
		"accordion",
		"faq",
		"toggle",
		"collapse",
		"expand",
		"details"
	],
	"textdomain": "sgs-blocks",
	"icon": "list-view",
	"supports": {
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-accordion"
	},
	"attributes": {
		"allowMultiple": {
			"type": "boolean",
			"default": false
		},
		"defaultOpen": {
			"type": "number",
			"default": -1
		},
		"iconPosition": {
			"type": "string",
			"default": "right"
		},
		"style": {
			"type": "string",
			"default": "bordered"
		},
		"faqSchema": {
			"type": "boolean",
			"default": false
		},
		"headerColour": {
			"type": "string"
		},
		"headerBackground": {
			"type": "string"
		},
		"iconColour": {
			"type": "string"
		},
		"openIcon": {
			"type": "string",
			"default": "chevron-down"
		},
		"closeIcon": {
			"type": "string",
			"default": "chevron-up"
		},
		"widthMode": {
			"type": "string",
			"default": "default",
			"enum": ["default", "wide", "full", "custom"]
		},
		"widthModeMobile": {
			"type": "string",
			"default": ""
		},
		"widthModeTablet": {
			"type": "string",
			"default": ""
		},
		"widthModeDesktop": {
			"type": "string",
			"default": ""
		},
		"customWidth": {
			"type": "number",
			"default": 0
		},
		"customWidthUnit": {
			"type": "string",
			"default": "px"
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		},
		"layout": {
			"type": "string",
			"default": ""
		},
		"templateMode": {
			"type": "string",
			"default": "free",
			"enum": ["free", "grid-section", "card-grid"]
		},
		"gridTemplateColumns": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsMobile": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRows": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsMobile": {
			"type": "string",
			"default": ""
		},
		"gridAutoRows": {
			"type": "string",
			"default": ""
		},
		"gap": {
			"type": "string",
			"default": ""
		},
		"gapTablet": {
			"type": "string",
			"default": ""
		},
		"gapMobile": {
			"type": "string",
			"default": ""
		},
		"justifyContent": {
			"type": "string",
			"default": ""
		},
		"justifyItems": {
			"type": "string",
			"default": "stretch",
			"enum": ["stretch", "start", "center", "end"]
		},
		"alignContent": {
			"type": "string",
			"default": "stretch",
			"enum": ["stretch", "start", "center", "end", "space-between", "space-around", "space-evenly"]
		},
		"alignItems": {
			"type": "string",
			"default": ""
		},
		"columns": {
			"type": "number",
			"default": 2
		},
		"columnsMobile": {
			"type": "number",
			"default": 1
		},
		"columnsTablet": {
			"type": "number",
			"default": 2
		}
	},
	"providesContext": {
		"sgs/accordionStyle": "style",
		"sgs/accordionIconPosition": "iconPosition",
		"sgs/accordionHeaderColour": "headerColour",
		"sgs/accordionHeaderBackground": "headerBackground",
		"sgs/accordionIconColour": "iconColour",
		"sgs/accordionOpenIcon": "openIcon",
		"sgs/accordionCloseIcon": "closeIcon"
	},
	"allowedBlocks": [
		"sgs/accordion-item"
	],
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js",
	"example": {
		"attributes": {
			"style": "bordered",
			"allowMultiple": false,
			"iconPosition": "right"
		},
		"innerBlocks": [
			{
				"name": "sgs/accordion-item",
				"attributes": {
					"title": "What are your delivery options?"
				}
			},
			{
				"name": "sgs/accordion-item",
				"attributes": {
					"title": "What is your minimum order quantity?"
				}
			}
		]
	}
}
