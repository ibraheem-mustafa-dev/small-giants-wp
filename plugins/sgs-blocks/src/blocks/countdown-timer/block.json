{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/countdown-timer",
	"version": "0.1.0",
	"title": "SGS Countdown Timer",
	"category": "sgs-interactive",
	"description": "Countdown to a target date or an evergreen timer with customisable styling.",
	"keywords": [
		"countdown",
		"timer",
		"date",
		"event",
		"launch"
	],
	"textdomain": "sgs-blocks",
	"icon": "clock",
	"supports": {
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"textAlign": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		},
		"interactivity": true,
		"sgs": {
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				],
				"borderRadius": [
					"borderRadiusTablet",
					"borderRadiusMobile"
				]
			}
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-countdown-timer"
	},
	"attributes": {
		"targetDate": {
			"type": "string",
			"default": ""
		},
		"evergreenMode": {
			"type": "boolean",
			"default": false
		},
		"evergreenHours": {
			"type": "number",
			"default": 24
		},
		"evergreenMinutes": {
			"type": "number",
			"default": 0
		},
		"expiredMessage": {
			"type": "string",
			"default": "This offer has expired."
		},
		"showDays": {
			"type": "boolean",
			"default": true
		},
		"showHours": {
			"type": "boolean",
			"default": true
		},
		"showMinutes": {
			"type": "boolean",
			"default": true
		},
		"showSeconds": {
			"type": "boolean",
			"default": true
		},
		"numberColour": {
			"type": "string",
			"default": "primary"
		},
		"labelColour": {
			"type": "string",
			"default": "text-muted"
		},
		"cardStyle": {
			"type": "string",
			"default": "elevated"
		},
		"digitStyle": {
			"type": "string",
			"default": "simple"
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		},
		"borderRadiusTablet": {
			"type": "object",
			"default": {}
		},
		"borderRadiusMobile": {
			"type": "object",
			"default": {}
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScriptModule": "file:./view.js",
	"example": {
		"attributes": {
			"cardStyle": "elevated",
			"showDays": true,
			"showHours": true,
			"showMinutes": true,
			"showSeconds": true
		}
	}
}
