{
    "$schema":  "https://schemas.wp.org/trunk/block.json",
    "apiVersion":  3,
    "name":  "sgs/countdown-timer",
    "version":  "0.1.0",
    "title":  "SGS Countdown Timer",
    "category":  "sgs-interactive",
    "description":  "Countdown to a target date or an evergreen timer with customisable styling.",
    "keywords":  [
                     "countdown",
                     "timer",
                     "date",
                     "event",
                     "launch"
                 ],
    "textdomain":  "sgs-blocks",
    "icon":  "clock",
    "supports":  {
                     "align":  [
                                   "wide",
                                   "full"
                               ],
                     "anchor":  true,
                     "html":  false,
                     "color":  {
                                   "background":  true,
                                   "text":  true
                               },
                     "typography":  {
                                        "fontSize":  true,
                                        "textAlign":  true
                                    },
                     "spacing":  {
                                     "margin":  true,
                                     "padding":  true
                                 },
                     "__experimentalBorder":  {
                                                  "radius":  true,
                                                  "width":  true,
                                                  "color":  true,
                                                  "style":  true
                                              }
                 },
    "attributes":  {
                       "targetDate":  {
                                          "type":  "string",
                                          "default":  ""
                                      },
                       "evergreenMode":  {
                                             "type":  "boolean",
                                             "default":  false
                                         },
                       "evergreenHours":  {
                                              "type":  "number",
                                              "default":  24
                                          },
                       "evergreenMinutes":  {
                                                "type":  "number",
                                                "default":  0
                                            },
                       "expiredMessage":  {
                                              "type":  "string",
                                              "default":  "This offer has expired."
                                          },
                       "showDays":  {
                                        "type":  "boolean",
                                        "default":  true
                                    },
                       "showHours":  {
                                         "type":  "boolean",
                                         "default":  true
                                     },
                       "showMinutes":  {
                                           "type":  "boolean",
                                           "default":  true
                                       },
                       "showSeconds":  {
                                           "type":  "boolean",
                                           "default":  true
                                       },
                       "numberColour":  {
                                            "type":  "string",
                                            "default":  "primary"
                                        },
                       "labelColour":  {
                                           "type":  "string",
                                           "default":  "text-muted"
                                       },
                       "separatorColour":  {
                                               "type":  "string",
                                               "default":  "border-subtle"
                                           },
                       "cardStyle":  {
                                         "type":  "string",
                                         "default":  "elevated"
                                     }
                   },
    "editorScript":  "file:./index.js",
    "editorStyle":  "file:./index.css",
    "style":  "file:./style-index.css",
    "render":  "file:./render.php",
    "viewScriptModule":  "file:./view.js",
    "example":  {
                    "attributes":  {
                                       "cardStyle":  "elevated",
                                       "showDays":  true,
                                       "showHours":  true,
                                       "showMinutes":  true,
                                       "showSeconds":  true
                                   }
                }
}