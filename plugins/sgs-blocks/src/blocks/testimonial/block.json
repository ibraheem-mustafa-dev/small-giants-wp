{
    "$schema":  "https://schemas.wp.org/trunk/block.json",
    "apiVersion":  3,
    "name":  "sgs/testimonial",
    "version":  "0.1.0",
    "title":  "SGS Testimonial",
    "category":  "sgs-content",
    "description":  "Single testimonial card with quote, name, role, optional avatar, and star rating.",
    "keywords":  [
                     "testimonial",
                     "review",
                     "quote",
                     "feedback",
                     "rating"
                 ],
    "textdomain":  "sgs-blocks",
    "icon":  "format-quote",
    "supports":  {
                     "align":  false,
                     "anchor":  true,
                     "html":  false,
                     "color":  {
                                   "background":  true,
                                   "text":  true,
                                   "link":  true
                               },
                     "typography":  {
                                        "fontSize":  true,
                                        "lineHeight":  true,
                                        "textAlign":  true
                                    },
                     "spacing":  {
                                     "margin":  true,
                                     "padding":  true
                                 },
                     "shadow":  true,
                     "__experimentalBorder":  {
                                                  "radius":  true,
                                                  "width":  true,
                                                  "color":  true,
                                                  "style":  true
                                              }
                 },
    "selectors":  {
                      "root":  ".sgs-testimonial",
                      "typography":  ".sgs-testimonial__quote"
                  },
    "attributes":  {
                       "quote":  {
                                     "type":  "string",
                                     "source":  "html",
                                     "selector":  ".sgs-testimonial__quote"
                                 },
                       "name":  {
                                    "type":  "string",
                                    "source":  "html",
                                    "selector":  ".sgs-testimonial__name"
                                },
                       "role":  {
                                    "type":  "string",
                                    "source":  "html",
                                    "selector":  ".sgs-testimonial__role"
                                },
                       "avatar":  {
                                      "type":  "object"
                                  },
                       "rating":  {
                                      "type":  "number",
                                      "default":  0
                                  },
                       "style":  {
                                     "type":  "string",
                                     "default":  "card"
                                 },
                       "quoteColour":  {
                                           "type":  "string"
                                       },
                       "nameColour":  {
                                          "type":  "string"
                                      },
                       "nameFontSize":  {
                                            "type":  "string"
                                        },
                       "roleColour":  {
                                          "type":  "string"
                                      },
                       "ratingColour":  {
                                            "type":  "string",
                                            "default":  "accent"
                                        },
                       "reviewSource":  {
                                            "type":  "string",
                                            "default":  ""
                                        },
                       "reviewDate":  {
                                          "type":  "string",
                                          "default":  ""
                                      }
                   },
    "editorScript":  "file:./index.js",
    "editorStyle":  "file:./index.css",
    "style":  "file:./style-index.css",
    "example":  {
                    "attributes":  {
                                       "quote":  "The quality and reliability of SGS has been outstanding. Next-day delivery keeps our kitchen running smoothly.",
                                       "name":  "James Thornton",
                                       "role":  "Head Chef, The Grand Hotel",
                                       "rating":  5,
                                       "style":  "card"
                                   }
                }
}
