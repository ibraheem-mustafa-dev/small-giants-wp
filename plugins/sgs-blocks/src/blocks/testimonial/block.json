{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/testimonial",
	"version": "0.3.4",
	"title": "SGS Testimonial",
	"category": "sgs-content",
	"description": "Single testimonial with 7 layout variants — quote, attribution, optional avatar, organisation logo, work media, and a fully optional rating.",
	"keywords": [
		"testimonial",
		"review",
		"quote",
		"feedback",
		"rating",
		"case study"
	],
	"textdomain": "sgs-blocks",
	"icon": "format-quote",
	"supports": {
		"align": false,
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"link": true,
			"gradients": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"letterSpacing": true,
			"textTransform": true,
			"fontWeight": true,
			"fontStyle": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"shadow": {
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"imageControls": true,
			"containerKind": "content",
			"scalarContentLift": true,
			"elements": {
				"quote-box": {
					"label": "Quote box",
					"order": 1,
					"clusters": [ "fill", "layout" ],
					"isWrapper": true,
					"attrMap": {
						"css:background-color": "native:color.background",
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin",
						"css:max-width": "maxWidth",
						"css:border-width": "native:__experimentalBorder.width",
						"css:border-style": "native:__experimentalBorder.style",
						"css:border-color": "native:__experimentalBorder.color",
						"css:border-radius": "native:__experimentalBorder.radius"
					}
				},
				"quote-text": {
					"label": "Quote text",
					"order": 2,
					"clusters": [ "text" ],
					"prefix": "quote"
				},
				"reviewer-name": {
					"label": "Reviewer name",
					"order": 3,
					"clusters": [ "text" ],
					"prefix": "name"
				},
				"reviewer-role": {
					"label": "Reviewer role",
					"order": 4,
					"clusters": [ "text" ],
					"prefix": "role"
				},
				"org-name": {
					"label": "Organisation name",
					"order": 5,
					"clusters": [ "text" ],
					"prefix": "org"
				},
				"avatar-image": {
					"label": "Avatar image",
					"order": 6,
					"clusters": [],
					"_note": "Governed by the universal image-controls extension (supports.sgs.imageControls), not the Text/Fill/Layout style clusters."
				},
				"org-logo-image": {
					"label": "Organisation logo",
					"order": 7,
					"clusters": [],
					"_note": "Governed by the universal image-controls extension (supports.sgs.imageControls), not the Text/Fill/Layout style clusters."
				},
				"work-media": {
					"label": "Work / case-study media",
					"order": 8,
					"clusters": [],
					"_note": "Governed by the universal image-controls extension (supports.sgs.imageControls) plus workMedia's own picker, not the Text/Fill/Layout style clusters."
				},
				"rating": {
					"label": "Rating",
					"order": 9,
					"clusters": [ "text" ],
					"prefix": "rating",
					"attrMap": {
						"css:font-size": "ratingSize"
					}
				}
			},
			"variantAttr": "variant",
			"variants": {
				"classic-card": [
					"ratingStars"
				],
				"pull-quote-editorial": [
					"summaryPhrase"
				],
				"rating-led": [
					"ratingScale",
					"verified",
					"reviewDate",
					"sourcePlatform"
				],
				"avatar-spotlight": [
					"avatarMedia"
				],
				"corporate-logo": [
					"orgLogo"
				],
				"case-study-media": [
					"workMedia"
				],
				"minimal-quote": []
			},
			"scalarStylingLift": true,
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				]
			}
		}
	},
	"usesContext": [
		"sgs/testimonialVariant"
	],
	"selectors": {
		"root": ".sgs-testimonial",
		"typography": ".sgs-testimonial__quote"
	},
	"attributes": {
		"variant": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"classic-card",
				"pull-quote-editorial",
				"rating-led",
				"avatar-spotlight",
				"corporate-logo",
				"case-study-media",
				"minimal-quote"
			]
		},
		"quote": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"summaryPhrase": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"reviewerName": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"reviewerRole": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"orgName": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"avatarMedia": {
			"type": "object",
			"default": null
		},
		"orgLogo": {
			"type": "object",
			"default": null
		},
		"workMedia": {
			"type": "object",
			"default": null
		},
		"showRating": {
			"type": "boolean",
			"default": false
		},
		"ratingType": {
			"type": "string",
			"default": "stars",
			"enum": [
				"stars",
				"scale"
			]
		},
		"ratingStars": {
			"type": "number",
			"default": 0
		},
		"ratingScale": {
			"type": "number",
			"default": 0
		},
		"ratingScaleMax": {
			"type": "string",
			"default": "10"
		},
		"reviewDate": {
			"type": "string",
			"default": ""
		},
		"verified": {
			"type": "boolean",
			"default": false
		},
		"sourcePlatform": {
			"type": "string",
			"default": ""
		},
		"schemaEnabled": {
			"type": "boolean",
			"default": false
		},
		"quoteFontSize": {
			"type": "string",
			"default": ""
		},
		"quoteColour": {
			"type": "string",
			"default": ""
		},
		"quoteFontStyle": {
			"type": "string",
			"default": "",
			"description": "Font style for the quote text. 'italic' or empty for normal."
		},
		"quoteLineHeight": {
			"type": "string",
			"default": "",
			"description": "Line height for the quote text. Raw CSS value (e.g. 1.6, 2em). Empty = default."
		},
		"quoteMarginBottom": {
			"type": "string",
			"default": "",
			"description": "Space below the quote text. Raw CSS value (e.g. 16px, 1.5rem). Empty = theme default (spacing--30)."
		},
		"summaryFontSize": {
			"type": "string",
			"default": ""
		},
		"summaryColour": {
			"type": "string",
			"default": ""
		},
		"nameFontWeight": {
			"type": "string",
			"default": "700"
		},
		"nameColour": {
			"type": "string",
			"default": ""
		},
		"roleColour": {
			"type": "string",
			"default": ""
		},
		"orgColour": {
			"type": "string",
			"default": ""
		},
		"ratingSize": {
			"type": "number",
			"default": 16
		},
		"ratingColour": {
			"type": "string",
			"default": ""
		},
		"_comment_legacyAvatar": "RETIRED attr — kept registered ONLY so render.php can one-way READ avatar.url → avatarMedia for un-migrated posts (synthesise-on-read; R-22-14 compliant). deprecated.js v8 migrates it permanently. Do NOT write to this attr from edit.js.",
		"avatar": {
			"type": "object"
		},
		"backgroundColourHover": {
			"type": "string",
			"default": ""
		},
		"textColourHover": {
			"type": "string",
			"default": ""
		},
		"borderColourHover": {
			"type": "string",
			"default": ""
		},
		"effectHover": {
			"type": "string",
			"default": "none"
		},
		"transitionDuration": {
			"type": "string",
			"default": "300"
		},
		"transitionEasing": {
			"type": "string",
			"default": "ease-in-out"
		},
		"scaleHover": {
			"type": "string",
			"default": ""
		},
		"shadowHover": {
			"type": "string",
			"default": ""
		},
		"staggerDelay": {
			"type": "number",
			"default": 0
		},
		"sgsAnimation": {
			"type": "string",
			"default": "fade-up"
		},
		"sgsAnimationDuration": {
			"type": "string",
			"default": "medium"
		},
		"sgsAnimationEasing": {
			"type": "string",
			"default": "default"
		},
		"_comment_wrapperAttrs": "WS-4 container-mirror (CONTENT kind): width/spacing only — mirrored verbatim from sgs/container block.json.",
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		},
		"_comment_boxTiers": "No-inline migration contract §B: tablet/mobile tier overrides for the WP-native style.spacing.padding/margin base (paddingTablet/paddingMobile/marginTablet/marginMobile).",
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"example": {
		"attributes": {
			"variant": "classic-card",
			"quote": "The quality and reliability of SGS has been outstanding. Next-day delivery keeps our kitchen running smoothly.",
			"reviewerName": "James Thornton",
			"reviewerRole": "Head Chef",
			"orgName": "The Grand Hotel",
			"showRating": true,
			"ratingStars": 5
		}
	}
}
