{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/testimonial",
	"version": "0.3.3",
	"title": "SGS Testimonial",
	"category": "sgs-content",
	"description": "Single testimonial with 7 layout variants — quote, attribution, optional avatar, organisation logo, work media, and a fully optional rating.",
	"keywords": [
		"testimonial",
		"review",
		"quote",
		"feedback",
		"rating",
		"case study"
	],
	"textdomain": "sgs-blocks",
	"icon": "format-quote",
	"supports": {
		"align": false,
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"link": true,
			"gradients": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"letterSpacing": true,
			"textTransform": true,
			"fontWeight": true,
			"fontStyle": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"shadow": true,
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true
		},
		"sgs": {
			"imageControls": true,
			"containerKind": "content",
			"scalarContentLift": true,
			"variantAttr": "variant",
			"variants": {
				"classic-card": [
					"ratingStars"
				],
				"pull-quote-editorial": [
					"summaryPhrase"
				],
				"rating-led": [
					"ratingScale",
					"verified",
					"reviewDate",
					"sourcePlatform"
				],
				"avatar-spotlight": [
					"avatarMedia"
				],
				"corporate-logo": [
					"orgLogo"
				],
				"case-study-media": [
					"workMedia"
				],
				"minimal-quote": []
			},
			"scalarStylingLift": true
		}
	},
	"selectors": {
		"root": ".sgs-testimonial",
		"typography": ".sgs-testimonial__quote"
	},
	"attributes": {
		"variant": {
			"type": "string",
			"default": "classic-card",
			"enum": [
				"classic-card",
				"pull-quote-editorial",
				"rating-led",
				"avatar-spotlight",
				"corporate-logo",
				"case-study-media",
				"minimal-quote"
			]
		},
		"quote": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"summaryPhrase": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"reviewerName": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"reviewerRole": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"orgName": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"avatarMedia": {
			"type": "object",
			"default": null
		},
		"orgLogo": {
			"type": "object",
			"default": null
		},
		"workMedia": {
			"type": "object",
			"default": null
		},
		"showRating": {
			"type": "boolean",
			"default": false
		},
		"ratingType": {
			"type": "string",
			"default": "stars",
			"enum": [
				"stars",
				"scale"
			]
		},
		"ratingStars": {
			"type": "number",
			"default": 0
		},
		"ratingScale": {
			"type": "number",
			"default": 0
		},
		"ratingScaleMax": {
			"type": "string",
			"default": "10"
		},
		"reviewDate": {
			"type": "string",
			"default": ""
		},
		"verified": {
			"type": "boolean",
			"default": false
		},
		"sourcePlatform": {
			"type": "string",
			"default": ""
		},
		"schemaEnabled": {
			"type": "boolean",
			"default": false
		},
		"quoteFontSize": {
			"type": "string",
			"default": ""
		},
		"quoteColour": {
			"type": "string",
			"default": ""
		},
		"quoteStyle": {
			"type": "string",
			"default": "",
			"description": "Font style for the quote text. 'italic' or empty for normal."
		},
		"quoteLineHeight": {
			"type": "string",
			"default": "",
			"description": "Line height for the quote text. Raw CSS value (e.g. 1.6, 2em). Empty = default."
		},
		"summaryFontSize": {
			"type": "string",
			"default": ""
		},
		"summaryColour": {
			"type": "string",
			"default": ""
		},
		"nameFontWeight": {
			"type": "string",
			"default": "700"
		},
		"nameColour": {
			"type": "string",
			"default": ""
		},
		"roleColour": {
			"type": "string",
			"default": ""
		},
		"orgColour": {
			"type": "string",
			"default": ""
		},
		"ratingSize": {
			"type": "number",
			"default": 16
		},
		"ratingColour": {
			"type": "string",
			"default": ""
		},
		"_comment_legacyAvatar": "RETIRED attr — kept registered ONLY so render.php can one-way READ avatar.url → avatarMedia for un-migrated posts (synthesise-on-read; R-22-14 compliant). deprecated.js v8 migrates it permanently. Do NOT write to this attr from edit.js.",
		"avatar": {
			"type": "object"
		},
		"hoverBackgroundColour": {
			"type": "string",
			"default": ""
		},
		"hoverTextColour": {
			"type": "string",
			"default": ""
		},
		"hoverBorderColour": {
			"type": "string",
			"default": ""
		},
		"hoverEffect": {
			"type": "string",
			"default": "none"
		},
		"transitionDuration": {
			"type": "string",
			"default": "300"
		},
		"transitionEasing": {
			"type": "string",
			"default": "ease-in-out"
		},
		"hoverScale": {
			"type": "string",
			"default": ""
		},
		"hoverShadow": {
			"type": "string",
			"default": ""
		},
		"staggerDelay": {
			"type": "number",
			"default": 0
		},
		"sgsAnimation": {
			"type": "string",
			"default": "fade-up"
		},
		"sgsAnimationDuration": {
			"type": "string",
			"default": "medium"
		},
		"sgsAnimationEasing": {
			"type": "string",
			"default": "default"
		},
		"_comment_wrapperAttrs": "WS-4 container-mirror (CONTENT kind): width/spacing only — mirrored verbatim from sgs/container block.json.",
		"customWidth": {
			"type": "number",
			"default": 0
		},
		"customWidthUnit": {
			"type": "string",
			"default": "px"
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"example": {
		"attributes": {
			"variant": "classic-card",
			"quote": "The quality and reliability of SGS has been outstanding. Next-day delivery keeps our kitchen running smoothly.",
			"reviewerName": "James Thornton",
			"reviewerRole": "Head Chef",
			"orgName": "The Grand Hotel",
			"showRating": true,
			"ratingStars": 5
		}
	}
}
