{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/icon",
	"version": "0.3.0",
	"title": "SGS Icon",
	"category": "sgs-content",
	"description": "Icon from multiple sources — Lucide SVG, WordPress icons, Dashicons, or emoji — with size, colour, optional background shape, and optional link.",
	"keywords": [
		"icon",
		"svg",
		"lucide",
		"dashicon",
		"emoji",
		"symbol",
		"graphic"
	],
	"textdomain": "sgs-blocks",
	"icon": "heart",
	"supports": {
		"align": [
			"left",
			"center",
			"right"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"imageControls": false,
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				]
			},
			"elements": {
				"icon": {
					"label": "Icon",
					"order": 1,
					"clusters": [ "text", "fill", "layout" ],
					"isWrapper": true,
					"attrMap": {
						"css:color": "iconColour",
						"css:background-color": "backgroundColour"
					},
					"states": {
						"hover": {
							"attrMap": {
								"css:color": "iconColourHover",
								"css:background-color": "shapeColourHover"
							}
						}
					},
					"_note": "Single-semantic-element block — the root <div> (or <a> when linkUrl is set) IS the icon element (render.php). css:color/background-color map to iconColour/backgroundColour rather than native: paths — render.php steps 3-4 drive the literal colour/shape-fill declarations from these SGS attrs directly. css:padding/margin resolve via the native fallback (isWrapper + spacing support). `backgroundPadding` is a bespoke single-value shape-inset control (Spec 32 §6.1c — deliberately NOT a BoxControl padding family) with no cluster member of its own, same carve-out reasoning as sgs/button's icon element (clusters: []) — left an honest orphan, not force-mapped. iconSize/iconAlign/scaleHover are bespoke icon controls with no Spec 35 vocabulary member (no size/scale/align member exists) — left unclaimed. No border-width/style/box-shadow/width/height/gap/aspect-ratio attrs on this block — honest gaps."
				}
			}
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-icon"
	},
	"attributes": {
		"iconSource": {
			"type": "string",
			"default": "lucide",
			"enum": [
				"lucide",
				"wp-icon",
				"dashicon",
				"emoji"
			]
		},
		"iconName": {
			"type": "string",
			"default": "star"
		},
		"emojiChar": {
			"type": "string",
			"default": ""
		},
		"dashiconName": {
			"type": "string",
			"default": ""
		},
		"wpIconName": {
			"type": "string",
			"default": ""
		},
		"iconSize": {
			"type": "number",
			"default": 32
		},
		"iconColour": {
			"type": "string",
			"default": "primary"
		},
		"backgroundColour": {
			"type": "string",
			"default": "surface-alt"
		},
		"backgroundShape": {
			"type": "string",
			"default": "none",
			"enum": [
				"none",
				"circle",
				"pill",
				"square",
				"rounded",
				"outline"
			]
		},
		"backgroundPadding": {
			"type": "string",
			"default": "",
			"description": "Padding inside the background shape (circle/pill/rounded/square/outline). Raw CSS length (e.g. 12px, 0.75rem). Empty = theme default (12px). Single uniform value — NOT a 4-side box family (Spec 32 6.1c) — emitted scoped, not inline."
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		},
		"linkUrl": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"linkTarget": {
			"type": "string",
			"default": "_self",
			"enum": [
				"_self",
				"_blank"
			]
		},
		"linkRel": {
			"type": "string",
			"default": ""
		},
		"ariaLabel": {
			"type": "string",
			"default": ""
		},
		"iconColourHover": {
			"type": "string",
			"default": "accent-text"
		},
		"shapeColourHover": {
			"type": "string",
			"default": ""
		},
		"scaleHover": {
			"type": "number",
			"default": 1.1
		},
		"iconAlign": {
			"type": "string",
			"default": "left",
			"enum": [
				"left",
				"center",
				"right"
			]
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"example": {
		"attributes": {
			"iconName": "star",
			"iconSize": 48,
			"iconColour": "primary",
			"backgroundShape": "circle",
			"backgroundColour": "surface-alt"
		}
	}
}
