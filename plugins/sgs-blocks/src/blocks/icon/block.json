{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/icon",
	"version": "0.1.0",
	"title": "SGS Icon",
	"category": "sgs-content",
	"description": "Standalone SVG icon with size, colour, background, and optional link.",
	"keywords": [
		"icon",
		"svg",
		"symbol",
		"graphic"
	],
	"textdomain": "sgs-blocks",
	"icon": "heart",
	"supports": {
		"align": [ "center", "wide", "full" ],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-icon"
	},
	"attributes": {
		"icon": {
			"type": "string",
			"default": "star"
		},
		"size": {
			"type": "number",
			"default": 48
		},
		"iconColour": {
			"type": "string",
			"default": "primary"
		},
		"backgroundColour": {
			"type": "string",
			"default": "surface-alt"
		},
		"backgroundShape": {
			"type": "string",
			"default": "circle"
		},
		"link": {
			"type": "string",
			"default": ""
		},
		"linkOpensNewTab": {
			"type": "boolean",
			"default": false
		},
		"linkLabel": {
			"type": "string",
			"default": ""
		},
		"hoverColour": {
			"type": "string",
			"default": "accent-text"
		},
		"hoverScale": {
			"type": "number",
			"default": 1.1
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"example": {
		"attributes": {
			"icon": "star",
			"size": 48,
			"iconColour": "primary",
			"backgroundShape": "circle",
			"backgroundColour": "surface-alt"
		}
	}
}
