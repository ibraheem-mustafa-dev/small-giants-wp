{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/audio",
	"version": "1.0.0",
	"title": "SGS Audio",
	"category": "sgs-content",
	"description": "Audio player with seven visual styles — from a quiet minimal pill to live spectrum bars, an oscilloscope, and a gradient that pulses to the sound. Reacts to the real audio via the Web Audio API; falls back to a native player with no JavaScript.",
	"keywords": [
		"audio",
		"sound",
		"player",
		"podcast",
		"music",
		"visualiser"
	],
	"textdomain": "sgs-blocks",
	"icon": "format-audio",
	"supports": {
		"anchor": true,
		"className": true,
		"color": false,
		"html": false,
		"align": [
			"wide",
			"full"
		],
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				]
			},
			"elements": {
				"wrapper": {
					"label": "Player wrapper",
					"order": 1,
					"clusters": [ "layout" ],
					"isWrapper": true,
					"attrMap": {
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin"
					}
				},
				"accent": {
					"label": "Accent colour",
					"order": 2,
					"clusters": [ "fill" ],
					"prefix": "accent",
					"attrMap": {
						"css:background-color": "accentColour"
					},
					"_note": "accentColour is the player-brand colour (play button fill, seek thumb, progress arc — CSS var --sgs-audio-accent, style.css:61/86/94/103/107/174, all `background`/`background-image` uses). Mapped to css:background-color via explicit attrMap (Spec 35 vocabulary fix) rather than left as an honest zero-cluster orphan."
				},
				"spectrum": {
					"label": "Spectrum colour",
					"order": 3,
					"clusters": [],
					"prefix": "spectrum",
					"_note": "spectrumColour drives the reactive spectrum/oscilloscope visualiser accent (--sgs-audio-spectrum) — a functional signal colour, not a styled element. Same ORPHAN treatment as accent."
				}
			}
		}
	},
	"attributes": {
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		},
		"audioUrl": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"audioSource": {
			"type": "string",
			"default": "external",
			"enum": [
				"external",
				"internal"
			]
		},
		"audioId": {
			"type": "integer",
			"default": null
		},
		"audioMimeType": {
			"type": "string",
			"default": ""
		},
		"playerStyle": {
			"type": "string",
			"default": "minimal",
			"enum": [
				"minimal",
				"waveform",
				"spectrum",
				"radial",
				"oscilloscope",
				"gradient-pulse",
				"hidden"
			]
		},
		"audioControls": {
			"type": "boolean",
			"default": true
		},
		"audioLoop": {
			"type": "boolean",
			"default": false
		},
		"audioAutoplay": {
			"type": "boolean",
			"default": false
		},
		"audioPreload": {
			"type": "string",
			"default": "metadata",
			"enum": [
				"none",
				"metadata",
				"auto"
			]
		},
		"accentColour": {
			"type": "string",
			"default": ""
		},
		"spectrumColour": {
			"type": "string",
			"default": ""
		},
		"title": {
			"type": "string",
			"default": "",
			"role": "content"
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScriptModule": "file:./view.js"
}
