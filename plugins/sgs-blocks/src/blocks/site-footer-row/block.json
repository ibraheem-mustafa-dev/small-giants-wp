{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/site-footer-row",
	"version": "0.1.0",
	"title": "SGS Footer Row",
	"category": "sgs-layout",
	"icon": "columns",
	"description": "One row of a site footer — either a never-overflow cluster (top strip / bottom bar) or a column grid (up to 6 columns collapsing to 1 below the mobile tier). Lives inside sgs/site-footer.",
	"keywords": [
		"footer row",
		"site footer",
		"columns",
		"cluster"
	],
	"textdomain": "sgs-blocks",
	"parent": [
		"sgs/site-footer"
	],
	"supports": {
		"anchor": true,
		"customClassName": true,
		"html": false,
		"reusable": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"containerKind": "layout"
		}
	},
	"attributes": {
		"rowSlot": {
			"type": "string",
			"default": ""
		},
		"layout": {
			"type": "string",
			"default": "grid"
		},
		"gridTemplateColumns": {
			"type": "object",
			"default": { "desktop": "repeat(3, 1fr)", "mobile": "1fr" }
		},
		"flexWrap": {
			"type": "string",
			"default": "wrap"
		},
		"justifyContent": {
			"type": "string",
			"default": ""
		},
		"verticalAlign": {
			"type": "string",
			"default": "top"
		},
		"gap": {
			"type": "object",
			"default": { "desktop": "48px", "mobile": "32px" }
		},
		"maxWidth": {
			"type": "object",
			"default": {}
		},
		"contentWidth": {
			"type": "object",
			"default": { "desktop": "full" }
		},
		"padding": {
			"type": "object",
			"default": {}
		},
		"margin": {
			"type": "object",
			"default": {}
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
