{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/site-header",
	"version": "0.1.0",
	"title": "SGS Site Header",
	"category": "sgs-layout",
	"icon": "menu",
	"description": "The site header shell — three optional rows (top / middle / bottom) of header elements. Each row is an intrinsic never-overflow cluster, so the header never overflows the viewport at any width. Lives inside the header template part.",
	"keywords": [
		"site header",
		"header",
		"masthead",
		"navigation"
	],
	"textdomain": "sgs-blocks",
	"supports": {
		"anchor": true,
		"customClassName": true,
		"html": false,
		"reusable": false,
		"align": [
			"full"
		],
		"color": {
			"background": true,
			"text": true,
			"gradients": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"containerKind": "section"
		}
	},
	"allowedBlocks": [
		"sgs/site-header-row"
	],
	"attributes": {
		"maxWidth": { "type": "string", "default": "" },
		"maxWidthTablet": { "type": "string", "default": "" },
		"maxWidthMobile": { "type": "string", "default": "" },
		"contentWidth": { "type": "string", "default": "full" },
		"contentWidthTablet": { "type": "string", "default": "" },
		"contentWidthMobile": { "type": "string", "default": "" },
		"paddingTopTablet": { "type": "string", "default": "" },
		"paddingRightTablet": { "type": "string", "default": "" },
		"paddingBottomTablet": { "type": "string", "default": "" },
		"paddingLeftTablet": { "type": "string", "default": "" },
		"paddingTopMobile": { "type": "string", "default": "" },
		"paddingRightMobile": { "type": "string", "default": "" },
		"paddingBottomMobile": { "type": "string", "default": "" },
		"paddingLeftMobile": { "type": "string", "default": "" },
		"marginTopTablet": { "type": "string", "default": "" },
		"marginRightTablet": { "type": "string", "default": "" },
		"marginBottomTablet": { "type": "string", "default": "" },
		"marginLeftTablet": { "type": "string", "default": "" },
		"marginTopMobile": { "type": "string", "default": "" },
		"marginRightMobile": { "type": "string", "default": "" },
		"marginBottomMobile": { "type": "string", "default": "" },
		"marginLeftMobile": { "type": "string", "default": "" }
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
