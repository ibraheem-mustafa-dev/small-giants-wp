{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/product-search",
	"version": "1.1.0",
	"title": "Product Search",
	"category": "sgs-interactive",
	"description": "Accessible combobox search that fetches live product suggestions. Includes a no-JS fallback form that submits to the theme's product-scoped search results page.",
	"keywords": [
		"search",
		"product",
		"woocommerce",
		"shop",
		"autocomplete",
		"combobox"
	],
	"textdomain": "sgs-blocks",
	"icon": "search",
	"supports": {
		"html": false,
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"align": [
			"wide"
		],
		"sgs": {
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				]
			},
			"elements": {
				"wrapper": {
					"label": "Search wrapper",
					"order": 1,
					"clusters": [ "layout" ],
					"isWrapper": true,
					"attrMap": {
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin"
					},
					"_note": "No color, typography or __experimentalBorder support is declared on this block at all. clusters is deliberately scoped to layout (native spacing only) to avoid a zero-resolution declaration (ROLLOUT REQUIREMENT 1)."
				}
			}
		}
	},
	"attributes": {
		"displayMode": {
			"type": "string",
			"default": "inline-bar"
		},
		"placeholder": {
			"type": "string",
			"default": ""
		},
		"buttonLabel": {
			"type": "string",
			"default": ""
		},
		"maxResults": {
			"type": "integer",
			"default": 10
		},
		"maxResultsMobile": {
			"type": "integer",
			"default": 6
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js"
}
