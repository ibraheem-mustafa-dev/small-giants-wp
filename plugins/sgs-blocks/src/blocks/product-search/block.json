{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/product-search",
	"version": "1.0.0",
	"title": "Product Search",
	"category": "sgs-interactive",
	"description": "Accessible combobox search that fetches live product suggestions. Includes a no-JS fallback form that submits to the theme's product-scoped search results page.",
	"keywords": [
		"search",
		"product",
		"woocommerce",
		"shop",
		"autocomplete",
		"combobox"
	],
	"textdomain": "sgs-blocks",
	"icon": "search",
	"supports": {
		"html": false,
		"spacing": {
			"margin": true,
			"padding": true
		},
		"align": [ "wide" ]
	},
	"attributes": {
		"placeholder": {
			"type": "string",
			"default": ""
		},
		"buttonLabel": {
			"type": "string",
			"default": ""
		},
		"maxResults": {
			"type": "integer",
			"default": 10
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js"
}
