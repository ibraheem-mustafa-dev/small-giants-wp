{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/adaptive-nav",
	"version": "0.1.0",
	"title": "SGS Adaptive Navigation",
	"category": "sgs-layout",
	"icon": "menu",
	"description": "One menu source that renders a desktop navigation bar and collapses to the off-canvas drawer at a configurable breakpoint. Submenus become accessible mega-panels; overflow auto-collapses into a More menu. Replaces core/navigation in the header. Lives inside sgs/site-header-row.",
	"keywords": [
		"navigation",
		"nav",
		"menu",
		"adaptive",
		"mega menu"
	],
	"textdomain": "sgs-blocks",
	"parent": [
		"sgs/site-header-row"
	],
	"supports": {
		"anchor": true,
		"customClassName": true,
		"html": false,
		"reusable": false,
		"color": {
			"background": false,
			"text": true,
			"gradients": false,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"containerKind": "layout"
		}
	},
	"attributes": {
		"ref": {
			"type": "number"
		},
		"menuButtonLabel": {
			"type": "string",
			"default": "Menu"
		},
		"drawerLabel": {
			"type": "string",
			"default": "Navigation menu"
		},
		"showDrawerSocials": {
			"type": "boolean",
			"default": true
		},
		"drawerSide": {
			"type": "string",
			"default": "right",
			"enum": [ "left", "right" ]
		},
		"menuFallback": {
			"type": "string",
			"default": "page-list"
		},
		"collapseTier": {
			"type": "string",
			"default": "mobile",
			"enum": [ "mobile", "tablet", "desktop", "custom" ]
		},
		"collapseCustomPx": {
			"type": "number",
			"default": 768
		},
		"overflowBehaviour": {
			"type": "string",
			"default": "more-menu",
			"enum": [ "more-menu", "wrap", "scroll" ]
		},
		"moreMenuLabel": {
			"type": "string",
			"default": "More"
		},
		"navigationLabel": {
			"type": "string",
			"default": "Primary"
		},
		"linkColour": {
			"type": "string",
			"default": "text"
		},
		"linkHoverColour": {
			"type": "string",
			"default": "primary-dark"
		},
		"linkFontSize": {
			"type": "object",
			"default": { "desktop": "15px" }
		},
		"linkFontWeight": {
			"type": "string",
			"default": "500"
		},
		"linkFontStyle": {
			"type": "string",
			"default": ""
		},
		"linkLineHeight": {
			"type": "number"
		},
		"linkLineHeightUnit": {
			"type": "string",
			"default": ""
		},
		"layout": {
			"type": "string",
			"default": "flex"
		},
		"flexWrap": {
			"type": "string",
			"default": "wrap"
		},
		"justifyContent": {
			"type": "string",
			"default": ""
		},
		"verticalAlign": {
			"type": "string",
			"default": "center"
		},
		"gap": {
			"type": "object",
			"default": { "desktop": "28px" }
		},
		"maxWidth": {
			"type": "object",
			"default": {}
		},
		"contentWidth": {
			"type": "object",
			"default": { "desktop": "full" }
		},
		"padding": {
			"type": "object",
			"default": {}
		},
		"margin": {
			"type": "object",
			"default": {}
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js"
}
