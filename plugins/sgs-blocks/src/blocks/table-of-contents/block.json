{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/table-of-contents",
	"version": "0.1.0",
	"title": "SGS Table of Contents",
	"category": "sgs-content",
	"description": "Auto-generated table of contents from heading blocks. Smooth scroll, scroll spy, collapsible.",
	"keywords": [
		"toc",
		"table of contents",
		"navigation",
		"headings",
		"index"
	],
	"textdomain": "sgs-blocks",
	"icon": "list-view",
	"supports": {
		"align": [
			"wide"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"link": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				],
				"borderRadius": [
					"borderRadiusTablet",
					"borderRadiusMobile"
				]
			},
			"elements": {
				"wrapper": {
					"label": "Wrapper",
					"order": 1,
					"clusters": [ "text", "fill", "layout" ],
					"isWrapper": true,
					"attrMap": {
						"css:color": "native:color.text",
						"css:background-color": "native:color.background",
						"css:font-size": "native:typography.fontSize",
						"css:line-height": "native:typography.lineHeight",
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin",
						"css:border-width": "native:__experimentalBorder.width",
						"css:border-style": "native:__experimentalBorder.style",
						"css:border-color": "native:__experimentalBorder.color",
						"css:border-radius": "native:__experimentalBorder.radius"
					},
					"_note": "Single-element block (the <nav> root) — no `layer` declared, so the 12 ARRANGEMENT members are never asked (this block has no grid/flex attrs at all — correct). Only fontSize+lineHeight are declared under typography support (no letterSpacing/textTransform/fontWeight/fontStyle/textAlign/fontFamily), no width/height/box-shadow/aspect-ratio/max-width attrs exist — all honest gaps."
				},
				"title": {
					"label": "TOC title",
					"order": 2,
					"clusters": [ "text" ],
					"prefix": "title",
					"attrMap": {
						"css:color": "titleColour"
					},
					"_note": "Only a design-token colour control exists for the title (titleColour) — resolves via default convention (`title`+`Colour`). No independent title font-size/weight/line-height control exists — honest gaps."
				},
				"link": {
					"label": "TOC link",
					"order": 3,
					"clusters": [ "text" ],
					"prefix": "link",
					"attrMap": {
						"css:color": "linkColour"
					},
					"states": {
						"selected": {
							"attrMap": {
								"css:color": "activeLinkColour"
							}
						}
					},
					"_note": "`activeLinkColour` styles the scroll-spy-active link (render.php:195 `.sgs-toc__link--active`, toggled by view.js) — a SELECTED state per FR-35-5, declared via explicit `states.selected.attrMap` because the naming is a PREFIX (`activeLinkColour`), not the mechanical suffix form, and would otherwise be unreachable by the default convention. No resting-state font-size/weight control exists on the link — honest gap."
				}
			}
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-table-of-contents",
		"typography": ".sgs-toc__title"
	},
	"attributes": {
		"headingLevels": {
			"type": "array",
			"default": [
				2,
				3,
				4
			]
		},
		"title": {
			"type": "string",
			"default": "Table of Contents",
			"role": "content"
		},
		"collapsible": {
			"type": "boolean",
			"default": true
		},
		"defaultCollapsed": {
			"type": "boolean",
			"default": false
		},
		"smoothScroll": {
			"type": "boolean",
			"default": true
		},
		"scrollOffset": {
			"type": "number",
			"default": 0
		},
		"scrollSpy": {
			"type": "boolean",
			"default": true
		},
		"listStyle": {
			"type": "string",
			"default": "numbered"
		},
		"tocStyle": {
			"type": "string",
			"default": "card"
		},
		"titleColour": {
			"type": "string",
			"default": "text"
		},
		"linkColour": {
			"type": "string",
			"default": "text-muted"
		},
		"activeLinkColour": {
			"type": "string",
			"default": "primary"
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		},
		"borderRadiusTablet": {
			"type": "object",
			"default": {}
		},
		"borderRadiusMobile": {
			"type": "object",
			"default": {}
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js",
	"example": {
		"attributes": {
			"title": "Table of Contents",
			"collapsible": true,
			"listStyle": "numbered",
			"tocStyle": "card"
		}
	}
}
