{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "sgs/decorative-image",
    "version": "0.3.0",
    "title": "SGS Decorative Image",
    "category": "sgs-content",
    "description": "Absolute-positioned decorative image that floats freely over sections. Used for organic, editorial-style design with optional parallax scroll effects.",
    "keywords": [
        "image",
        "decorative",
        "parallax",
        "float",
        "position"
    ],
    "textdomain": "sgs-blocks",
    "icon": "format-image",
    "supports": {
        "anchor": true,
        "html": false,
        "sgs": {
            "imageControls": true,
            "elements": {
                "image": {
                    "label": "Image",
                    "order": 1,
                    "clusters": [ "layout", "fill", "position" ],
                    "isWrapper": true,
                    "prefix": "",
                    "attrMap": {
                        "css:max-width": "maxWidthPercent",
                        "css:width": "width",
                        "css:opacity": "opacity",
                        "css:z-index": "zIndex"
                    },
                    "_note": "An empty-string prefix does NOT trigger the default-convention resolver (it's checked with `if (element.prefix)`, and '' is falsy) — so opacity/zIndex are mapped explicitly rather than relying on bare-attribute matching. positionX/positionY are percentage-based anchor coordinates for the whole floating element, not literal CSS top/bottom offsets or object-position within a box, so they are deliberately left unmapped — css:top/css:bottom stay genuine gaps rather than being force-mapped to a different semantic. No layer field is declared (this is not a composite). parallaxStrength/pathDrawDurationMs/pathDrawEasing are JS-driven scroll-triggered animation parameters, not CSS transitions, so the motion cluster is not declared here — mapping them to transition-duration/transition-timing-function would misrepresent the mechanism."
                }
            }
        }
    },
    "attributes": {
        "_comment_decorMedia": "Migrated 2026-05-05 — legacy imageId/imageUrl/imageAlt retained for deprecation. New instances should use decorMedia (unified image-or-video slot).",
        "decorMedia": {
            "type": "object",
            "default": null
        },
        "imageId": {
            "type": "number"
        },
        "imageUrl": {
            "type": "string",
            "role": "content"
        },
        "imageAlt": {
            "type": "string",
            "default": "",
            "role": "content"
        },
        "positionX": {
            "type": "number",
            "default": 50
        },
        "positionY": {
            "type": "number",
            "default": 50
        },
        "width": {
            "type": "number",
            "default": 200
        },
        "maxWidthPercent": {
            "type": "number",
            "default": 20
        },
        "rotation": {
            "type": "number",
            "default": 0
        },
        "opacity": {
            "type": "number",
            "default": 85
        },
        "zIndex": {
            "type": "number",
            "default": 1
        },
        "flipX": {
            "type": "boolean",
            "default": false
        },
        "parallaxStrength": {
            "type": "number",
            "default": 0
        },
        "fadeOnScroll": {
            "type": "boolean",
            "default": false
        },
        "overflow": {
            "type": "string",
            "default": "visible"
        },
        "positionXTablet": {
            "type": "number"
        },
        "positionYTablet": {
            "type": "number"
        },
        "widthTablet": {
            "type": "number"
        },
        "rotationTablet": {
            "type": "number"
        },
        "hideOnTablet": {
            "type": "boolean",
            "default": false
        },
        "positionXMobile": {
            "type": "number"
        },
        "positionYMobile": {
            "type": "number"
        },
        "widthMobile": {
            "type": "number"
        },
        "rotationMobile": {
            "type": "number"
        },
        "hideOnMobile": {
            "type": "boolean",
            "default": false
        },
        "pathDrawOnScroll": {
            "type": "boolean",
            "default": false
        },
        "pathDrawDurationMs": {
            "type": "number",
            "default": 1500
        },
        "pathDrawTriggerOffset": {
            "type": "number",
            "default": 20
        },
        "pathDrawEasing": {
            "type": "string",
            "default": "ease-out"
        }
    },
    "render": "file:./render.php",
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": "file:./style-index.css",
    "viewScriptModule": "file:./view.js",
    "example": {
        "attributes": {
            "positionX": 80,
            "positionY": 20,
            "width": 200,
            "rotation": 15,
            "opacity": 85
        }
    }
}
