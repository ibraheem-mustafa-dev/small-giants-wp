{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/tabs",
	"version": "0.2.0",
	"title": "SGS Tabs",
	"category": "sgs-interactive",
	"description": "Tabbed content with horizontal or vertical layout, full ARIA support, and deep linking via URL hash.",
	"keywords": [
		"tabs",
		"tabbed",
		"panels",
		"sections",
		"switch"
	],
	"textdomain": "sgs-blocks",
	"icon": "table-row-after",
	"supports": {
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-tabs"
	},
	"attributes": {
		"orientation": {
			"type": "string",
			"default": "horizontal",
			"enum": [
				"horizontal",
				"vertical"
			]
		},
		"tabAlignment": {
			"type": "string",
			"default": "left",
			"enum": [
				"left",
				"centre",
				"right",
				"stretch"
			]
		},
		"tabStyle": {
			"type": "string",
			"default": "underline",
			"enum": [
				"underline",
				"boxed",
				"pills"
			]
		},
		"tabTextColour": {
			"type": "string",
			"default": "text-muted"
		},
		"tabActiveTextColour": {
			"type": "string",
			"default": "primary"
		},
		"tabActiveBgColour": {
			"type": "string"
		},
		"tabActiveIndicatorColour": {
			"type": "string",
			"default": "primary"
		},
		"tabHoverBgColour": {
			"type": "string"
		},
		"panelBgColour": {
			"type": "string"
		},
		"panelBorderColour": {
			"type": "string",
			"default": "border-subtle"
		},
		"transitionDuration": {
			"type": "number",
			"default": 200
		},
		"widthMode": {
			"type": "string",
			"default": "default",
			"enum": [
				"default",
				"wide",
				"full",
				"custom"
			]
		},
		"widthModeMobile": {
			"type": "string",
			"default": ""
		},
		"widthModeTablet": {
			"type": "string",
			"default": ""
		},
		"widthModeDesktop": {
			"type": "string",
			"default": ""
		},
		"customWidth": {
			"type": "number",
			"default": 0
		},
		"customWidthUnit": {
			"type": "string",
			"default": "px"
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		},
		"layout": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumns": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsMobile": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRows": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsMobile": {
			"type": "string",
			"default": ""
		},
		"gridAutoRows": {
			"type": "string",
			"default": ""
		},
		"justifyItems": {
			"type": "string",
			"default": "stretch",
			"enum": [
				"stretch",
				"start",
				"center",
				"end"
			]
		},
		"alignContent": {
			"type": "string",
			"default": "stretch",
			"enum": [
				"stretch",
				"start",
				"center",
				"end",
				"space-between",
				"space-around",
				"space-evenly"
			]
		},
		"gap": {
			"type": "string",
			"default": ""
		},
		"gapTablet": {
			"type": "string",
			"default": ""
		},
		"gapMobile": {
			"type": "string",
			"default": ""
		},
		"columns": {
			"type": "number",
			"default": 2
		},
		"columnsMobile": {
			"type": "number",
			"default": 1
		},
		"columnsTablet": {
			"type": "number",
			"default": 2
		},
		"flexDirection": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"row",
				"column"
			]
		},
		"flexWrap": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"wrap",
				"nowrap"
			]
		},
		"justifyContent": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"flex-start",
				"center",
				"flex-end",
				"space-between",
				"space-around"
			]
		},
		"templateMode": {
			"type": "string",
			"default": "free",
			"enum": [
				"free",
				"grid-section",
				"card-grid"
			]
		}
	},
	"providesContext": {
		"sgs/tabsOrientation": "orientation",
		"sgs/tabsStyle": "tabStyle"
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js",
	"example": {
		"attributes": {
			"orientation": "horizontal",
			"tabStyle": "underline",
			"tabAlignment": "left"
		},
		"innerBlocks": [
			{
				"name": "sgs/tab",
				"attributes": {
					"label": "Overview"
				}
			},
			{
				"name": "sgs/tab",
				"attributes": {
					"label": "Specifications"
				}
			},
			{
				"name": "sgs/tab",
				"attributes": {
					"label": "Delivery"
				}
			}
		]
	}
}
