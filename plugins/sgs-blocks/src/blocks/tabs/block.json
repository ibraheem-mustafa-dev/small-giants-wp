{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/tabs",
	"version": "0.2.0",
	"title": "SGS Tabs",
	"category": "sgs-interactive",
	"description": "Tabbed content with horizontal or vertical layout, full ARIA support, and deep linking via URL hash.",
	"keywords": [
		"tabs",
		"tabbed",
		"panels",
		"sections",
		"switch"
	],
	"textdomain": "sgs-blocks",
	"icon": "table-row-after",
	"supports": {
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"elements": {
				"wrapper": {
					"label": "Wrapper",
					"layer": "OUTER",
					"order": 1,
					"clusters": [ "text", "fill", "layout" ],
					"isWrapper": true,
					"attrMap": {
						"css:color": "native:color.text",
						"css:background-color": "native:color.background",
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin",
						"css:border-width": "native:__experimentalBorder.width",
						"css:border-style": "native:__experimentalBorder.style",
						"css:border-color": "native:__experimentalBorder.color",
						"css:border-radius": "native:__experimentalBorder.radius",
						"css:max-width": "maxWidth"
					},
					"_note": "block.json declares no `typography` support at all on this block — every text-cluster member beyond colour is an honest gap. The 12 ARRANGEMENT members also apply here (layer OUTER) and are resolved by the sibling `grid` element."
				},
				"grid": {
					"label": "Grid / flex layout",
					"layer": "GRID",
					"order": 2,
					"clusters": [ "layout" ],
					"attrMap": {
						"css:gap": "gap",
						"css:grid-template-columns": "gridTemplateColumns",
						"css:grid-template-rows": "gridTemplateRows",
						"css:grid-auto-rows": "gridAutoRows",
						"css:justify-items": "justifyItems",
						"css:justify-content": "justifyContent",
						"css:align-content": "alignContent",
						"css:flex-direction": "flexDirection",
						"css:flex-wrap": "flexWrap"
					},
					"_note": "Composite-mirror grid capability (shared SGS_Container_Wrapper, kind='layout'). Maps explicitly — no `prefix` declared, so the default convention cannot resolve bare camelCase attrs (ROLLOUT REQUIREMENT 1). This block has NO `alignItems` attribute at all — an honest gap, not an omission."
				},
				"tab": {
					"label": "Tab (resting state)",
					"order": 3,
					"clusters": [ "text", "fill", "motion" ],
					"attrMap": {
						"css:color": "tabTextColour",
						"css:transition-duration": "transitionDuration"
					},
					"_note": "Resting-state colour + shared transition duration only. tabActiveTextColour/tabActiveBgColour/tabActiveIndicatorColour/tabHoverBgColour are ACTIVE/HOVER state variants — the manifest schema has no states/pseudo axis (Spec 35 'Out of scope'), so they surface as ORPHANs under this element's fallback prefix `tab`, not gaps; that is the correct, honest outcome. No resting background-colour attribute exists (only active/hover) — an honest gap. No transition-timing-function attribute exists on this block — also an honest gap."
				},
				"panel": {
					"label": "Tab panel",
					"order": 4,
					"clusters": [ "fill", "layout" ],
					"attrMap": {
						"css:background-color": "panelBgColour",
						"css:border-color": "panelBorderColour"
					},
					"_note": "Only background + border-colour are independently controlled for the panel — the remaining fill/layout members are honest gaps."
				}
			}
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-tabs"
	},
	"attributes": {
		"blockLabel": {
			"type": "string",
			"default": ""
		},
		"orientation": {
			"type": "string",
			"default": "horizontal",
			"enum": [
				"horizontal",
				"vertical"
			]
		},
		"tabAlignment": {
			"type": "string",
			"default": "left",
			"enum": [
				"left",
				"centre",
				"right",
				"stretch"
			]
		},
		"tabStyle": {
			"type": "string",
			"default": "underline",
			"enum": [
				"underline",
				"boxed",
				"pills"
			]
		},
		"tabTextColour": {
			"type": "string",
			"default": "text-muted"
		},
		"tabActiveTextColour": {
			"type": "string",
			"default": "primary"
		},
		"tabActiveBgColour": {
			"type": "string"
		},
		"tabActiveIndicatorColour": {
			"type": "string",
			"default": "primary"
		},
		"tabHoverBgColour": {
			"type": "string"
		},
		"panelBgColour": {
			"type": "string"
		},
		"panelBorderColour": {
			"type": "string",
			"default": "border-subtle"
		},
		"transitionDuration": {
			"type": "number",
			"default": 200
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		},
		"layout": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumns": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsMobile": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRows": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsMobile": {
			"type": "string",
			"default": ""
		},
		"gridAutoRows": {
			"type": "string",
			"default": ""
		},
		"justifyItems": {
			"type": "string",
			"default": "stretch",
			"enum": [
				"stretch",
				"start",
				"center",
				"end"
			]
		},
		"alignContent": {
			"type": "string",
			"default": "stretch",
			"enum": [
				"stretch",
				"start",
				"center",
				"end",
				"space-between",
				"space-around",
				"space-evenly"
			]
		},
		"gap": {
			"type": "string",
			"default": ""
		},
		"gapTablet": {
			"type": "string",
			"default": ""
		},
		"gapMobile": {
			"type": "string",
			"default": ""
		},
		"columns": {
			"type": "number",
			"default": 2
		},
		"columnsMobile": {
			"type": "number",
			"default": 1
		},
		"columnsTablet": {
			"type": "number",
			"default": 2
		},
		"flexDirection": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"row",
				"column"
			]
		},
		"flexWrap": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"wrap",
				"nowrap"
			]
		},
		"justifyContent": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"flex-start",
				"center",
				"flex-end",
				"space-between",
				"space-around"
			]
		},
		"templateMode": {
			"type": "string",
			"default": "free",
			"enum": [
				"free",
				"grid-section",
				"card-grid"
			]
		}
	},
	"providesContext": {
		"sgs/tabsOrientation": "orientation",
		"sgs/tabsStyle": "tabStyle"
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js",
	"example": {
		"attributes": {
			"orientation": "horizontal",
			"tabStyle": "underline",
			"tabAlignment": "left"
		},
		"innerBlocks": [
			{
				"name": "sgs/tab",
				"attributes": {
					"label": "Overview"
				}
			},
			{
				"name": "sgs/tab",
				"attributes": {
					"label": "Specifications"
				}
			},
			{
				"name": "sgs/tab",
				"attributes": {
					"label": "Delivery"
				}
			}
		]
	}
}
