{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/post-grid",
	"version": "0.2.0",
	"title": "SGS Post Grid",
	"category": "sgs-content",
	"description": "Display posts in grid, list, masonry, or carousel layouts with AJAX filtering and pagination.",
	"keywords": [
		"posts",
		"grid",
		"blog",
		"query",
		"news",
		"articles",
		"cards",
		"masonry",
		"carousel"
	],
	"textdomain": "sgs-blocks",
	"icon": "grid-view",
	"supports": {
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"elements": {
				"grid": {
					"label": "Grid",
					"layer": "OUTER",
					"_layer_note": "Block root and grid/list/masonry/carousel track combined. layer_detect.py's MF-3 guard makes the root OUTER regardless of its own display:grid.",
					"order": 1,
					"clusters": [ "fill", "layout", "animation" ],
					"isWrapper": true,
					"attrMap": {
						"css:background-color": "native:color.background",
						"css:color": "native:color.text",
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin",
						"css:max-width": "maxWidth",
						"css:border-width": "native:__experimentalBorder.width",
						"css:border-style": "native:__experimentalBorder.style",
						"css:border-color": "native:__experimentalBorder.color",
						"css:border-radius": "native:__experimentalBorder.radius",
						"css:gap": "gap",
						"css:grid-template-columns": "gridTemplateColumns",
						"css:grid-template-rows": "gridTemplateRows",
						"css:grid-auto-rows": "gridAutoRows",
						"css:justify-items": "justifyItems",
						"css:justify-content": "justifyContent",
						"css:align-content": "alignContent",
						"css:flex-direction": "flexDirection",
						"css:flex-wrap": "flexWrap",
						"anim:preset": "sgsAnimation",
						"anim:duration": "sgsAnimationDuration",
						"anim:easing": "sgsAnimationEasing"
					},
					"_note": "No `display`/`align-items`/`order`/`overflow` attribute exists on this block — honest GAPs.",
					"_note_animation": "FR-35-6 — the scroll-reveal preset (sgsAnimation/sgsAnimationDuration/sgsAnimationEasing) resolves via explicit attrMap (no `prefix` declared, per ROLLOUT REQUIREMENT 1). This block has NO staggerDelay attribute, so anim:stagger is an honest gap; anim:parallax/anim:trigger are also honest gaps (no bgParallax/scroll-trigger attrs)."
				},
				"card": {
					"label": "Post card",
					"order": 2,
					"clusters": [ "fill" ],
					"prefix": "card",
					"attrMap": {
						"css:background-color": "cardBgColour"
					},
					"states": {
						"hover": {
							"attrMap": {
								"css:transform": "scaleHover"
							}
						}
					},
					"_note": "cardStyle (card/flat/overlay/minimal) is a preset, not a Layout-cluster control; no static border/padding/radius attrs exist for the card — hover-only (backgroundColourHover/borderColourHover/shadowHover), same shape as sgs/card-grid's card-tile gap. scaleHover is declared here (css:transform on the card element's :hover) so the generator seeds it css_property='transform' / css_element='card' / css_state='hover' — fixing the derived-classifier smell (was 'background-color,transform' / css_state NULL) at SOURCE (R-31-1 declarative channel) and giving the per-element state-lift a clean row to route the draft's `.sgs-post-grid__card:hover{transform:scale(N)}` onto."
				},
				"card-image": {
					"label": "Post image",
					"order": 3,
					"clusters": [],
					"_note": "aspectRatio/imageSize/showImage/imageZoomHover govern this element; no supports.sgs.imageControls declared on this block (unlike gallery/hero/feature-grid), and no Text/Fill/Layout style attrs exist for it."
				},
				"title": {
					"label": "Post title",
					"order": 4,
					"clusters": [ "text" ],
					"prefix": "title",
					"_note": "css:color resolves via the default convention (titleColour). No font-size/weight attrs exist — honest GAPs."
				},
				"excerpt": {
					"label": "Post excerpt",
					"order": 5,
					"clusters": [ "text" ],
					"prefix": "excerpt",
					"_note": "css:color resolves via the default convention (excerptColour). excerptLength is a content-length control, not a style member."
				},
				"meta": {
					"label": "Meta (date/author)",
					"order": 6,
					"clusters": [ "text" ],
					"prefix": "meta",
					"_note": "css:color resolves via the default convention (metaColour)."
				},
				"category-badge": {
					"label": "Category badge",
					"order": 7,
					"clusters": [ "text", "fill" ],
					"prefix": "categoryBadge",
					"attrMap": {
						"css:background-color": "categoryBadgeBgColour"
					},
					"_note": "css:color resolves via the default convention (categoryBadgeColour)."
				},
				"read-more": {
					"label": "Read more link",
					"order": 8,
					"clusters": [ "text" ],
					"prefix": "readMore",
					"_note": "css:color resolves via the default convention (readMoreColour). readMoreText is content, not style."
				}
			}
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-post-grid",
		"typography": ".sgs-post-grid__title"
	},
	"attributes": {
		"postType": {
			"type": "string",
			"default": "post"
		},
		"postsPerPage": {
			"type": "number",
			"default": 6
		},
		"orderBy": {
			"type": "string",
			"default": "date"
		},
		"order": {
			"type": "string",
			"default": "desc"
		},
		"categories": {
			"type": "array",
			"default": []
		},
		"tags": {
			"type": "array",
			"default": []
		},
		"excludeCurrent": {
			"type": "boolean",
			"default": true
		},
		"offset": {
			"type": "number",
			"default": 0
		},
		"layout": {
			"type": "string",
			"default": "grid",
			"enum": [
				"grid",
				"list",
				"masonry",
				"carousel"
			]
		},
		"cardStyle": {
			"type": "string",
			"default": "card",
			"enum": [
				"card",
				"flat",
				"overlay",
				"minimal"
			]
		},
		"columns": {
			"type": "number",
			"default": 3
		},
		"columnsTablet": {
			"type": "number",
			"default": 2
		},
		"columnsMobile": {
			"type": "number",
			"default": 1
		},
		"gap": {
			"type": "string",
			"default": "30px"
		},
		"aspectRatio": {
			"type": "string",
			"default": "16/10"
		},
		"imageSize": {
			"type": "string",
			"default": "medium_large"
		},
		"showImage": {
			"type": "boolean",
			"default": true
		},
		"showTitle": {
			"type": "boolean",
			"default": true
		},
		"showExcerpt": {
			"type": "boolean",
			"default": true
		},
		"excerptLength": {
			"type": "number",
			"default": 20
		},
		"showDate": {
			"type": "boolean",
			"default": true
		},
		"showAuthor": {
			"type": "boolean",
			"default": false
		},
		"showCategory": {
			"type": "boolean",
			"default": true
		},
		"showReadMore": {
			"type": "boolean",
			"default": true
		},
		"readMoreText": {
			"type": "string",
			"default": "Read more"
		},
		"pagination": {
			"type": "string",
			"default": "none",
			"enum": [
				"none",
				"standard",
				"load-more",
				"infinite"
			]
		},
		"showFilters": {
			"type": "boolean",
			"default": false
		},
		"filterTaxonomy": {
			"type": "string",
			"default": "category"
		},
		"titleColour": {
			"type": "string",
			"default": "primary"
		},
		"excerptColour": {
			"type": "string",
			"default": "text"
		},
		"metaColour": {
			"type": "string",
			"default": "text-muted"
		},
		"categoryBadgeColour": {
			"type": "string",
			"default": "text-inverse"
		},
		"categoryBadgeBgColour": {
			"type": "string",
			"default": "primary"
		},
		"readMoreColour": {
			"type": "string",
			"default": "primary"
		},
		"cardBgColour": {
			"type": "string",
			"default": "surface"
		},
		"backgroundColourHover": {
			"type": "string"
		},
		"textColourHover": {
			"type": "string"
		},
		"borderColourHover": {
			"type": "string"
		},
		"scaleHover": {
			"type": "string",
			"default": ""
		},
		"shadowHover": {
			"type": "string",
			"default": ""
		},
		"imageZoomHover": {
			"type": "boolean",
			"default": true
		},
		"transitionDuration": {
			"type": "string",
			"default": "300"
		},
		"transitionEasing": {
			"type": "string",
			"default": "ease"
		},
		"carouselAutoplay": {
			"type": "boolean",
			"default": false
		},
		"carouselSpeed": {
			"type": "number",
			"default": 5000
		},
		"carouselShowDots": {
			"type": "boolean",
			"default": true
		},
		"carouselShowArrows": {
			"type": "boolean",
			"default": true
		},
		"sgsAnimation": {
			"type": "string",
			"default": "fade-up"
		},
		"sgsAnimationDuration": {
			"type": "string",
			"default": "medium"
		},
		"sgsAnimationEasing": {
			"type": "string",
			"default": "ease-out"
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		},
		"gapTablet": {
			"type": "string",
			"default": ""
		},
		"gapMobile": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumns": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsMobile": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRows": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsMobile": {
			"type": "string",
			"default": ""
		},
		"gridAutoRows": {
			"type": "string",
			"default": ""
		},
		"justifyItems": {
			"type": "string",
			"default": "stretch",
			"enum": [
				"stretch",
				"start",
				"center",
				"end"
			]
		},
		"alignContent": {
			"type": "string",
			"default": "stretch",
			"enum": [
				"stretch",
				"start",
				"center",
				"end",
				"space-between",
				"space-around",
				"space-evenly"
			]
		},
		"templateMode": {
			"type": "string",
			"default": "free",
			"enum": [
				"free",
				"grid-section",
				"card-grid"
			]
		},
		"flexDirection": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"row",
				"column"
			]
		},
		"flexWrap": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"wrap",
				"nowrap"
			]
		},
		"justifyContent": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"flex-start",
				"center",
				"flex-end",
				"space-between",
				"space-around"
			]
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js",
	"render": "file:./render.php",
	"example": {
		"attributes": {
			"layout": "grid",
			"columns": 3,
			"cardStyle": "card",
			"showImage": true,
			"showExcerpt": true,
			"postsPerPage": 6
		}
	}
}
