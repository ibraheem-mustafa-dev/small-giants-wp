{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/accordion-item",
	"version": "0.1.0",
	"title": "SGS Accordion Item",
	"category": "sgs-interactive",
	"description": "A single expandable section within an accordion.",
	"keywords": [ "item", "section", "panel", "question", "answer" ],
	"textdomain": "sgs-blocks",
	"icon": "arrow-down-alt2",
	"parent": [ "sgs/accordion" ],
	"supports": {
		"html": false,
		"reusable": false
	},
	"usesContext": [
		"sgs/accordionStyle",
		"sgs/accordionIconPosition",
		"sgs/accordionHeaderColour",
		"sgs/accordionHeaderBackground",
		"sgs/accordionIconColour"
	],
	"attributes": {
		"title": {
			"type": "string",
			"default": ""
		},
		"isOpen": {
			"type": "boolean",
			"default": false
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js"
}
