{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/accordion-item",
	"version": "0.2.0",
	"title": "SGS Accordion Item",
	"category": "sgs-interactive",
	"description": "A single expandable panel within an accordion. Enter a title for the header and add any content blocks inside the panel body.",
	"keywords": [
		"item",
		"section",
		"panel",
		"question",
		"answer"
	],
	"textdomain": "sgs-blocks",
	"icon": "arrow-down-alt2",
	"parent": [
		"sgs/accordion"
	],
	"supports": {
		"html": false,
		"reusable": false,
		"color": {
			"background": true,
			"gradients": true,
			"text": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		}
	},
	"usesContext": [
		"sgs/accordionStyle",
		"sgs/accordionIconPosition",
		"sgs/accordionHeaderColour",
		"sgs/accordionHeaderBackground",
		"sgs/accordionIconColour",
		"sgs/accordionOpenIcon",
		"sgs/accordionCloseIcon"
	],
	"attributes": {
		"title": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"isOpen": {
			"type": "boolean",
			"default": false
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"example": {
		"attributes": {
			"title": "What are your delivery options?",
			"isOpen": true
		}
	}
}
