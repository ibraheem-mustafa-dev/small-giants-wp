{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/card-grid",
	"version": "0.3.0",
	"title": "SGS Card Grid",
	"category": "sgs-content",
	"description": "Flexible image and content grid with overlay and card variants.",
	"keywords": [
		"card",
		"grid",
		"image",
		"gallery",
		"product",
		"tiles"
	],
	"textdomain": "sgs-blocks",
	"icon": "grid-view",
	"supports": {
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"letterSpacing": true,
			"textTransform": true,
			"fontWeight": true,
			"fontStyle": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"shadow": {
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"scalarStylingLift": true,
			"imageControls": true,
			"arrayContentLift": true,
			"elements": {
				"grid": {
					"label": "Grid",
					"layer": "OUTER",
					"_layer_note": "This element is BOTH the block root and the grid definition. layer_detect.py's MF-3 guard makes the root OUTER regardless of its own display:grid, so OUTER is correct here — the layout cluster carries the grid/arrangement properties, disambiguated by this element being the grid.",
					"order": 1,
					"clusters": [ "layout", "animation" ],
					"isWrapper": true,
					"attrMap": {
						"css:gap": "gap",
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin",
						"css:max-width": "maxWidth",
						"css:border-width": "native:__experimentalBorder.width",
						"css:border-style": "native:__experimentalBorder.style",
						"css:border-color": "native:__experimentalBorder.color",
						"css:border-radius": "native:__experimentalBorder.radius",
						"css:grid-template-columns": "gridTemplateColumns",
						"css:grid-template-rows": "gridTemplateRows",
						"css:grid-auto-rows": "gridAutoRows",
						"css:justify-items": "justifyItems",
						"css:justify-content": "justifyContent",
						"css:align-content": "alignContent",
						"css:align-items": "alignItems",
						"css:flex-direction": "flexDirection",
						"css:flex-wrap": "flexWrap",
						"anim:preset": "sgsAnimation",
						"anim:duration": "sgsAnimationDuration",
						"anim:easing": "sgsAnimationEasing",
						"anim:stagger": "staggerDelay"
					},
					"_note_animation": "FR-35-6 — the scroll-reveal preset (sgsAnimation/sgsAnimationDuration/sgsAnimationEasing) + per-card staggerDelay resolve via explicit attrMap (no `prefix` declared, per ROLLOUT REQUIREMENT 1). anim:parallax/anim:trigger are honest gaps — this block has no bgParallax/scroll-trigger attributes."
				},
				"card-tile": {
					"label": "Card",
					"order": 2,
					"clusters": [],
					"states": {
						"hover": {
							"attrMap": {
								"css:background-color": "backgroundColourHover",
								"css:border-color": "borderColourHover",
								"css:box-shadow": "shadowHover"
							}
						}
					},
					"_note": "Spec 35 FR-35-5 — the card tile's fill/border controls are HOVER-ONLY (backgroundColourHover, borderColourHover, shadowHover), with no STATIC background-colour, border, or box-shadow attrs for the resting state (resting state is hardcoded at style.css:29-31 — logged, not solved here, see design doc 'Out of scope'). Declaring the `fill`/`layout` clusters at base here would report every member as a false-looking gap since none are wired; the `states.hover` declaration above surfaces the REAL, narrower finding as STATE_WITHOUT_BASE for each of the 3 hover attrs instead — a client can restyle the hover fill but not the resting fill."
				},
				"card-media": {
					"label": "Card image",
					"order": 3,
					"clusters": [],
					"_note": "Governed by the universal image-controls extension (supports.sgs.imageControls) plus aspectRatio/overlayStyle, not the Text/Fill/Layout style clusters."
				},
				"card-title": {
					"label": "Card title",
					"order": 4,
					"clusters": [ "text" ],
					"prefix": "title"
				},
				"card-subtitle": {
					"label": "Card subtitle",
					"order": 5,
					"clusters": [ "text" ],
					"prefix": "subtitle"
				},
				"card-badge": {
					"label": "Card badge",
					"order": 6,
					"clusters": [],
					"_note": "Per-item badge text + badgeVariant preset are content/variant fields, not exposed as independent style controls — no badge-specific text/fill/layout attrs exist on the block."
				}
			}
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-card-grid",
		"typography": ".sgs-card-grid__title"
	},
	"attributes": {
		"variant": {
			"type": "string",
			"default": "card"
		},
		"_comment_items_media": "Migrated 2026-05-05 â€” each item gains a unified `media` slot (image OR video). Legacy `image` retained on items for deprecation back-compat. New instances should write `media` via MediaPicker.",
		"items": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object",
				"properties": {
					"title": {
						"type": "string",
						"role": "text-content"
					},
					"subtitle": {
						"type": "string",
						"role": "text-content"
					},
					"media": {
						"type": "string"
					},
					"badge": {
						"type": "string",
						"role": "text-content"
					},
					"link": {
						"type": "string"
					},
					"badgeVariant": {
						"type": "string"
					}
				}
			}
		},
		"columns": {
			"type": "number",
			"default": 3
		},
		"columnsMobile": {
			"type": "number",
			"default": 1
		},
		"gap": {
			"type": "string",
			"default": "30"
		},
		"aspectRatio": {
			"type": "string",
			"default": "16/10"
		},
		"effectHover": {
			"type": "string",
			"default": "zoom"
		},
		"columnsTablet": {
			"type": "number",
			"default": 2
		},
		"overlayStyle": {
			"type": "string",
			"default": "gradient"
		},
		"titleColour": {
			"type": "string",
			"default": "primary"
		},
		"subtitleColour": {
			"type": "string",
			"default": "text"
		},
		"titleFontSize": {
			"type": "number"
		},
		"titleFontSizeUnit": {
			"type": "string",
			"default": "px"
		},
		"titleFontSizeTablet": {
			"type": "number"
		},
		"titleFontSizeMobile": {
			"type": "number"
		},
		"subtitleFontSize": {
			"type": "number"
		},
		"subtitleFontSizeUnit": {
			"type": "string",
			"default": "px"
		},
		"subtitleFontSizeTablet": {
			"type": "number"
		},
		"subtitleFontSizeMobile": {
			"type": "number"
		},
		"backgroundColourHover": {
			"type": "string"
		},
		"textColourHover": {
			"type": "string"
		},
		"borderColourHover": {
			"type": "string",
			"default": "primary"
		},
		"transitionDuration": {
			"type": "string",
			"default": "300"
		},
		"transitionEasing": {
			"type": "string",
			"default": "ease-in-out"
		},
		"scaleHover": {
			"type": "string",
			"default": ""
		},
		"shadowHover": {
			"type": "string",
			"default": ""
		},
		"imageZoomHover": {
			"type": "boolean",
			"default": false
		},
		"grayscaleHover": {
			"type": "boolean",
			"default": false
		},
		"staggerDelay": {
			"type": "number",
			"default": 80
		},
		"sgsAnimation": {
			"type": "string",
			"default": "fade-up"
		},
		"sgsAnimationDuration": {
			"type": "string",
			"default": "medium"
		},
		"sgsAnimationEasing": {
			"type": "string",
			"default": "default"
		},
		"source": {
			"type": "string",
			"default": "manual",
			"enum": [
				"manual",
				"query",
				"wc-product"
			]
		},
		"productSource": {
			"type": "string",
			"default": "collection",
			"enum": [
				"collection",
				"handpick"
			],
			"description": "How products are selected: 'collection' = smart preset + filters; 'handpick' = explicit IDs."
		},
		"productCollection": {
			"type": "string",
			"default": "latest",
			"enum": [
				"best-selling",
				"price-high",
				"price-low",
				"top-rated",
				"latest"
			],
			"description": "Smart collection preset. Ignored when productSource = 'handpick'."
		},
		"productCategories": {
			"type": "array",
			"default": [],
			"items": {
				"type": "number"
			},
			"description": "WC product category term IDs to filter by (multi-select). Empty = all categories."
		},
		"productTags": {
			"type": "array",
			"default": [],
			"items": {
				"type": "number"
			},
			"description": "WC product tag term IDs to filter by (multi-select). Empty = all tags."
		},
		"productFeatured": {
			"type": "boolean",
			"default": false,
			"description": "When true, only featured products are returned."
		},
		"productOnSale": {
			"type": "boolean",
			"default": false,
			"description": "When true, only on-sale products are returned (uses wc_get_product_ids_on_sale index)."
		},
		"productInStock": {
			"type": "boolean",
			"default": true,
			"description": "When true, only in-stock products are returned."
		},
		"productLimit": {
			"type": "number",
			"default": 6,
			"description": "Maximum number of products to return (1â€“24). Server-side cap enforced at 24. The on-sale filter over-fetches and refills to this limit; fewer are returned only when fewer on-sale products exist."
		},
		"productIds": {
			"type": "array",
			"default": [],
			"items": {
				"type": "number"
			},
			"description": "Explicit product IDs for handpick mode. Order is respected."
		},
		"productShowLadder": {
			"type": "boolean",
			"default": false,
			"description": "Show the per-pack price ladder on each card. Off by default â€” grids are a browsing context; the ladder does its upsell work on the product page."
		},
		"productEmptyMessage": {
			"type": "string",
			"default": "No products to show at the moment. Check back soon.",
			"description": "Message shown when the product query returns zero results (FR-24-6 empty state)."
		},
		"queryPostType": {
			"type": "string",
			"default": "post"
		},
		"queryPostsPerPage": {
			"type": "number",
			"default": 6
		},
		"queryCategory": {
			"type": "number",
			"default": 0
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		},
		"layout": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumns": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsMobile": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRows": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsMobile": {
			"type": "string",
			"default": ""
		},
		"gridAutoRows": {
			"type": "string",
			"default": ""
		},
		"direction": {
			"type": "string",
			"default": ""
		},
		"flexDirection": {
			"type": "string",
			"default": ""
		},
		"flexWrap": {
			"type": "string",
			"default": ""
		},
		"wrap": {
			"type": "string",
			"default": ""
		},
		"justifyContent": {
			"type": "string",
			"default": ""
		},
		"justifyItems": {
			"type": "string",
			"default": ""
		},
		"alignContent": {
			"type": "string",
			"default": ""
		},
		"alignItems": {
			"type": "string",
			"default": ""
		},
		"templateMode": {
			"type": "string",
			"default": ""
		},
		"gapMobile": {
			"type": "string",
			"default": ""
		},
		"gapTablet": {
			"type": "string",
			"default": ""
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"example": {
		"attributes": {
			"variant": "card",
			"columns": 3,
			"items": [
				{
					"title": "Fresh Produce",
					"subtitle": "Farm-fresh vegetables and fruits"
				},
				{
					"title": "Dairy & Eggs",
					"subtitle": "Sourced from trusted local farms"
				},
				{
					"title": "Bakery",
					"subtitle": "Baked fresh every morning"
				}
			]
		}
	}
}
