{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/gallery",
	"version": "0.2.0",
	"title": "SGS Image Gallery",
	"category": "sgs-content",
	"description": "Image gallery with grid, masonry, and carousel layouts plus lightbox viewing.",
	"keywords": [
		"gallery",
		"images",
		"photos",
		"lightbox",
		"masonry",
		"carousel",
		"portfolio"
	],
	"textdomain": "sgs-blocks",
	"icon": "format-gallery",
	"supports": {
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		},
		"interactivity": true,
		"sgs": {
			"imageControls": true,
			"elements": {
				"grid": {
					"label": "Grid",
					"layer": "OUTER",
					"_layer_note": "Block root and grid/carousel-track definition combined. layer_detect.py's MF-3 guard makes the root OUTER regardless of its own display:grid.",
					"order": 1,
					"clusters": [ "fill", "layout", "animation" ],
					"isWrapper": true,
					"attrMap": {
						"css:background-color": "native:color.background",
						"css:color": "native:color.text",
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin",
						"css:max-width": "maxWidth",
						"css:border-width": "native:__experimentalBorder.width",
						"css:border-style": "native:__experimentalBorder.style",
						"css:border-color": "native:__experimentalBorder.color",
						"css:border-radius": "native:__experimentalBorder.radius",
						"css:gap": "gap",
						"css:grid-template-columns": "gridTemplateColumns",
						"css:grid-template-rows": "gridTemplateRows",
						"css:grid-auto-rows": "gridAutoRows",
						"css:justify-items": "justifyItems",
						"css:justify-content": "justifyContent",
						"css:align-content": "alignContent",
						"css:align-items": "alignItems",
						"css:flex-direction": "flexDirection",
						"css:flex-wrap": "flexWrap",
						"anim:preset": "sgsAnimation",
						"anim:duration": "sgsAnimationDuration",
						"anim:easing": "sgsAnimationEasing",
						"anim:stagger": "staggerDelay"
					},
					"_note": "No `display`/`order`/`overflow` attribute exists on this block — honest GAPs.",
					"_note_animation": "FR-35-6 — the scroll-reveal preset (sgsAnimation/sgsAnimationDuration/sgsAnimationEasing) + per-image staggerDelay resolve via explicit attrMap (no `prefix` declared, per ROLLOUT REQUIREMENT 1). anim:parallax/anim:trigger are honest gaps — no bgParallax/scroll-trigger attributes on this block."
				},
				"image": {
					"label": "Image",
					"order": 2,
					"clusters": [],
					"_note": "Governed by the universal image-controls extension (supports.sgs.imageControls) plus aspectRatio/effectHover/imageZoomHover, not the Text/Fill/Layout style clusters."
				},
				"caption": {
					"label": "Caption",
					"order": 3,
					"clusters": [ "text", "fill" ],
					"prefix": "caption",
					"attrMap": {
						"css:background-color": "captionBgColour"
					},
					"_note": "Only shown when showCaptions is true. css:color resolves via the default convention (captionColour)."
				}
			}
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-gallery"
	},
	"attributes": {
		"mediaItems": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object"
			}
		},
		"images": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object"
			}
		},
		"layout": {
			"type": "string",
			"default": "grid",
			"enum": [
				"grid",
				"masonry",
				"carousel"
			]
		},
		"columns": {
			"type": "number",
			"default": 3
		},
		"columnsTablet": {
			"type": "number",
			"default": 2
		},
		"columnsMobile": {
			"type": "number",
			"default": 1
		},
		"gap": {
			"type": "string",
			"default": "16"
		},
		"aspectRatio": {
			"type": "string",
			"default": "1/1"
		},
		"effectHover": {
			"type": "string",
			"default": "zoom"
		},
		"enableLightbox": {
			"type": "boolean",
			"default": true
		},
		"showCaptions": {
			"type": "boolean",
			"default": false
		},
		"captionColour": {
			"type": "string",
			"default": "text-inverse"
		},
		"captionBgColour": {
			"type": "string",
			"default": "primary-dark"
		},
		"overlayColourHover": {
			"type": "string",
			"default": "primary-dark"
		},
		"scaleHover": {
			"type": "string",
			"default": ""
		},
		"imageZoomHover": {
			"type": "boolean",
			"default": true
		},
		"transitionDuration": {
			"type": "string",
			"default": "300"
		},
		"transitionEasing": {
			"type": "string",
			"default": "ease"
		},
		"carouselAutoplay": {
			"type": "boolean",
			"default": false
		},
		"carouselSpeed": {
			"type": "number",
			"default": 5000
		},
		"carouselShowDots": {
			"type": "boolean",
			"default": true
		},
		"carouselShowArrows": {
			"type": "boolean",
			"default": true
		},
		"imageSize": {
			"type": "string",
			"default": "large"
		},
		"captionReveal": {
			"type": "boolean",
			"default": false
		},
		"grayscaleHover": {
			"type": "boolean",
			"default": false
		},
		"staggerDelay": {
			"type": "number",
			"default": 60
		},
		"shadowHover": {
			"type": "string",
			"default": ""
		},
		"sgsAnimation": {
			"type": "string",
			"default": "fade-in"
		},
		"sgsAnimationDuration": {
			"type": "string",
			"default": "medium"
		},
		"sgsAnimationEasing": {
			"type": "string",
			"default": "ease-out"
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumns": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsMobile": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRows": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsMobile": {
			"type": "string",
			"default": ""
		},
		"gridAutoRows": {
			"type": "string",
			"default": ""
		},
		"direction": {
			"type": "string",
			"default": ""
		},
		"flexDirection": {
			"type": "string",
			"default": ""
		},
		"flexWrap": {
			"type": "string",
			"default": ""
		},
		"wrap": {
			"type": "string",
			"default": ""
		},
		"justifyContent": {
			"type": "string",
			"default": ""
		},
		"justifyItems": {
			"type": "string",
			"default": ""
		},
		"alignContent": {
			"type": "string",
			"default": ""
		},
		"alignItems": {
			"type": "string",
			"default": ""
		},
		"templateMode": {
			"type": "string",
			"default": ""
		},
		"gapMobile": {
			"type": "string",
			"default": ""
		},
		"gapTablet": {
			"type": "string",
			"default": ""
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js",
	"render": "file:./render.php",
	"example": {
		"attributes": {
			"layout": "grid",
			"columns": 3,
			"enableLightbox": true,
			"gap": "16"
		}
	}
}
