{
    "$schema":  "https://schemas.wp.org/trunk/block.json",
    "apiVersion":  3,
    "name":  "sgs/heritage-strip",
    "version":  "0.1.0",
    "title":  "SGS Heritage Strip",
    "category":  "sgs-content",
    "description":  "Full-width story section with images and narrative text. Three layout options.",
    "keywords":  [
                     "heritage",
                     "story",
                     "about",
                     "history",
                     "strip",
                     "narrative"
                 ],
    "textdomain":  "sgs-blocks",
    "icon":  "book-alt",
    "supports":  {
                     "align":  [
                                   "wide",
                                   "full"
                               ],
                     "anchor":  true,
                     "html":  false,
                     "color":  {
                                   "background":  true,
                                   "text":  true,
                                   "gradients":  true
                               },
                     "typography":  {
                                        "fontSize":  true,
                                        "lineHeight":  true,
                                        "textAlign":  true,
                                        "letterSpacing":  true,
                                        "textTransform":  true,
                                        "fontWeight":  true,
                                        "fontStyle":  true
                                    },
                     "spacing":  {
                                     "margin":  true,
                                     "padding":  true
                                 },
                     "__experimentalBorder":  {
                                                  "radius":  true,
                                                  "width":  true,
                                                  "color":  true,
                                                  "style":  true
                                              }
                 },
    "selectors":  {
                      "root":  ".sgs-heritage-strip",
                      "typography":  ".sgs-heritage-strip__headline"
                  },
    "attributes":  {
                       "layout":  {
                                      "type":  "string",
                                      "default":  "image-text-image"
                                  },
                       "headline":  {
                                        "type":  "string",
                                        "source":  "html",
                                        "selector":  ".sgs-heritage-strip__headline"
                                    },
                       "body":  {
                                    "type":  "string",
                                    "source":  "html",
                                    "selector":  ".sgs-heritage-strip__body"
                                },
                       "imageLeft":  {
                                         "type":  "object"
                                     },
                       "imageRight":  {
                                          "type":  "object"
                                      },
                       "headlineColour":  {
                                              "type":  "string"
                                          },
                       "headlineFontSize":  {
                                                "type":  "string"
                                            },
                       "bodyColour":  {
                                          "type":  "string"
                                      },
                       "bodyFontSize":  {
                                            "type":  "string"
                                        },
                       "backgroundColour":  {
                                                "type":  "string"
                                            },
                       "hoverBackgroundColour":  {
                                                     "type":  "string",
                                                     "default":  ""
                                                 },
                       "hoverTextColour":  {
                                               "type":  "string",
                                               "default":  ""
                                           },
                       "hoverBorderColour":  {
                                                 "type":  "string",
                                                 "default":  ""
                                             },
                       "hoverEffect":  {
                                           "type":  "string",
                                           "default":  "none"
                                       },
                       "transitionDuration":  {
                                                  "type":  "string",
                                                  "default":  "300"
                                              },
                       "transitionEasing":  {
                                                "type":  "string",
                                                "default":  "ease-in-out"
                                            }
                   },
    "editorScript":  "file:./index.js",
    "editorStyle":  "file:./index.css",
    "style":  "file:./style-index.css",
    "example":  {
                    "attributes":  {
                                       "layout":  "image-text-image",
                                       "headline":  "Our Story — Over 60 Years in the Making",
                                       "body":  "Founded in 1962, we\u0027ve grown from a local supplier to one of the UK\u0027s leading food wholesalers, without ever losing sight of the values that made us."
                                   }
                }
}
