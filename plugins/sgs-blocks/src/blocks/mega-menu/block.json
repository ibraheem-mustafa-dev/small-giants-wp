{
    "$schema":  "https://schemas.wp.org/trunk/block.json",
    "apiVersion":  3,
    "name":  "sgs/mega-menu",
    "version":  "0.2.0",
    "title":  "SGS Mega Menu",
    "category":  "sgs-interactive",
    "description":  "Block-based mega menu with template part dropdowns, layout variants, configurable animations and full keyboard navigation. Works inside Navigation block.",
    "keywords":  [
                     "mega menu",
                     "navigation",
                     "dropdown",
                     "menu",
                     "navbar",
                     "flyout"
                 ],
    "textdomain":  "sgs-blocks",
    "icon":  "menu-alt",
    "parent":  [
                   "core/navigation"
               ],
    "supports":  {
                     "align":  false,
                     "anchor":  false,
                     "html":  false,
                     "reusable":  false,
                     "spacing":  {
                                     "margin":  true,
                                     "padding":  true
                                 },
                     "color":  {
                                   "text":  true,
                                   "background":  true
                               }
                 },
    "attributes":  {
                       "label":  {
                                     "type":  "string",
                                     "source":  "html",
                                     "selector":  ".sgs-mega-menu__label"
                                 },
                       "url":  {
                                   "type":  "string"
                               },
                       "opensInNewTab":  {
                                             "type":  "boolean",
                                             "default":  false
                                         },
                       "menuTemplatePart":  {
                                                "type":  "string",
                                                "default":  ""
                                            },
                       "layoutVariant":  {
                                             "type":  "string",
                                             "default":  "full-width",
                                             "enum":  [
                                                          "full-width",
                                                          "contained",
                                                          "columns",
                                                          "flyout",
                                                          "card-grid",
                                                          "tabbed",
                                                          "featured"
                                                      ]
                                         },
                       "panelWidth":  {
                                          "type":  "string",
                                          "default":  "full"
                                      },
                       "panelMaxWidth":  {
                                             "type":  "string",
                                             "default":  "1200px"
                                         },
                       "panelAlignment":  {
                                              "type":  "string",
                                              "default":  "left"
                                          },
                       "openOn":  {
                                      "type":  "string",
                                      "default":  "hover"
                                  },
                       "openAnimation":  {
                                             "type":  "string",
                                             "default":  "fade",
                                             "enum":  [
                                                          "fade",
                                                          "slide-down",
                                                          "scale"
                                                      ]
                                         },
                       "closeDelay":  {
                                          "type":  "number",
                                          "default":  300
                                      },
                       "icon":  {
                                    "type":  "string",
                                    "default":  "chevron-down"
                                },
                       "iconPosition":  {
                                            "type":  "string",
                                            "default":  "after"
                                        },
                       "highlight":  {
                                         "type":  "boolean",
                                         "default":  false
                                     },
                       "badge":  {
                                     "type":  "string"
                                 },
                       "badgeColour":  {
                                           "type":  "string",
                                           "default":  "accent"
                                       },
                       "featuredImage":  {
                                             "type":  "object",
                                             "default":  {}
                                         },
                       "featuredTitle":  {
                                             "type":  "string",
                                             "default":  ""
                                         },
                       "featuredCta":  {
                                           "type":  "string",
                                           "default":  "Learn more"
                                       },
                       "featuredCtaUrl":  {
                                              "type":  "string",
                                              "default":  ""
                                          }
                   },
    "render":  "file:./render.php",
    "editorScript":  "file:./index.js",
    "editorStyle":  "file:./index.css",
    "style":  "file:./style-index.css",
    "viewScriptModule":  "file:./view.js",
    "example":  {
                    "attributes":  {
                                       "label":  "Products",
                                       "layoutVariant":  "full-width",
                                       "openAnimation":  "fade"
                                   }
                }
}
