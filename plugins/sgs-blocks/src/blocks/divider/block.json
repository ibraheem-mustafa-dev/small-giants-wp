{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "sgs/divider",
    "version": "0.1.0",
    "title": "Divider",
    "category": "sgs-layout",
    "description": "Section separator with four visual variants: simple line, dot row, SVG wave, or centred shape. Used to mark transitions between page sections.",
    "keywords": [
        "divider",
        "separator",
        "line",
        "hr",
        "spacer"
    ],
    "textdomain": "sgs-blocks",
    "icon": "minus",
    "supports": {
        "align": [ "wide", "full", "center" ],
        "html": false,
        "color": {
            "text": false,
            "background": true,
            "link": false
        },
        "spacing": {
            "margin": true,
            "padding": false
        }
    },
    "attributes": {
        "variant": {
            "type": "string",
            "enum": [ "line", "dots", "wave", "shape" ],
            "default": "line"
        },
        "colour": {
            "type": "string",
            "default": "primary"
        },
        "thickness": {
            "type": "number",
            "default": 1
        },
        "width": {
            "type": "number",
            "default": 100
        },
        "widthUnit": {
            "type": "string",
            "default": "%"
        },
        "dividerAlign": {
            "type": "string",
            "enum": [ "left", "center", "right" ],
            "default": "center"
        },
        "marginTop": {
            "type": "number",
            "default": 32
        },
        "marginBottom": {
            "type": "number",
            "default": 32
        },
        "marginUnit": {
            "type": "string",
            "default": "px"
        },
        "shape": {
            "type": "string",
            "enum": [ "circle", "square", "diamond" ],
            "default": "circle"
        },
        "shapeSize": {
            "type": "number",
            "default": 12
        },
        "dotCount": {
            "type": "number",
            "default": 3
        }
    },
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": "file:./style-index.css",
    "example": {
        "attributes": {
            "variant": "line",
            "colour": "primary",
            "width": 80
        }
    }
}
