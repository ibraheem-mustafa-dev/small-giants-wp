{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/hero",
	"version": "0.3.4",
	"title": "SGS Hero",
	"category": "sgs-layout",
	"description": "Page hero section with headline, sub-headline, CTAs, and background image.",
	"keywords": [
		"hero",
		"banner",
		"header",
		"headline",
		"landing"
	],
	"textdomain": "sgs-blocks",
	"icon": "cover-image",
	"supports": {
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"letterSpacing": true,
			"textTransform": true,
			"fontWeight": true,
			"fontStyle": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"imageControls": true,
			"is_section_root": true,
			"containerKind": "section",
			"variantAttr": "variant",
			"gridAreas": [
				"content",
				"media"
			],
			"variants": {
				"standard": [
					"backgroundImage"
				],
				"split": [
					"splitImage",
					"splitImageMobile"
				],
				"video": [
					"backgroundVideo",
					"bgVideo"
				],
				"svg-animated": [
					"svgContent"
				]
			},
			"arrayContentLift": true,
			"boxFamilies": {
				"contentPadding": [
					"contentPadding",
					"contentPaddingTablet",
					"contentPaddingMobile"
				],
				"mediaPadding": [
					"mediaPadding",
					"mediaPaddingTablet",
					"mediaPaddingMobile"
				],
				"imagePadding": [
					"imagePadding",
					"imagePaddingTablet",
					"imagePaddingMobile"
				],
				"imageBorderWidth": [
					"imageBorderWidth"
				],
				"imageBorderRadius": [
					"imageBorderRadius",
					"imageBorderRadiusTablet",
					"imageBorderRadiusMobile"
				],
				"contentBandPadding": [
					"contentBandPadding",
					"contentBandPaddingTablet",
					"contentBandPaddingMobile"
				],
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				]
			},
			"elements": {
				"wrapper": {
					"label": "Wrapper",
					"layer": "OUTER",
					"order": 1,
					"clusters": [ "fill", "layout", "animation" ],
					"isWrapper": true,
					"attrMap": {
						"css:background-color": "native:color.background",
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin",
						"css:max-width": "maxWidth",
						"css:min-height": "minHeight",
						"css:border-width": "native:__experimentalBorder.width",
						"css:border-style": "native:__experimentalBorder.style",
						"css:border-color": "native:__experimentalBorder.color",
						"css:border-radius": "native:__experimentalBorder.radius",
						"css:box-shadow": "shadow",
						"anim:parallax": "bgParallax",
						"anim:duration": "bgAnimationDuration"
					},
					"_note_animation": "FR-35-6 — anim:parallax/anim:duration resolve via bgParallax/bgAnimationDuration (explicit attrMap; no `prefix` declared, per ROLLOUT REQUIREMENT 1). bgKenBurns is a separate preset toggle with no animation-cluster member and stays unmapped. anim:preset/anim:easing/anim:stagger/anim:trigger are honest gaps — no sgsAnimation*/staggerDelay/scroll-trigger attrs on this block."
				},
				"grid": {
					"label": "Grid / flex layout",
					"layer": "GRID",
					"order": 2,
					"clusters": [ "layout" ],
					"attrMap": {
						"css:gap": "gap",
						"css:grid-template-columns": "gridTemplateColumns",
						"css:grid-template-rows": "gridTemplateRows",
						"css:grid-auto-rows": "gridAutoRows",
						"css:justify-items": "justifyItems",
						"css:justify-content": "justifyContent",
						"css:align-content": "alignContent",
						"css:flex-direction": "flexDirection",
						"css:flex-wrap": "flexWrap"
					},
					"_note": "The content/media split grid (gridAreas: content, media). Declares no `prefix` so arrangement members map explicitly. No `display`, `align-items`, `order` or `overflow` attribute exists on this block — honest GAPs, not omissions."
				},
				"content-band": {
					"label": "Content band",
					"layer": "CONTENT",
					"order": 3,
					"clusters": [ "fill", "layout" ],
					"prefix": "contentBand",
					"attrMap": {
						"css:background-color": "contentBandBackground",
						"css:width": "contentWidth"
					},
					"_note": "Mirrors sgs/container's content-band — the content-width constraining band, independent of the `content` grid-area below. Padding resolves via the default {prefix}{Suffix} convention (contentBandPadding)."
				},
				"content": {
					"label": "Content column",
					"layer": "GRID_AREA",
					"order": 4,
					"clusters": [ "fill", "layout" ],
					"prefix": "content",
					"_note": "The `content` grid-area (headline/sub-headline/CTA column in the split variant). background-color and padding both resolve via the default convention (contentBackground, contentPadding)."
				},
				"media": {
					"label": "Media column",
					"layer": "GRID_AREA",
					"order": 5,
					"clusters": [ "fill", "layout" ],
					"prefix": "image",
					"attrMap": {
						"css:background-color": "mediaBackgroundColour",
						"css:object-fit": "imageObjectFit",
						"css:object-position": "imageObjectPosition"
					},
					"_note": "The `media` grid-area. Most box/border members resolve via the default `image{Suffix}` convention (imageBorderWidth/Style/Colour/Radius/Padding). `mediaBackground` (a second, plainer background attr alongside `mediaBackgroundColour`) is a genuine ORPHAN — two overlapping attrs for one concept, not modelled here."
				},
				"grid-item": {
					"label": "Grid item",
					"layer": "GRID_AREA",
					"order": 6,
					"clusters": [ "text", "fill", "layout" ],
					"prefix": "gridItem",
					"attrMap": {
						"css:background-color": "gridItemBackground",
						"css:padding": "gridItemPadding",
						"css:border-radius": "gridItemBorderRadius",
						"css:border-width": "gridItemBorder",
						"css:border-style": "gridItemBorder",
						"css:border-color": "gridItemBorder",
						"css:box-shadow": "gridItemShadow",
						"css:color": "gridItemTextColour"
					},
					"_note": "Inherited from the sgs/container capability mirror — present on this block's attribute list but not exercised by any hero variant today. Declared so the attrs resolve rather than surface as orphans."
				},
				"headline": {
					"label": "Headline",
					"order": 7,
					"clusters": [ "text", "layout" ],
					"prefix": "headline",
					"attrMap": {
						"css:font-size": "native:typography.fontSize",
						"css:font-weight": "native:typography.fontWeight",
						"css:line-height": "native:typography.lineHeight",
						"css:letter-spacing": "native:typography.letterSpacing",
						"css:font-style": "native:typography.fontStyle",
						"css:text-transform": "native:typography.textTransform",
						"css:text-align": "native:typography.textAlign",
						"css:color": "native:color.text",
						"css:margin-bottom": "headlineMarginBottom"
					},
					"_note": "block.json `selectors.typography.root` scopes the wrapper's native typography support to `.sgs-hero__headline`, so these native paths are this element's controls, not the wrapper's. `headlineMarginBottom`/`headlineMarginBottomMobile` (render.php:364-372, `.sgs-hero__headline{margin-bottom:...}`) resolve via the new css:margin-bottom layout member (Spec 35 vocabulary fix) — a partial bottom-only margin, distinct from the whole-box `css:margin` member."
				},
				"sub-headline": {
					"label": "Sub-headline",
					"order": 8,
					"clusters": [],
					"_note": "No dedicated typography attrs — inherits the wrapper's native typography. `subHeadlineMaxWidth`/`subHeadlineMarginBottom(Mobile)` are layout-shaped but partial (not the whole-box padding/margin members), so left unclustered rather than manufacturing a false gap."
				},
				"cta": {
					"label": "CTA buttons",
					"order": 9,
					"clusters": [],
					"_note": "CTAs render via InnerBlocks (sgs/multi-button > sgs/button children, FR-22-6) — no scalar cta* content/style attrs remain on this block, so nothing to cluster-map here."
				}
			}
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-hero",
		"border": ".wp-block-sgs-hero",
		"color": {
			"background": ".wp-block-sgs-hero",
			"text": ".wp-block-sgs-hero"
		},
		"spacing": {
			"padding": ".wp-block-sgs-hero",
			"margin": ".wp-block-sgs-hero"
		},
		"typography": {
			"root": ".sgs-hero__headline",
			"fontSize": ".sgs-hero__headline",
			"fontFamily": ".sgs-hero__headline",
			"fontWeight": ".sgs-hero__headline",
			"lineHeight": ".sgs-hero__headline",
			"letterSpacing": ".sgs-hero__headline",
			"textTransform": ".sgs-hero__headline",
			"textDecoration": ".sgs-hero__headline"
		}
	},
	"attributes": {
		"variant": {
