{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/hero",
	"version": "0.3.4",
	"title": "SGS Hero",
	"category": "sgs-layout",
	"description": "Page hero section with headline, sub-headline, CTAs, and background image.",
	"keywords": [
		"hero",
		"banner",
		"header",
		"headline",
		"landing"
	],
	"textdomain": "sgs-blocks",
	"icon": "cover-image",
	"supports": {
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"letterSpacing": true,
			"textTransform": true,
			"fontWeight": true,
			"fontStyle": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"imageControls": true,
			"is_section_root": true,
			"containerKind": "section",
			"variantAttr": "variant",
			"gridAreas": [
				"content",
				"media"
			],
			"variants": {
				"standard": [
					"backgroundImage"
				],
				"split": [
					"splitImage",
					"splitImageMobile"
				],
				"video": [
					"backgroundVideo",
					"bgVideo"
				],
				"svg-animated": [
					"svgContent"
				]
			},
			"arrayContentLift": true,
			"boxFamilies": {
				"contentPadding": [
					"contentPadding",
					"contentPaddingTablet",
					"contentPaddingMobile"
				],
				"mediaPadding": [
					"mediaPadding",
					"mediaPaddingTablet",
					"mediaPaddingMobile"
				],
				"imagePadding": [
					"imagePadding",
					"imagePaddingTablet",
					"imagePaddingMobile"
				],
				"imageBorderWidth": [
					"imageBorderWidth"
				],
				"imageBorderRadius": [
					"imageBorderRadius",
					"imageBorderRadiusTablet",
					"imageBorderRadiusMobile"
				],
				"contentBandPadding": [
					"contentBandPadding",
					"contentBandPaddingTablet",
					"contentBandPaddingMobile"
				],
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				]
			}
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-hero",
		"border": ".wp-block-sgs-hero",
		"color": {
			"background": ".wp-block-sgs-hero",
			"text": ".wp-block-sgs-hero"
		},
		"spacing": {
			"padding": ".wp-block-sgs-hero",
			"margin": ".wp-block-sgs-hero"
		},
		"typography": {
			"root": ".sgs-hero__headline",
			"fontSize": ".sgs-hero__headline",
			"fontFamily": ".sgs-hero__headline",
			"fontWeight": ".sgs-hero__headline",
			"lineHeight": ".sgs-hero__headline",
			"letterSpacing": ".sgs-hero__headline",
			"textTransform": ".sgs-hero__headline",
			"textDecoration": ".sgs-hero__headline"
		}
	},
	"attributes": {
		"variant": {
			"type": "string",
			"default": "standard",
			"enum": [
				"standard",
				"split",
				"video",
				"svg-animated"
			]
		},
		"headline": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"subHeadline": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"alignment": {
			"type": "string",
			"default": "left"
		},
		"backgroundImage": {
			"type": "object"
		},
		"overlayColour": {
			"type": "string",
			"default": "text"
		},
		"overlayOpacity": {
			"type": "number",
			"default": 50
		},
		"splitImage": {
			"type": "object"
		},
		"_comment_splitMedia": "Migrated 2026-05-05 â€” splitImage retained for deprecation. New instances should use splitMedia.",
