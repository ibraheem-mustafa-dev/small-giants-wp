{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/hero",
	"version": "0.3.0",
	"title": "SGS Hero",
	"category": "sgs-layout",
	"description": "Page hero section with headline, sub-headline, CTAs, and background image.",
	"keywords": [
		"hero",
		"banner",
		"header",
		"headline",
		"landing"
	],
	"textdomain": "sgs-blocks",
	"icon": "cover-image",
	"supports": {
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"letterSpacing": true,
			"textTransform": true,
			"fontWeight": true,
			"fontStyle": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true
		},
		"sgs": {
			"imageControls": true,
			"is_section_root": true,
			"containerKind": "section",
			"variantAttr": "variant",
			"gridAreas": [
				"content",
				"media"
			],
			"variants": {
				"standard": [
					"backgroundImage"
				],
				"split": [
					"splitImage",
					"splitImageMobile"
				],
				"video": [
					"backgroundVideo",
					"bgVideo"
				],
				"svg-animated": [
					"svgContent"
				]
			},
			"arrayContentLift": true,
			"arrayItemSchema": {
				"badges": {
					"itemSelector": ".sgs-hero__badge",
					"fields": {
						"number": {
							"selector": ".sgs-hero__badge-number",
							"role": "plain-integer"
						},
						"suffix": {
							"selector": ".sgs-hero__badge-number",
							"role": "gap-pending",
							"gapReason": "number/suffix share one element; needs split"
						},
						"label": {
							"selector": ".sgs-hero__badge-label",
							"role": "text-content"
						},
						"position": {
							"selector": ".sgs-hero__badge",
							"role": "gap-pending",
							"gapReason": "disambiguation: render.php emits both position and style as separate --modifier classes on the same .sgs-hero__badge div (e.g. sgs-hero__badge--bottom-left sgs-hero__badge--light). The generic css-modifier handler returns only the FIRST modifier — it cannot distinguish position from style without a valueAllowlist or two-pass approach. Both fields share one element; needs per-field allowlist matching or a dedicated handler."
						},
						"style": {
							"selector": ".sgs-hero__badge",
							"role": "gap-pending",
							"gapReason": "disambiguation: same as position — both fields read --modifier classes on the same .sgs-hero__badge element. The generic css-modifier handler would return the first modifier for both, assigning the position value to style or vice versa. Previous selectors (.sgs-hero__review-position / .sgs-hero__review-style) were fictional — they match nothing in actual drafts. Fix requires a valueAllowlist mechanism or two separate child elements."
						}
					}
				}
			}
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-hero",
		"border": ".wp-block-sgs-hero",
		"color": {
			"background": ".wp-block-sgs-hero",
			"text": ".wp-block-sgs-hero"
		},
		"spacing": {
			"padding": ".wp-block-sgs-hero",
			"margin": ".wp-block-sgs-hero"
		},
		"typography": {
			"root": ".sgs-hero__headline",
