			"default": "left"
		},
		"backgroundImage": {
			"type": "object"
		},
		"overlayColour": {
			"type": "string",
			"default": "text"
		},
		"overlayOpacity": {
			"type": "number",
			"default": 50
		},
		"splitImage": {
			"type": "object"
		},
		"_comment_splitMedia": "Migrated 2026-05-05 â€” splitImage retained for deprecation. New instances should use splitMedia.",
