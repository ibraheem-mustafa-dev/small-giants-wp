			"type": "string",
			"default": ""
		},
		"minHeightMobile": {
			"type": "string",
			"default": "360px"
		},
		"badges": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object",
				"properties": {
					"number": {
						"type": "string"
					},
					"suffix": {
						"type": "string",
						"role": "text-content"
					},
					"label": {
						"type": "string"
					},
					"position": {
						"type": "string"
					},
					"style": {
