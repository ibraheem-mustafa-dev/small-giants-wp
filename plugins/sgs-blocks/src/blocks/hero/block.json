		"textAlignDesktop": {
			"type": "string",
			"default": ""
		},
		"bgParallax": {
			"type": "boolean",
			"default": false
		},
		"bgKenBurns": {
			"type": "boolean",
			"default": false
		},
		"bgVideo": {
			"type": "object"
		},
		"bgVideoMobile": {
			"type": "object"
		},
		"splitImageBleed": {
			"type": "boolean",
			"default": false
		},
		"subHeadlineMaxWidth": {
			"type": "number",
			"default": null
		},
		"splitImageMobileHeight": {
			"type": "number",
			"default": null
		},
		"imageObjectFit": {
			"type": "string",
			"default": "cover"
		},
		"imageObjectPosition": {
