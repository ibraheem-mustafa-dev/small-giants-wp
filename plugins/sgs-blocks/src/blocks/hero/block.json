			"type": "object",
			"default": null
		},
		"splitImageMobile": {
			"type": "object"
		},
		"splitImageMobileObjectPosition": {
			"type": "string",
			"default": "center 20%"
		},
		"label": {
			"type": "string",
			"default": "",
