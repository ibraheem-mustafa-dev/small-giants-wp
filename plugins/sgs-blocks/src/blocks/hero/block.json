		"imageBorderColour": {
			"type": "string",
			"default": ""
		},
		"imagePadding": {
			"type": "object",
			"default": {}
		},
		"imagePaddingTablet": {
			"type": "object",
			"default": {}
		},
		"imagePaddingMobile": {
			"type": "object",
			"default": {}
		},
		"mediaBackgroundColour": {
			"type": "string",
			"default": ""
		},
		"mediaBackground": {
			"type": "string",
			"default": ""
		},
		"contentPadding": {
			"type": "object",
			"default": {}
		},
		"contentPaddingTablet": {
			"type": "object",
			"default": {}
		},
		"contentPaddingMobile": {
			"type": "object",
			"default": {}
