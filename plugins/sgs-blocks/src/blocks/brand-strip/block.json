{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/brand-strip",
	"version": "0.2.0",
	"title": "SGS Brand Strip",
	"category": "sgs-content",
	"description": "Horizontal logo strip with infinite marquee scroll, fade edges, direction control, and greyscale/sepia image effects.",
	"keywords": [
		"brand",
		"logo",
		"partner",
		"client",
		"strip",
		"carousel",
		"marquee"
	],
	"textdomain": "sgs-blocks",
	"icon": "images-alt2",
	"supports": {
		"sgs": {
			"imageControls": true,
			"arrayContentLift": true,
			"hideExtensions": [ "hover", "blockLink", "clickEffects", "parallax", "spacing" ],
			"elements": {
				"tile": {
					"label": "Tile",
					"order": 1,
					"clusters": [ "fill", "layout" ],
					"prefix": "tile",
					"attrMap": {
						"css:background-color": "tileBackgroundColour",
						"css:border-width": "tileBorderWidth",
						"css:border-color": "tileBorderColour",
						"css:border-radius": "tileRadius",
						"css:box-shadow": "tileShadow",
						"css:padding": "tilePadding",
						"css:gap": "logoGap"
					}
				},
				"logo-image": {
					"label": "Logo image",
					"order": 2,
					"clusters": [],
					"_note": "Governed by the universal image-controls extension (supports.sgs.imageControls) plus logoFit/imageEffect selects — outside the Text/Fill/Layout style clusters, so it declares none."
				},
				"caption": {
					"label": "Caption",
					"order": 3,
					"clusters": [ "text" ],
					"prefix": "name",
					"attrMap": {
						"css:font-size": "nameFontSize",
						"css:font-weight": "nameFontWeight",
						"css:color": "nameColour"
					}
				},
				"strip-spacing": {
					"label": "Strip spacing",
					"order": 4,
					"clusters": [ "layout" ],
					"isWrapper": true,
					"attrMap": {
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin",
						"css:border-width": "native:__experimentalBorder.width",
						"css:border-style": "native:__experimentalBorder.style",
						"css:border-color": "native:__experimentalBorder.color",
						"css:border-radius": "native:__experimentalBorder.radius"
					}
				}
			},
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				],
				"borderRadius": [
					"borderRadiusTablet",
					"borderRadiusMobile"
				]
			}
		},
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": false,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		}
	},
	"attributes": {
		"_comment_logos_media": "Migrated 2026-05-05 â€” each logo entry uses the unified media-slot shape { url, type: 'image', id, alt, mime } via shared MediaPicker (image-only). Legacy { image: {...} } shape retained on existing posts via deprecated.js v2 migrate. New instances write the unified shape. allowedTypes={ [ 'image' ] } enforces no video on logos. alt/linkUrl/linkTarget/name are per-item JS runtime keys, declared here for schema clarity (array-item sub-properties are not subject to the D338 top-level attr-discard rule).",
		"logos": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object",
				"properties": {
					"media": {
						"type": "object"
					},
					"alt": {
						"type": "string"
					},
					"linkUrl": {
						"type": "string"
					},
					"linkTarget": {
						"type": "string"
					},
					"linkRel": {
						"type": "string"
					},
					"name": {
						"type": "string"
					}
				}
			}
		},
		"scrolling": {
			"type": "boolean",
			"default": false
		},
		"scrollSpeed": {
			"type": "string",
			"default": "medium"
		},
		"scrollDirection": {
			"type": "string",
			"default": "left"
		},
		"fadeEdges": {
			"type": "boolean",
			"default": false
		},
		"fadeWidth": {
			"type": "number",
			"default": 60
		},
		"imageEffect": {
			"type": "string",
			"default": "none"
		},
		"maxHeight": {
			"type": "number",
			"default": 180
		},
		"columnsDesktop": {
			"type": "number",
			"default": 8
		},
		"columnsTablet": {
			"type": "number",
			"default": 4
		},
		"columnsMobile": {
			"type": "number",
			"default": 2
		},
		"showNames": {
			"type": "boolean",
			"default": false
		},
		"pauseOnHover": {
			"type": "boolean",
			"default": true
		},
		"nameFontSize": {
			"type": "number"
		},
		"nameFontSizeUnit": {
			"type": "string",
			"default": "px"
		},
		"nameFontSizeTablet": {
			"type": "number"
		},
		"nameFontSizeMobile": {
			"type": "number"
		},
		"nameFontWeight": {
			"type": "string",
			"default": ""
		},
		"nameFontStyle": {
			"type": "string",
			"default": ""
		},
		"nameLineHeight": {
			"type": "number"
		},
		"nameLineHeightUnit": {
			"type": "string",
			"default": ""
		},
		"nameLineHeightTablet": {
			"type": "number"
		},
		"nameLineHeightMobile": {
			"type": "number"
		},
		"nameLetterSpacing": {
			"type": "number"
		},
		"nameLetterSpacingUnit": {
			"type": "string",
			"default": "em"
		},
		"nameLetterSpacingTablet": {
			"type": "number"
		},
		"nameLetterSpacingMobile": {
			"type": "number"
		},
		"nameTextTransform": {
			"type": "string",
			"default": ""
		},
		"nameTextDecoration": {
			"type": "string",
			"default": ""
		},
		"nameColour": {
			"type": "string",
			"default": ""
		},
		"logoGap": {
			"type": "number",
			"default": 0
		},
		"tilePadding": {
			"type": "number",
			"default": 10
		},
		"tileRadius": {
			"type": "number",
			"default": 16
		},
		"tileShape": {
			"type": "string",
			"enum": [ "square", "circle", "none" ],
			"default": "square"
		},
		"logoFit": {
			"type": "string",
			"enum": [ "contain", "cover" ],
			"default": "contain"
		},
		"tileBorderWidth": {
			"type": "number",
			"default": 0
		},
		"tileBackgroundColour": {
			"type": "string",
			"default": ""
		},
		"tileBorderColour": {
			"type": "string",
			"default": ""
		},
		"tileShadow": {
			"type": "string",
			"default": ""
		},
		"backgroundColourHover": {
			"type": "string",
			"default": ""
		},
		"textColourHover": {
			"type": "string",
			"default": ""
		},
		"borderColourHover": {
			"type": "string",
			"default": ""
		},
		"effectHover": {
			"type": "string",
			"default": "none"
		},
		"transitionDuration": {
			"type": "string",
			"default": "300"
		},
		"transitionEasing": {
			"type": "string",
			"default": "ease-in-out"
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		},
		"borderRadiusTablet": {
			"type": "object",
			"default": {}
		},
		"borderRadiusMobile": {
			"type": "object",
			"default": {}
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js",
	"render": "file:./render.php",
	"example": {
		"attributes": {
			"scrolling": true,
			"imageEffect": "none",
			"maxHeight": 80
		}
	}
}
