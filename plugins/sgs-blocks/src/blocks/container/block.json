{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/container",
	"version": "0.3.0",
	"title": "SGS Container",
	"category": "sgs-layout",
	"description": "Flexible layout wrapper — the fundamental building block for all page sections. Breakout via WP-native align (wide/full toolbar); outer cap via maxWidth literal; inner band via contentWidth token (normal/wide/full) or literal.",
	"keywords": [
		"container",
		"section",
		"wrapper",
		"layout",
		"grid",
		"flex"
	],
	"textdomain": "sgs-blocks",
	"icon": "layout",
	"supports": {
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true,
			"link": true,
			"heading": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"letterSpacing": true,
			"textTransform": true,
			"fontWeight": true,
			"fontStyle": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				],
				"contentBandPadding": [
					"contentBandPadding",
					"contentBandPaddingTablet",
					"contentBandPaddingMobile"
				]
			},
			"elements": {
				"wrapper": {
					"label": "Wrapper",
					"layer": "OUTER",
					"order": 1,
					"clusters": [ "text", "fill", "layout" ],
					"isWrapper": true,
					"attrMap": {
						"css:color": "native:color.text",
						"css:background-color": "native:color.background",
						"css:font-size": "native:typography.fontSize",
						"css:font-weight": "native:typography.fontWeight",
						"css:line-height": "native:typography.lineHeight",
						"css:letter-spacing": "native:typography.letterSpacing",
						"css:font-style": "native:typography.fontStyle",
						"css:text-transform": "native:typography.textTransform",
						"css:text-align": "native:typography.textAlign",
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin",
						"css:border-width": "native:__experimentalBorder.width",
						"css:border-style": "native:__experimentalBorder.style",
						"css:border-color": "native:__experimentalBorder.color",
						"css:border-radius": "native:__experimentalBorder.radius",
						"css:max-width": "maxWidth",
						"css:min-height": "minHeight",
						"css:box-shadow": "shadow"
					}
				},
				"grid": {
					"label": "Grid / flex layout",
					"layer": "GRID",
					"order": 2,
					"clusters": [ "layout", "flow" ],
					"attrMap": {
						"css:gap": "gap",
						"css:grid-template-columns": "gridTemplateColumns",
						"css:grid-template-rows": "gridTemplateRows",
						"css:grid-auto-rows": "gridAutoRows",
						"css:justify-items": "justifyItems",
						"css:justify-content": "justifyContent",
						"css:align-content": "alignContent",
						"css:flex-direction": "flexDirection",
						"css:flex-wrap": "flexWrap"
					},
					"_note": "Flow-cluster members map explicitly because this element declares no `prefix` — the default {prefix}{Suffix} convention cannot resolve a bare camelCase attribute. Members with no attribute on this block (display, order, overflow, align-items) remain honest GAPs."
				},
				"content-band": {
					"label": "Content band",
					"layer": "CONTENT",
					"order": 3,
					"clusters": [ "fill", "layout" ],
					"prefix": "contentBand",
					"attrMap": {
						"css:background-color": "contentBandBackground",
						"css:width": "contentWidth"
					}
				},
				"grid-item": {
					"label": "Grid item",
					"layer": "GRID_AREA",
					"order": 4,
					"clusters": [ "text", "fill", "layout" ],
					"prefix": "gridItem",
					"attrMap": {
						"css:background-color": "gridItemBackground",
						"css:padding": "gridItemPadding",
						"css:border-radius": "gridItemBorderRadius",
						"css:border-width": "gridItemBorder",
						"css:border-style": "gridItemBorder",
						"css:border-color": "gridItemBorder",
						"css:box-shadow": "gridItemShadow",
						"css:color": "gridItemTextColour"
					}
				},
				"decorative": {
					"label": "Decorative background",
					"order": 5,
					"clusters": [],
					"_note": "Background image/video (backgroundImage*/bgVideo*), background SVG (bgSvg*), overlay gradient (overlayGradient*), parallax/Ken Burns, and shape dividers (shapeDivider*) are governed by dedicated controls outside the Text/Fill/Layout style clusters, so this element declares none."
				}
			}
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-container"
	},
	"attributes": {
		"layout": {
			"type": "string",
			"default": ""
		},
		"tagName": {
			"type": "string",
			"enum": [ "div", "section", "article", "aside", "main", "nav", "header", "footer", "figure" ],
			"default": "section"
		},
		"columns": {
			"type": "number",
			"default": 2
		},
		"columnsMobile": {
			"type": "number",
			"default": 1
		},
		"columnsTablet": {
			"type": "number",
			"default": 2
		},
		"gridTemplateColumns": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsMobile": {
			"type": "string",
			"default": ""
		},
		"gap": {
			"type": "string",
			"default": ""
		},
		"gapTablet": {
			"type": "string",
			"default": ""
		},
		"gapMobile": {
			"type": "string",
			"default": ""
		},
		"backgroundImage": {
			"type": "object"
		},
		"backgroundImageTablet": {
			"type": "object"
		},
		"backgroundImageMobile": {
			"type": "object"
		},
		"backgroundSize": {
			"type": "string",
			"default": "cover",
			"enum": [
				"cover",
				"contain",
				"auto"
			]
		},
		"backgroundPosition": {
			"type": "string",
			"default": "center center"
		},
		"backgroundRepeat": {
			"type": "string",
			"default": "no-repeat",
			"enum": [
				"no-repeat",
				"repeat",
				"repeat-x",
				"repeat-y"
			]
		},
		"backgroundAttachment": {
			"type": "string",
			"default": "scroll",
			"enum": [
				"scroll",
				"fixed"
			]
		},
		"backgroundOverlayColour": {
			"type": "string"
		},
		"backgroundOverlayOpacity": {
			"type": "number",
			"default": 50
		},
		"overlayGradient": {
			"type": "boolean",
			"default": false
		},
		"overlayGradientAngle": {
			"type": "number",
			"default": 180
		},
		"overlayGradientFrom": {
			"type": "string",
			"default": ""
		},
		"overlayGradientTo": {
			"type": "string",
			"default": ""
		},
		"bgVideo": {
			"type": "object"
		},
		"bgVideoMobile": {
			"type": "object"
		},
		"bgParallax": {
			"type": "boolean",
			"default": false
		},
		"bgKenBurns": {
			"type": "boolean",
			"default": false
		},
		"bgAnimationDuration": {
			"type": "number",
			"default": 20
		},
		"shadow": {
			"type": "string"
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		},
		"maxWidthTablet": {
			"type": "string",
			"default": ""
		},
		"maxWidthMobile": {
			"type": "string",
			"default": ""
		},
		"minHeight": {
			"type": "string"
		},
		"minHeightTablet": {
			"type": "string",
			"default": ""
		},
		"minHeightMobile": {
			"type": "string",
			"default": ""
		},
		"verticalAlign": {
			"type": "string",
			"default": ""
		},
		"shapeDividerTop": {
			"type": "string",
			"default": ""
		},
		"shapeDividerTopColour": {
			"type": "string",
			"default": ""
		},
		"shapeDividerTopHeight": {
			"type": "number",
			"default": 80
		},
		"shapeDividerTopFlip": {
			"type": "boolean",
			"default": false
		},
		"shapeDividerTopInvert": {
			"type": "boolean",
			"default": false
		},
		"shapeDividerBottom": {
			"type": "string",
			"default": ""
		},
		"shapeDividerBottomColour": {
			"type": "string",
			"default": ""
		},
		"shapeDividerBottomHeight": {
			"type": "number",
			"default": 80
		},
		"shapeDividerBottomFlip": {
			"type": "boolean",
			"default": false
		},
		"shapeDividerBottomInvert": {
			"type": "boolean",
			"default": false
		},
		"bgSvgContent": {
			"type": "string",
			"default": ""
		},
		"bgSvgPosition": {
			"type": "string",
			"default": "background",
			"enum": [
				"background",
				"foreground"
			]
		},
		"bgSvgAnimation": {
			"type": "string",
			"default": "none",
			"enum": [
				"none",
				"pulse",
				"float",
				"wave"
			]
		},
		"bgSvgAnimationSpeed": {
			"type": "string",
			"default": "medium",
			"enum": [
				"slow",
				"medium",
				"fast"
			]
		},
		"bgSvgOpacity": {
			"type": "number",
			"default": 100
		},
		"bgSvgMinHeight": {
			"type": "string",
			"default": ""
		},
		"bgSvgTextShadow": {
			"type": "boolean",
			"default": false
		},
		"gridItemPadding": {
			"type": "string",
			"default": ""
		},
		"gridItemBackground": {
			"type": "string",
			"default": ""
		},
		"gridItemBorderRadius": {
			"type": "string",
			"default": ""
		},
		"gridItemBorder": {
			"type": "string",
			"default": ""
		},
		"gridItemShadow": {
			"type": "string",
			"default": ""
		},
		"gridItemTextColour": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRows": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsMobile": {
			"type": "string",
			"default": ""
		},
		"gridAutoRows": {
			"type": "string",
			"default": ""
		},
		"justifyItems": {
			"type": "string",
			"default": "stretch",
			"enum": [
				"stretch",
				"start",
				"center",
				"end"
			]
		},
		"alignContent": {
			"type": "string",
			"default": "stretch",
			"enum": [
				"stretch",
				"start",
				"center",
				"end",
				"space-between",
				"space-around",
				"space-evenly"
			]
		},
		"justifyContent": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"flex-start",
				"center",
				"flex-end",
				"space-between",
				"space-around",
				"space-evenly"
			]
		},
		"flexDirection": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"row",
				"row-reverse",
				"column",
				"column-reverse"
			]
		},
		"flexWrap": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"wrap",
				"nowrap",
				"wrap-reverse"
			]
		},
		"templateMode": {
			"type": "string",
			"default": "free",
			"enum": [
				"free",
				"grid-section",
				"card-grid"
			]
		},
		"contentWidth": {
			"type": "string",
			"default": "full"
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		},
		"contentBandPadding": {
			"type": "object",
			"default": {}
		},
		"contentBandPaddingTablet": {
			"type": "object",
			"default": {}
		},
		"contentBandPaddingMobile": {
			"type": "object",
			"default": {}
		},
		"contentBandBackground": {
			"type": "string",
			"default": ""
		},
		"contentWidthTablet": {
			"type": "string",
			"default": ""
		},
		"contentWidthMobile": {
			"type": "string",
			"default": ""
		}
	},
	"providesContext": {
		"sgs/gridItemPadding": "gridItemPadding",
		"sgs/gridItemBackground": "gridItemBackground",
		"sgs/gridItemBorderRadius": "gridItemBorderRadius",
		"sgs/gridItemBorder": "gridItemBorder",
		"sgs/gridItemShadow": "gridItemShadow",
		"sgs/gridItemTextColour": "gridItemTextColour"
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js",
	"example": {
		"attributes": {
			"layout": "grid",
			"columns": 2,
			"gap": "40"
		}
	}
}
