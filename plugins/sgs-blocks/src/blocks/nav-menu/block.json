{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/nav-menu",
	"version": "0.1.0",
	"title": "SGS Nav Menu",
	"category": "sgs-content",
	"icon": "menu",
	"description": "The site's primary navigation bar. A flat horizontal row of real links on desktop; below the collapse point it becomes a burger that opens the sgs/nav-drawer via the shared sgs/nav Interactivity store. Menu content comes from a native WordPress menu.",
	"keywords": [ "navigation", "nav", "menu", "links", "bar", "burger" ],
	"textdomain": "sgs-blocks",
	"supports": {
		"anchor": true,
		"customClassName": true,
		"html": false,
		"reusable": false,
		"sgs": {
			"containerKind": "layout"
		},
		"spacing": {
			"padding": true,
			"margin": true,
			"__experimentalSkipSerialization": true
		}
	},
	"attributes": {
		"ref": { "type": "number", "default": 0 },
		"collapsePoint": { "type": "number", "default": 768 },
		"drawerRef": { "type": "string", "default": "sgs-nav-drawer" },
		"featuredItemIds": { "type": "array", "default": [], "items": { "type": "string" } },
		"navLabel": { "type": "string", "default": "Primary" },

		"layout": { "type": "string", "default": "flex" },
		"gap": { "type": "string", "default": "8px" },
		"maxWidth": { "type": "string", "default": "" },
		"paddingTablet": { "type": "object", "default": {} },
		"paddingMobile": { "type": "object", "default": {} },

		"itemColour": { "type": "string", "default": "" },
		"itemBg": { "type": "string", "default": "" },
		"itemColourHover": { "type": "string", "default": "" },
		"itemBgHover": { "type": "string", "default": "" },
		"hoverStyle": {
			"type": "string",
			"default": "pill",
			"enum": [ "pill", "underline", "text" ]
		},
		"underlineColour": { "type": "string", "default": "" },
		"underlineColourHover": { "type": "string", "default": "" },
		"underlineThickness": { "type": "number", "default": 2 },
		"underlineOffset": { "type": "number", "default": 6 },
		"itemFontSize": { "type": "number" },
		"itemFontSizeUnit": { "type": "string", "default": "" },
		"itemFontSizeTablet": { "type": "number" },
		"itemFontSizeMobile": { "type": "number" },
		"itemFontWeight": { "type": "string", "default": "" },
		"itemFontStyle": { "type": "string", "default": "" },
		"itemLineHeight": { "type": "number" },
		"itemLineHeightUnit": { "type": "string", "default": "" },

		"featuredColour": { "type": "string", "default": "accent" },
		"featuredBg": { "type": "string", "default": "" },
		"featuredColourHover": { "type": "string", "default": "" },
		"featuredBgHover": { "type": "string", "default": "" },

		"burgerColour": { "type": "string", "default": "" },
		"burgerHoverColour": { "type": "string", "default": "" },
		"burgerSize": { "type": "string", "default": "44px" },

		"sgsCustomCss": { "type": "string", "default": "" }
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js"
}
