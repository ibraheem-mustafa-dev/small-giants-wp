{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/form-step",
	"version": "0.1.1",
	"title": "SGS Form Step",
	"category": "sgs-forms",
	"description": "Groups form fields into a step for multi-step forms.",
	"keywords": [
		"step",
		"page",
		"section"
	],
	"textdomain": "sgs-blocks",
	"icon": "editor-ol",
	"parent": [
		"sgs/form"
	],
	"supports": {
		"html": false,
		"spacing": {
			"padding": true,
			"blockGap": true,
			"__experimentalSkipSerialization": true
		},
		"color": {
			"background": true,
			"gradients": true,
			"text": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"hideExtensions": [
				"animation"
			],
			"elements": {
				"wrapper": {
					"label": "Wrapper",
					"layer": "CONTENT",
					"order": 1,
					"clusters": [ "text", "fill", "layout" ],
					"isWrapper": true,
					"attrMap": {
						"css:color": "native:color.text",
						"css:background-color": "native:color.background",
						"css:padding": "native:spacing.padding",
						"css:border-width": "native:__experimentalBorder.width",
						"css:border-style": "native:__experimentalBorder.style",
						"css:border-color": "native:__experimentalBorder.color",
						"css:border-radius": "native:__experimentalBorder.radius",
						"css:max-width": "maxWidth",
						"css:width": "contentWidth"
					},
					"_note": "CONTENT-kind composite (WS-4 composite-mirror, render.php:104-117) — width/spacing layer only via SGS_Container_Wrapper('content'). block.json declares no `margin` spacing support (only padding) and no typography support, so those members are honest gaps. Layer CONTENT names the structural role (naming discipline, FR-35-1) — this block has no GRID layer."
				}
			}
		}
	},
	"usesContext": [
		"sgs/formId"
	],
	"attributes": {
		"label": {
			"type": "string",
			"default": "Step",
			"role": "content"
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"example": {
		"attributes": {
			"label": "Your Details"
		}
	}
}
