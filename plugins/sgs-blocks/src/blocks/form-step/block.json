{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/form-step",
	"version": "0.1.1",
	"title": "SGS Form Step",
	"category": "sgs-forms",
	"description": "Groups form fields into a step for multi-step forms.",
	"keywords": [
		"step",
		"page",
		"section"
	],
	"textdomain": "sgs-blocks",
	"icon": "editor-ol",
	"parent": [
		"sgs/form"
	],
	"supports": {
		"html": false,
		"spacing": {
			"padding": true,
			"blockGap": true,
			"__experimentalSkipSerialization": true
		},
		"color": {
			"background": true,
			"gradients": true,
			"text": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"hideExtensions": [
				"animation"
			]
		}
	},
	"usesContext": [
		"sgs/formId"
	],
	"attributes": {
		"label": {
			"type": "string",
			"default": "Step",
			"role": "content"
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"example": {
		"attributes": {
			"label": "Your Details"
		}
	}
}
