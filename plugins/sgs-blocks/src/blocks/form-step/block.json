{
    "$schema":  "https://schemas.wp.org/trunk/block.json",
    "apiVersion":  3,
    "name":  "sgs/form-step",
    "version":  "0.1.0",
    "title":  "SGS Form Step",
    "category":  "sgs-forms",
    "description":  "Groups form fields into a step for multi-step forms.",
    "keywords":  [
                     "step",
                     "page",
                     "section"
                 ],
    "textdomain":  "sgs-blocks",
    "icon":  "editor-ol",
    "parent":  [
                   "sgs/form"
               ],
    "supports":  {
                     "html":  false,
                     "spacing":  {
                                     "padding":  true,
                                     "blockGap":  true,
                                     "margin":  true
                                 },
                     "color":  {
                                   "text":  true,
                                   "background":  true
                               }
                 },
    "usesContext":  [
                        "sgs/formId"
                    ],
    "attributes":  {
                       "label":  {
                                     "type":  "string",
                                     "default":  "Step"
                                 }
                   },
    "render":  "file:./render.php",
    "editorScript":  "file:./index.js",
    "example":  {
                    "attributes":  {
                                       "label":  "Your Details"
                                   }
                }
}
