{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/icon-list",
	"version": "0.1.0",
	"title": "SGS Icon List",
	"category": "sgs-content",
	"description": "List with custom icons or checkmarks per item.",
	"keywords": [
		"list",
		"icon",
		"check",
		"tick",
		"features",
		"benefits"
	],
	"textdomain": "sgs-blocks",
	"icon": "yes-alt",
	"supports": {
		"align": false,
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"link": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true
		},
		"sgs": {
			"arrayContentLift": true,
			"arrayItemSchema": {
				"items": {
					"itemSelector": ".sgs-icon-list__item",
					"fields": {
						"text": {
							"selector": ".sgs-icon-list__text",
							"role": "text-content"
						},
						"iconSource": {
							"selector": ".sgs-icon-list__icon-source",
							"role": "gap-pending",
							"gapReason": "icon-slug — no icon handler"
						},
						"iconName": {
							"selector": ".sgs-icon-list__icon-name",
							"role": "gap-pending",
							"gapReason": "icon-slug — no icon handler"
						},
						"url": {
							"selector": ".sgs-icon-list__link",
							"role": "gap-pending",
							"gapReason": "url-href — no handler"
						}
					}
				}
			}
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-icon-list",
		"typography": ".sgs-icon-list__text"
	},
	"attributes": {
		"items": {
			"type": "array",
			"default": [
				{
					"iconSource": "lucide",
					"iconName": "check",
					"text": "First list item"
				},
				{
					"iconSource": "lucide",
					"iconName": "check",
					"text": "Second list item"
				},
				{
					"iconSource": "lucide",
					"iconName": "check",
					"text": "Third list item"
				}
			]
		},
		"icon": {
			"type": "string",
			"default": "check"
		},
		"defaultIconSource": {
			"type": "string",
			"default": "lucide"
		},
		"iconColour": {
			"type": "string",
			"default": "primary"
		},
		"iconSize": {
			"type": "string",
			"default": "medium"
		},
		"dividers": {
			"type": "boolean",
			"default": false
		},
		"textColour": {
			"type": "string",
			"default": "text"
		},
		"gap": {
			"type": "string",
			"default": "20"
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"example": {
		"attributes": {
			"items": [
				{
					"icon": "check",
					"text": "BRC Grade AA certified"
				},
				{
					"icon": "check",
					"text": "Next-day delivery available"
				},
				{
					"icon": "check",
					"text": "Minimum order Â£250"
				}
			]
		}
	}
}
