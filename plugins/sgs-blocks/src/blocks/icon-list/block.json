{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/icon-list",
	"version": "0.1.0",
	"title": "SGS Icon List",
	"category": "sgs-content",
	"description": "List with custom icons or checkmarks per item.",
	"keywords": [
		"list",
		"icon",
		"check",
		"tick",
		"features",
		"benefits"
	],
	"textdomain": "sgs-blocks",
	"icon": "yes-alt",
	"supports": {
		"align": false,
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"link": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"arrayContentLift": true,
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				],
				"borderRadius": [
					"borderRadiusTablet",
					"borderRadiusMobile"
				],
				"borderWidth": [
					"borderWidth"
				]
			},
			"elements": {
				"wrapper": {
					"label": "List wrapper",
					"order": 1,
					"clusters": [ "fill", "layout" ],
					"isWrapper": true,
					"attrMap": {
						"css:background-color": "native:color.background",
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin",
						"css:border-radius": "native:__experimentalBorder.radius",
						"css:border-width": "borderWidth",
						"css:border-style": "borderStyle",
						"css:border-color": "borderColour",
						"css:gap": "gap"
					},
					"_note": "The root <ul> (render.php step 6). `gap` is the per-item spacing preset slug emitted as the `--sgs-icon-list-gap` custom-property VALUE (contract-permitted, not a declaration). No __experimentalBorder.width/color/style native support declared — border-width/style/colour are SGS custom scalar attrs (base only, no tiers), mirrors sgs/quote's borderWidth object pattern. No `layer` — this is a static list, not a configurable grid/flex composite (no display/flex-*/grid-* attrs exist)."
				},
				"item-icon": {
					"label": "Item icon",
					"order": 2,
					"clusters": [ "text" ],
					"prefix": "icon",
					"_note": "Per-item icon span (render.php:457, `.sgs-icon-list__icon`). Only `css:color` resolves (default convention `icon`+`Colour`=`iconColour`, render.php:221-223) — font-size/weight/line-height/etc are honest gaps, an icon glyph has no typography surface. iconSize/defaultIconSource are bespoke icon-source controls with no cluster member and surface as orphans, not gaps."
				},
				"item-text": {
					"label": "Item text",
					"order": 3,
					"clusters": [ "text" ],
					"attrMap": {
						"css:color": "textColour",
						"css:font-size": "native:typography.fontSize",
						"css:line-height": "native:typography.lineHeight",
						"css:text-align": "native:typography.textAlign"
					},
					"_note": "Per-item text span (render.php:457, `.sgs-icon-list__text` — the block's declared `selectors.typography`). WP-native typography.fontSize/lineHeight/textAlign are skip-serialised and rendered SCOPED ONTO THIS SELECTOR specifically (render.php step 5, `$text_sel`), not the root — so the native: attrMap targets this per-item element correctly rather than the wrapper. No font-weight/letter-spacing/font-style/text-transform/text-decoration/font-family attribute or native path exists for item text — honest gaps."
				}
			}
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-icon-list",
		"typography": ".sgs-icon-list__text"
	},
	"attributes": {
		"items": {
			"type": "array",
			"default": [
				{
					"iconSource": "lucide",
					"iconName": "check",
					"text": "First list item"
				},
				{
					"iconSource": "lucide",
					"iconName": "check",
					"text": "Second list item"
				},
				{
					"iconSource": "lucide",
					"iconName": "check",
					"text": "Third list item"
				}
			],
			"items": {
				"type": "object",
				"properties": {
					"text": {
						"type": "string"
					},
					"iconSource": {
						"type": "string"
					},
					"iconName": {
						"type": "string",
						"role": "icon-slug"
					},
					"url": {
						"type": "string",
						"role": "url-href"
					}
				}
			}
		},
		"icon": {
			"type": "string",
			"default": "check"
		},
		"defaultIconSource": {
			"type": "string",
			"default": "lucide"
		},
		"iconColour": {
			"type": "string",
			"default": "primary"
		},
		"iconSize": {
			"type": "string",
			"default": "medium"
		},
		"dividers": {
			"type": "boolean",
			"default": false
		},
		"textColour": {
			"type": "string",
			"default": "text"
		},
		"gap": {
			"type": "string",
			"default": "20"
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		},
		"borderRadiusTablet": {
			"type": "object",
			"default": {}
		},
		"borderRadiusMobile": {
			"type": "object",
			"default": {}
		},
		"borderWidth": {
			"type": "object",
			"default": {}
		},
		"borderColour": {
			"type": "string",
			"default": ""
		},
		"borderStyle": {
			"type": "string",
			"enum": [
				"none",
				"solid",
				"dashed",
				"dotted",
				"double",
				"groove",
				"ridge",
				"inset",
				"outset"
			],
			"default": "none"
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"example": {
		"attributes": {
			"items": [
				{
					"icon": "check",
					"text": "BRC Grade AA certified"
				},
				{
					"icon": "check",
					"text": "Next-day delivery available"
				},
				{
					"icon": "check",
					"text": "Minimum order Â£250"
				}
			]
		}
	}
}
