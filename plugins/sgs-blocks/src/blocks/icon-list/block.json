{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/icon-list",
	"version": "0.1.0",
	"title": "SGS Icon List",
	"category": "sgs-content",
	"description": "List with custom icons or checkmarks per item.",
	"keywords": [
		"list",
		"icon",
		"check",
		"tick",
		"features",
		"benefits"
	],
	"textdomain": "sgs-blocks",
	"icon": "yes-alt",
	"supports": {
		"align": false,
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"link": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"arrayContentLift": true,
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				],
				"borderRadius": [
					"borderRadiusTablet",
					"borderRadiusMobile"
				],
				"borderWidth": [
					"borderWidth"
				]
			}
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-icon-list",
		"typography": ".sgs-icon-list__text"
	},
	"attributes": {
		"items": {
			"type": "array",
			"default": [
				{
					"iconSource": "lucide",
					"iconName": "check",
					"text": "First list item"
				},
				{
					"iconSource": "lucide",
					"iconName": "check",
					"text": "Second list item"
				},
				{
					"iconSource": "lucide",
					"iconName": "check",
					"text": "Third list item"
				}
			],
			"items": {
				"type": "object",
				"properties": {
					"text": {
						"type": "string"
					},
					"iconSource": {
						"type": "string"
					},
					"iconName": {
						"type": "string",
						"role": "icon-slug"
					},
					"url": {
						"type": "string",
						"role": "url-href"
					}
				}
			}
		},
		"icon": {
			"type": "string",
			"default": "check"
		},
		"defaultIconSource": {
			"type": "string",
			"default": "lucide"
		},
		"iconColour": {
			"type": "string",
			"default": "primary"
		},
		"iconSize": {
			"type": "string",
			"default": "medium"
		},
		"dividers": {
			"type": "boolean",
			"default": false
		},
		"textColour": {
			"type": "string",
			"default": "text"
		},
		"gap": {
			"type": "string",
			"default": "20"
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		},
		"borderRadiusTablet": {
			"type": "object",
			"default": {}
		},
		"borderRadiusMobile": {
			"type": "object",
			"default": {}
		},
		"borderWidth": {
			"type": "object",
			"default": {}
		},
		"borderColour": {
			"type": "string",
			"default": ""
		},
		"borderStyle": {
			"type": "string",
			"enum": [
				"none",
				"solid",
				"dashed",
				"dotted",
				"double",
				"groove",
				"ridge",
				"inset",
				"outset"
			],
			"default": "none"
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"example": {
		"attributes": {
			"items": [
				{
					"icon": "check",
					"text": "BRC Grade AA certified"
				},
				{
					"icon": "check",
					"text": "Next-day delivery available"
				},
				{
					"icon": "check",
					"text": "Minimum order Â£250"
				}
			]
		}
	}
}
