{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "sgs/form-field-phone",
    "version": "0.1.0",
    "title": "SGS Phone Field",
    "category": "sgs-forms",
    "description": "A telephone number input field.",
    "keywords": [
        "phone",
        "telephone",
        "mobile",
        "number"
    ],
    "textdomain": "sgs-blocks",
    "icon": "phone",
    "parent": [
        "sgs/form",
        "sgs/form-step"
    ],
    "usesContext": [
        "sgs/formId"
    ],
    "supports": {
        "html": false,
        "anchor": false,
        "spacing": {
            "margin": true,
            "padding": true
        },
        "color": {
            "text": true,
            "background": true
        }
    },
    "attributes": {
        "fieldName": {
            "type": "string",
            "default": ""
        },
        "label": {
            "type": "string",
            "default": ""
        },
        "placeholder": {
            "type": "string",
            "default": ""
        },
        "helpText": {
            "type": "string",
            "default": ""
        },
        "required": {
            "type": "boolean",
            "default": false
        },
        "width": {
            "type": "string",
            "default": "full"
        },
        "conditionalField": {
            "type": "string",
            "default": ""
        },
        "conditionalOperator": {
            "type": "string",
            "default": "equals"
        },
        "conditionalValue": {
            "type": "string",
            "default": ""
        },
        "minLength": {
            "type": "number",
            "default": 0
        },
        "maxLength": {
            "type": "number",
            "default": 0
        },
        "pattern": {
            "type": "string",
            "default": ""
        },
        "customError": {
            "type": "string",
            "default": ""
        }
    },
    "render": "file:./render.php",
    "editorScript": "file:./index.js",
    "example": {
        "attributes": {
            "label": "Phone Number",
            "placeholder": "07700 000000",
            "required": true
        }
    }
}