{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/form-field-phone",
	"version": "0.1.0",
	"title": "Phone Field",
	"category": "sgs-forms",
	"description": "A telephone number input field.",
	"keywords": [ "phone", "telephone", "mobile", "number" ],
	"textdomain": "sgs-blocks",
	"icon": "phone",
	"parent": [ "sgs/form", "sgs/form-step" ],
	"usesContext": [ "sgs/formId" ],
	"supports": {
		"html": false,
		"anchor": false
	},
	"attributes": {
		"fieldName": {
			"type": "string",
			"default": ""
		},
		"label": {
			"type": "string",
			"default": ""
		},
		"placeholder": {
			"type": "string",
			"default": ""
		},
		"helpText": {
			"type": "string",
			"default": ""
		},
		"required": {
			"type": "boolean",
			"default": false
		},
		"width": {
			"type": "string",
			"default": "full"
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js"
}
