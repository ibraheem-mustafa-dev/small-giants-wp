{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/label",
	"version": "0.1.0",
	"title": "Label",
	"category": "sgs-content",
	"description": "Atomic eyebrow / kicker / badge text block. A BLOCK-LEVEL element by contract (renders display:block/inline-block, never a bare inline span), so vertical margins and box padding always paint. Three style variants: plain text, full-width pill fill, content-width pill wrap. Reusable for section eyebrows, card-tag badges, and intro labels.",
	"keywords": [
		"label",
		"eyebrow",
		"kicker",
		"badge",
		"pill",
		"tag"
	],
	"textdomain": "sgs-blocks",
	"icon": "tag",
	"render": "file:./render.php",
	"supports": {
		"align": true,
		"html": false,
		"color": {
			"text": true,
			"background": true,
			"link": false,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": false,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"boxFamilies": {
				"padding": [
					"padding",
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				]
			},
			"elements": {
				"label": {
					"label": "Label",
					"order": 1,
					"clusters": [ "text", "fill", "layout" ],
					"isWrapper": true,
					"attrMap": {
						"css:font-size": "fontSize",
						"css:font-weight": "fontWeight",
						"css:line-height": "lineHeight",
						"css:letter-spacing": "letterSpacing",
						"css:font-style": "fontStyle",
						"css:text-transform": "textTransform",
						"css:text-decoration": "textDecoration",
						"css:color": "textColour",
						"css:text-align": "textAlign",
						"css:font-family": "fontFamily",
						"css:background-color": "backgroundColour",
						"css:padding": "padding",
						"css:margin": "native:spacing.margin",
						"css:border-radius": "borderRadius"
					},
					"_note": "Single-semantic-element block — the <span> root IS the wrapper (render.php:63, block-level element by contract). `padding` support is declared `false` (spacing.padding=false) — padding is instead the SGS custom object attr `padding` (pill-gated, base + paddingTablet/paddingMobile tiers), not native. No __experimentalBorder support at all — border-radius is the scalar `borderRadius` attr, and border-width/style/colour have no controls on this block (honest gaps: label has no border feature). No box-shadow, no hover states, no width/height/gap/aspect-ratio attrs — all honest gaps; label is a small text chip with no image surface (no fill members beyond background-color)."
				}
			}
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-label",
		"typography": ".wp-block-sgs-label"
	},
	"attributes": {
		"text": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"textColour": {
			"type": "string",
			"default": "primary"
		},
		"backgroundColour": {
			"type": "string",
			"default": ""
		},
		"fontFamily": {
			"type": "string",
			"default": ""
		},
		"fontSize": {
			"type": "number",
			"default": 12
		},
		"fontSizeUnit": {
			"type": "string",
			"default": "px"
		},
		"fontSizeTablet": {
			"type": "number"
		},
		"fontSizeMobile": {
			"type": "number"
		},
		"fontWeight": {
			"type": "string",
			"default": "600"
		},
		"lineHeight": {
			"type": "number",
			"default": 1.2
		},
		"lineHeightUnit": {
			"type": "string",
			"default": "em"
		},
		"letterSpacing": {
			"type": "number",
			"default": 0.08
		},
		"letterSpacingUnit": {
			"type": "string",
			"default": "em"
		},
		"textTransform": {
			"type": "string",
			"default": "uppercase"
		},
		"fontStyle": {
			"type": "string",
			"enum": [
				"",
				"normal",
				"italic"
			],
			"default": ""
		},
		"textDecoration": {
			"type": "string",
			"default": ""
		},
		"textAlign": {
			"type": "string",
			"enum": [
				"",
				"left",
				"center",
				"right",
				"justify",
				"start",
				"end"
			],
			"default": ""
		},
		"padding": {
			"type": "object",
			"default": {}
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		},
		"borderRadius": {
			"type": "number",
			"default": 0
		},
		"fullWidth": {
			"type": "boolean",
			"default": false
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"example": {
		"attributes": {
			"text": "Our signature",
			"textColour": "primary"
		}
	}
}
