{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/label",
	"version": "0.1.0",
	"title": "Label",
	"category": "sgs-content",
	"description": "Atomic eyebrow / kicker / badge text block. Three style variants: plain text, full-width pill fill, content-width pill wrap. Reusable for section eyebrows, card-tag badges, and intro labels.",
	"keywords": [
		"label",
		"eyebrow",
		"kicker",
		"badge",
		"pill",
		"tag"
	],
	"textdomain": "sgs-blocks",
	"icon": "tag",
	"render": "file:./render.php",
	"supports": {
		"align": true,
		"html": false,
		"color": {
			"text": true,
			"background": true,
			"link": false,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": false,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"boxFamilies": {
				"padding": [
					"padding",
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				]
			}
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-label",
		"typography": ".wp-block-sgs-label"
	},
	"attributes": {
		"text": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"textColour": {
			"type": "string",
			"default": "primary"
		},
		"backgroundColour": {
			"type": "string",
			"default": "primary"
		},
		"fontFamily": {
			"type": "string",
			"default": ""
		},
		"fontSize": {
			"type": "number",
			"default": 12
		},
		"fontSizeUnit": {
			"type": "string",
			"default": "px"
		},
		"fontSizeTablet": {
			"type": "number"
		},
		"fontSizeMobile": {
			"type": "number"
		},
		"fontWeight": {
			"type": "string",
			"default": "600"
		},
		"lineHeight": {
			"type": "number",
			"default": 1.2
		},
		"lineHeightUnit": {
			"type": "string",
			"default": "em"
		},
		"letterSpacing": {
			"type": "number",
			"default": 0.08
		},
		"letterSpacingUnit": {
			"type": "string",
			"default": "em"
		},
		"textTransform": {
			"type": "string",
			"default": "uppercase"
		},
		"fontStyle": {
			"type": "string",
			"enum": [
				"",
				"normal",
				"italic"
			],
			"default": ""
		},
		"textDecoration": {
			"type": "string",
			"default": ""
		},
		"textAlign": {
			"type": "string",
			"enum": [
				"",
				"left",
				"center",
				"right",
				"justify",
				"start",
				"end"
			],
			"default": ""
		},
		"padding": {
			"type": "object",
			"default": {
				"top": "4px",
				"right": "12px",
				"bottom": "4px",
				"left": "12px"
			}
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		},
		"borderRadius": {
			"type": "number",
			"default": 6
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"example": {
		"attributes": {
			"text": "Our signature",
			"textColour": "primary"
		}
	}
}
