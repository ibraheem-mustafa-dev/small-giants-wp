{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/content-collection",
	"version": "1.2.0",
	"title": "Content Collection",
	"category": "sgs-content",
	"description": "Query-driven grid of content items. Runs its own WP_Query with a named selection rule and renders each result through the dual-mode product card. Inspector controls only — no code required. (Spec 24 FR-24-4/5/6.)",
	"keywords": [
		"collection",
		"query",
		"products",
		"grid",
		"loop",
		"featured",
		"filter"
	],
	"textdomain": "sgs-blocks",
	"icon": "grid-view",
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		],
		"spacing": {
			"margin": true,
			"padding": false,
			"__experimentalSkipSerialization": true
		},
		"color": {
			"background": true,
			"gradients": true,
			"text": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		}
	},
	"attributes": {
		"contentType": {
			"type": "string",
			"default": "sgs_product"
		},
		"selectionRule": {
			"type": "string",
			"default": "newest",
			"enum": [
				"newest",
				"featured",
				"most-expensive",
				"cheapest",
				"most-popular",
				"handpicked",
				"category"
			]
		},
		"count": {
			"type": "number",
			"default": 12
		},
		"handpickedIds": {
			"type": "array",
			"default": [],
			"items": {
				"type": "number"
			}
		},
		"categoryTerm": {
			"type": "number",
			"default": 0
		},
		"columns": {
			"type": "number",
			"default": 3
		},
		"emptyMessage": {
			"type": "string",
			"default": "No items to show yet. Check back soon."
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		},
		"layout": {
			"type": "string",
			"default": ""
		},
		"layoutMode": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumns": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsMobile": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRows": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsMobile": {
			"type": "string",
			"default": ""
		},
		"gridAutoRows": {
			"type": "string",
			"default": ""
		},
		"direction": {
			"type": "string",
			"default": ""
		},
		"flexDirection": {
			"type": "string",
			"default": ""
		},
		"flexWrap": {
			"type": "string",
			"default": ""
		},
		"wrap": {
			"type": "boolean",
			"default": false
		},
		"justifyContent": {
			"type": "string",
			"default": ""
		},
		"justifyItems": {
			"type": "string",
			"default": "stretch"
		},
		"alignContent": {
			"type": "string",
			"default": "stretch"
		},
		"alignItems": {
			"type": "string",
			"default": ""
		},
		"templateMode": {
			"type": "string",
			"default": "free"
		},
		"columnsDesktop": {
			"type": "number",
			"default": 0
		},
		"gap": {
			"type": "string",
			"default": ""
		},
		"gapTablet": {
			"type": "string",
			"default": ""
		},
		"gapMobile": {
			"type": "string",
			"default": ""
		},
		"columnsMobile": {
			"type": "number",
			"default": 1
		},
		"columnsTablet": {
			"type": "number",
			"default": 2
		},
		"showPickers": {
			"type": "boolean",
			"default": true,
			"description": "Forwarded to each rendered product-card. When false, suppresses in-card option-picker UI (axis pickers and pill pickers) — useful for browsing/shop grids where picker UI is unwanted. Default true."
		},
		"ctaBehaviour": {
			"type": "string",
			"default": "learn-more",
			"enum": [
				"learn-more",
				"add-to-basket",
				"buy-now"
			],
			"description": "Forwarded to each rendered product-card. Controls the primary CTA: learn-more = link to PDP; add-to-basket = SGS cart proxy; buy-now = add then redirect to checkout."
		},
		"showLadder": {
			"type": "boolean",
			"default": false,
			"description": "Forwarded to each rendered product-card. Browsing/shop grids default false (price + per-unit note only, no multi-row value ladder). PDP configurator cards use true."
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"style": "file:./style.css",
	"example": {
		"attributes": {
			"selectionRule": "newest",
			"count": 3,
			"columns": 3
		}
	}
}
