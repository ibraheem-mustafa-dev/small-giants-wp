{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/site-header-row",
	"version": "0.1.0",
	"title": "SGS Header Row",
	"category": "sgs-layout",
	"icon": "columns",
	"description": "One row of a site header — an intrinsic never-overflow cluster of header elements (logo, nav, cart, etc.) that wraps rather than overflowing at any width. Lives inside sgs/site-header.",
	"keywords": [
		"header row",
		"site header",
		"cluster",
		"navigation"
	],
	"textdomain": "sgs-blocks",
	"parent": [
		"sgs/site-header"
	],
	"supports": {
		"anchor": true,
		"customClassName": true,
		"html": false,
		"reusable": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"containerKind": "layout"
		}
	},
	"attributes": {
		"rowSlot": {
			"type": "string",
			"default": ""
		},
		"layout": {
			"type": "string",
			"default": "flex"
		},
		"flexWrap": {
			"type": "string",
			"default": "wrap"
		},
		"justifyContent": {
			"type": "string",
			"default": ""
		},
		"verticalAlign": {
			"type": "string",
			"default": "center"
		},
		"gap": {
			"type": "object",
			"default": { "desktop": "16px" }
		},
		"maxWidth": {
			"type": "object",
			"default": {}
		},
		"contentWidth": {
			"type": "object",
			"default": { "desktop": "full" }
		},
		"padding": {
			"type": "object",
			"default": {}
		},
		"margin": {
			"type": "object",
			"default": {}
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
