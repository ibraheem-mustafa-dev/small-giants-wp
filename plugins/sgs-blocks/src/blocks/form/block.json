{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/form",
	"version": "0.2.0",
	"title": "SGS Form",
	"category": "sgs-forms",
	"description": "Form wrapper with multi-step support, validation, and N8N webhook notifications.",
	"keywords": [
		"form",
		"contact",
		"application",
		"submission",
		"multi-step"
	],
	"textdomain": "sgs-blocks",
	"icon": "feedback",
	"supports": {
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		},
		"interactivity": true,
		"sgs": {
			"containerKind": "layout"
		}
	},
	"attributes": {
		"formId": {
			"type": "string",
			"default": ""
		},
		"formName": {
			"type": "string",
			"default": ""
		},
		"submitLabel": {
			"type": "string",
			"default": "Submit"
		},
		"submitStyle": {
			"type": "string",
			"default": "primary"
		},
		"successMessage": {
			"type": "string",
			"default": "Thank you! Your submission has been received.",
			"role": "content"
		},
		"successRedirect": {
			"type": "string",
			"default": ""
		},
		"honeypot": {
			"type": "boolean",
			"default": true
		},
		"storeSubmissions": {
			"type": "boolean",
			"default": true
		},
		"submitColour": {
			"type": "string",
			"default": "text-inverse"
		},
		"submitBackground": {
			"type": "string",
			"default": "primary"
		},
		"progressBarColour": {
			"type": "string",
			"default": "primary"
		},
		"requireLogin": {
			"type": "boolean",
			"default": false
		},
		"rateLimit": {
			"type": "integer",
			"default": 5
		},
		"formFocusRingColour": {
			"type": "string",
			"default": "primary"
		},
		"formFocusRingWidth": {
			"type": "number",
			"default": 2
		},
		"formFocusRingOpacity": {
			"type": "number",
			"default": 40
		},
		"formFocusRingOffset": {
			"type": "number",
			"default": 2
		},
		"layout": {
			"type": "string",
			"default": ""
		},
		"columns": {
			"type": "number",
			"default": 2
		},
		"columnsMobile": {
			"type": "number",
			"default": 1
		},
		"columnsTablet": {
			"type": "number",
			"default": 2
		},
		"gridTemplateColumns": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsMobile": {
			"type": "string",
			"default": ""
		},
		"gap": {
			"type": "string",
			"default": ""
		},
		"gapTablet": {
			"type": "string",
			"default": ""
		},
		"gapMobile": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		},
		"customWidth": {
			"type": "number",
			"default": 0
		},
		"customWidthUnit": {
			"type": "string",
			"default": "px"
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRows": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsMobile": {
			"type": "string",
			"default": ""
		},
		"gridAutoRows": {
			"type": "string",
			"default": ""
		},
		"justifyItems": {
			"type": "string",
			"default": "stretch",
			"enum": [
				"stretch",
				"start",
				"center",
				"end"
			]
		},
		"alignContent": {
			"type": "string",
			"default": "stretch",
			"enum": [
				"stretch",
				"start",
				"center",
				"end",
				"space-between",
				"space-around",
				"space-evenly"
			]
		},
		"flexDirection": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"row",
				"column"
			]
		},
		"flexWrap": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"wrap",
				"nowrap"
			]
		},
		"justifyContent": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"flex-start",
				"center",
				"flex-end",
				"space-between",
				"space-around"
			]
		},
		"templateMode": {
			"type": "string",
			"default": "free",
			"enum": [
				"free",
				"grid-section",
				"card-grid"
			]
		}
	},
	"providesContext": {
		"sgs/formId": "formId"
	},
	"allowedBlocks": [
		"sgs/form-step",
		"sgs/form-field-text",
		"sgs/form-field-email",
		"sgs/form-field-phone",
		"sgs/form-field-textarea",
		"sgs/form-field-select",
		"sgs/form-field-radio",
		"sgs/form-field-checkbox",
		"sgs/form-field-tiles",
		"sgs/form-field-file",
		"sgs/form-field-consent",
		"sgs/form-field-date",
		"sgs/form-field-number",
		"sgs/form-field-hidden",
		"sgs/form-field-address",
		"sgs/form-review"
	],
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js",
	"example": {
		"attributes": {
			"formName": "Contact Us",
			"submitLabel": "Send Message",
			"successMessage": "Thank you! We'll be in touch shortly."
		}
	}
}
