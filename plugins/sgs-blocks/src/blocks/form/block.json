{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/form",
	"version": "0.2.0",
	"title": "SGS Form",
	"category": "sgs-forms",
	"description": "Form wrapper with multi-step support, validation, and N8N webhook notifications.",
	"keywords": [
		"form",
		"contact",
		"application",
		"submission",
		"multi-step"
	],
	"textdomain": "sgs-blocks",
	"icon": "feedback",
	"supports": {
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		},
		"interactivity": true,
		"sgs": {
			"containerKind": "layout",
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				]
			},
			"elements": {
				"wrapper": {
					"label": "Wrapper",
					"layer": "OUTER",
					"order": 1,
					"clusters": [ "text", "fill", "layout" ],
					"isWrapper": true,
					"attrMap": {
						"css:color": "native:color.text",
						"css:background-color": "native:color.background",
						"css:font-size": "native:typography.fontSize",
						"css:line-height": "native:typography.lineHeight",
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin",
						"css:border-width": "native:__experimentalBorder.width",
						"css:border-style": "native:__experimentalBorder.style",
						"css:border-color": "native:__experimentalBorder.color",
						"css:border-radius": "native:__experimentalBorder.radius",
						"css:max-width": "maxWidth",
						"css:width": "contentWidth"
					},
					"_note": "WS-4 composite-mirror — outer wrapper emitted by SGS_Container_Wrapper('layout', render.php:366-382), inheriting sgs/container's full LAYOUT-scope capabilities. color/typography/border are block-private, scoped via render.php:131-198 (mirrors sgs/container's render.php pattern)."
				},
				"grid": {
					"label": "Grid / flex layout",
					"layer": "GRID",
					"order": 2,
					"clusters": [ "layout" ],
					"attrMap": {
						"css:gap": "gap",
						"css:grid-template-columns": "gridTemplateColumns",
						"css:grid-template-rows": "gridTemplateRows",
						"css:grid-auto-rows": "gridAutoRows",
						"css:justify-items": "justifyItems",
						"css:justify-content": "justifyContent",
						"css:align-content": "alignContent",
						"css:flex-direction": "flexDirection",
						"css:flex-wrap": "flexWrap"
					},
					"_note": "Composite-mirror grid capability (shared SGS_Container_Wrapper, kind='layout'). Maps explicitly — no `prefix` declared, so the default convention cannot resolve bare camelCase attrs (ROLLOUT REQUIREMENT 1)."
				},
				"submit-button": {
					"label": "Submit button",
					"order": 3,
					"clusters": [ "text", "fill" ],
					"prefix": "submit",
					"_note": "submitColour/submitBackground resolve via the default {prefix}{suffix} convention (Colour/Background suffixes). Rendered as a scoped rule on `.uid .sgs-form__button--submit` (render.php:211-228, contract §A) — not inline."
				},
				"progress-bar": {
					"label": "Progress bar",
					"order": 4,
					"clusters": [ "fill" ],
					"prefix": "progressBar",
					"attrMap": {
						"css:background-color": "progressBarColour"
					},
					"_note": "progressBarColour drives the `--sgs-progress-colour` custom-property value (render.php:230-235) — a colour setting, not a real background-color declaration, so mapped explicitly rather than via the default Bg/Background suffixes."
				},
				"focus-ring": {
					"label": "Focus ring",
					"order": 5,
					"clusters": [],
					"prefix": "formFocusRing",
					"_note": "formFocusRingColour/Width/Opacity/Offset (render.php:82-86,237-243) drive :focus-visible custom-property values on form inputs — a distinct focus-ring control surface outside the Text/Fill/Layout/Position/Motion clusters (no 'outline colour'/'ring width' member exists), so this element declares none and its attributes surface as ORPHANs (FR-35-4), same treatment as sgs/button's icon element."
				}
			}
		}
	},
	"attributes": {
		"formId": {
			"type": "string",
			"default": ""
		},
		"formName": {
			"type": "string",
			"default": ""
		},
		"submitLabel": {
			"type": "string",
			"default": "Submit"
		},
		"submitStyle": {
			"type": "string",
			"default": "primary"
		},
		"successMessage": {
			"type": "string",
			"default": "Thank you! Your submission has been received.",
			"role": "content"
		},
		"successRedirect": {
			"type": "string",
			"default": ""
		},
		"honeypot": {
			"type": "boolean",
			"default": true
		},
		"storeSubmissions": {
			"type": "boolean",
			"default": true
		},
		"submitColour": {
			"type": "string",
			"default": "text-inverse"
		},
		"submitBackground": {
			"type": "string",
			"default": "primary"
		},
		"progressBarColour": {
			"type": "string",
			"default": "primary"
		},
		"requireLogin": {
			"type": "boolean",
			"default": false
		},
		"rateLimit": {
			"type": "integer",
			"default": 5
		},
		"formFocusRingColour": {
			"type": "string",
			"default": "primary"
		},
		"formFocusRingWidth": {
			"type": "number",
			"default": 2
		},
		"formFocusRingOpacity": {
			"type": "number",
			"default": 40
		},
		"formFocusRingOffset": {
			"type": "number",
			"default": 2
		},
		"layout": {
			"type": "string",
			"default": ""
		},
		"columns": {
			"type": "number",
			"default": 2
		},
		"columnsMobile": {
			"type": "number",
			"default": 1
		},
		"columnsTablet": {
			"type": "number",
			"default": 2
		},
		"gridTemplateColumns": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsMobile": {
			"type": "string",
			"default": ""
		},
		"gap": {
			"type": "string",
			"default": ""
		},
		"gapTablet": {
			"type": "string",
			"default": ""
		},
		"gapMobile": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRows": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsMobile": {
			"type": "string",
			"default": ""
		},
		"gridAutoRows": {
			"type": "string",
			"default": ""
		},
		"justifyItems": {
			"type": "string",
			"default": "stretch",
			"enum": [
				"stretch",
				"start",
				"center",
				"end"
			]
		},
		"alignContent": {
			"type": "string",
			"default": "stretch",
			"enum": [
				"stretch",
				"start",
				"center",
				"end",
				"space-between",
				"space-around",
				"space-evenly"
			]
		},
		"flexDirection": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"row",
				"column"
			]
		},
		"flexWrap": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"wrap",
				"nowrap"
			]
		},
		"justifyContent": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"flex-start",
				"center",
				"flex-end",
				"space-between",
				"space-around"
			]
		},
		"templateMode": {
			"type": "string",
			"default": "free",
			"enum": [
				"free",
				"grid-section",
				"card-grid"
			]
		}
	},
	"providesContext": {
		"sgs/formId": "formId"
	},
	"allowedBlocks": [
		"sgs/form-step",
		"sgs/form-field-text",
		"sgs/form-field-email",
		"sgs/form-field-phone",
		"sgs/form-field-textarea",
		"sgs/form-field-select",
		"sgs/form-field-radio",
		"sgs/form-field-checkbox",
		"sgs/form-field-tiles",
		"sgs/form-field-file",
		"sgs/form-field-consent",
		"sgs/form-field-date",
		"sgs/form-field-number",
		"sgs/form-field-hidden",
		"sgs/form-field-address",
		"sgs/form-review"
	],
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js",
	"example": {
		"attributes": {
			"formName": "Contact Us",
			"submitLabel": "Send Message",
			"successMessage": "Thank you! We'll be in touch shortly."
		}
	}
}
