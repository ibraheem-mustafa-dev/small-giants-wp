{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "sgs/counter",
    "version": "0.2.0",
    "title": "SGS Counter",
    "category": "sgs-content",
    "description": "Animated number counter with prefix, suffix, and label.",
    "keywords": [
        "counter",
        "number",
        "stat",
        "animated",
        "count"
    ],
    "textdomain": "sgs-blocks",
    "icon": "chart-bar",
    "supports": {
        "align": false,
        "anchor": true,
        "html": false,
        "color": {
            "background": true,
            "text": true,
            "link": true
        },
        "typography": {
            "fontSize": true,
            "lineHeight": true,
            "textAlign": true
        },
        "spacing": {
            "margin": true,
            "padding": true
        },
        "__experimentalBorder": {
            "radius": true,
            "width": true,
            "color": true,
            "style": true
        },
        "interactivity": true
    },
    "selectors": {
        "root": ".sgs-counter",
        "typography": ".sgs-counter__number"
    },
    "attributes": {
        "number": {
            "type": "number",
            "default": 0
        },
        "prefix": {
            "type": "string",
            "default": "",
            "role": "content"
        },
        "suffix": {
            "type": "string",
            "default": "",
            "role": "content"
        },
        "label": {
            "type": "string",
            "default": "",
            "role": "content"
        },
        "duration": {
            "type": "number",
            "default": 2000
        },
        "separator": {
            "type": "boolean",
            "default": true
        },
        "numberColour": {
            "type": "string",
            "default": "primary"
        },
        "labelColour": {
            "type": "string",
            "default": "text-muted"
        },
        "labelFontSize": {
            "type": "string"
        },
        "icon": {
            "type": "string",
            "default": ""
        },
        "accentStroke": {
            "type": "boolean",
            "default": false
        }
    },
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": "file:./style-index.css",
    "render": "file:./render.php",
    "viewScriptModule": "file:./view.js",
    "example": {
        "attributes": {
            "number": 5000,
            "prefix": "",
            "suffix": "+",
            "label": "Happy Customers"
        }
    }
}
