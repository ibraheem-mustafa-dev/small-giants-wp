{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/counter",
	"version": "0.2.1",
	"title": "SGS Counter",
	"category": "sgs-content",
	"description": "Animated number counter with prefix, suffix, and label.",
	"keywords": [
		"counter",
		"number",
		"stat",
		"animated",
		"count"
	],
	"textdomain": "sgs-blocks",
	"icon": "chart-bar",
	"supports": {
		"sgs": {
			"scalarStylingLift": true,
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				],
				"borderRadius": [
					"borderRadiusTablet",
					"borderRadiusMobile"
				]
			},
			"elements": {
				"wrapper": {
					"label": "Counter box",
					"order": 1,
					"clusters": [ "fill", "layout" ],
					"isWrapper": true,
					"attrMap": {
						"css:background-color": "native:color.background",
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin",
						"css:border-width": "native:__experimentalBorder.width",
						"css:border-style": "native:__experimentalBorder.style",
						"css:border-color": "native:__experimentalBorder.color",
						"css:border-radius": "native:__experimentalBorder.radius"
					}
				},
				"number": {
					"label": "Number",
					"order": 2,
					"clusters": [ "text", "fill" ],
					"prefix": "number",
					"attrMap": {
						"css:font-size": "native:typography.fontSize",
						"css:line-height": "native:typography.lineHeight"
					},
					"_note": "selectors.typography targets .sgs-counter__number, so the block-level typography.fontSize/lineHeight supports serialise onto this element specifically, not the wrapper — unlike quote's root-level inherited-default case."
				},
				"label": {
					"label": "Label",
					"order": 3,
					"clusters": [ "text" ],
					"prefix": "label"
				},
				"icon": {
					"label": "Icon",
					"order": 4,
					"clusters": [],
					"_note": "The icon attribute is a bare slug with no colour/size control of its own — no Text/Fill/Layout member applies. accentStroke was adjudicated 2026-07-19 as a decoration toggle (an accent underline), not a paint/stroke style property, so it maps to no cluster member either."
				}
			}
		},
		"align": false,
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"link": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		},
		"interactivity": true
	},
	"selectors": {
		"root": ".sgs-counter",
		"typography": ".sgs-counter__number"
	},
	"attributes": {
		"number": {
			"type": "number",
			"default": 0
		},
		"prefix": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"suffix": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"label": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"duration": {
			"type": "number",
			"default": 2000
		},
		"separator": {
			"type": "boolean",
			"default": true
		},
		"numberColour": {
			"type": "string",
			"default": "primary"
		},
		"labelColour": {
			"type": "string",
			"default": "text-muted"
		},
		"labelFontSize": {
			"type": "number"
		},
		"labelFontSizeUnit": {
			"type": "string",
			"default": "px"
		},
		"labelFontSizeTablet": {
			"type": "number"
		},
		"labelFontSizeMobile": {
			"type": "number"
		},
		"labelFontWeight": {
			"type": "string",
			"default": ""
		},
		"labelFontStyle": {
			"type": "string",
			"default": ""
		},
		"labelLineHeight": {
			"type": "number"
		},
		"labelLineHeightUnit": {
			"type": "string",
			"default": ""
		},
		"icon": {
			"type": "string",
			"default": ""
		},
		"accentStroke": {
			"type": "boolean",
			"default": false
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		},
		"borderRadiusTablet": {
			"type": "object",
			"default": {}
		},
		"borderRadiusMobile": {
			"type": "object",
			"default": {}
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScriptModule": "file:./view.js",
	"example": {
		"attributes": {
			"number": 5000,
			"prefix": "",
			"suffix": "+",
			"label": "Happy Customers"
		}
	}
}
