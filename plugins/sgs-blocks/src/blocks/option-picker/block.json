{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/option-picker",
	"version": "0.1.9",
	"title": "SGS Option Picker",
	"category": "sgs-interactive",
	"description": "Exclusive single-select pill chooser for pack sizes, flavours, colours, plan tiers, or any option set. Emits a custom DOM event on selection — fully decoupled from any parent block.",
	"keywords": [
		"option",
		"picker",
		"pill",
		"selector",
		"size",
		"variant",
		"radio",
		"choice"
	],
	"textdomain": "sgs-blocks",
	"icon": "admin-generic",
	"render": "file:./render.php",
	"supports": {
		"align": false,
		"html": false,
		"anchor": true,
		"className": true,
		"color": {
			"background": true,
			"text": true,
			"gradients": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true,
			"__experimentalDefaultControls": {
				"margin": false,
				"padding": false
			}
		},
		"__experimentalBorder": {
			"radius": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"scalarStylingLift": true
		}
	},
	"selectors": {
		"root": ".sgs-option-picker",
		"typography": ".sgs-option-picker__pill"
	},
	"attributes": {
		"label": {
			"type": "string",
			"default": "Choose an option"
		},
		"showLabel": {
			"type": "boolean",
			"default": true
		},
		"labelFontSize": {
			"type": "number"
		},
		"labelFontSizeUnit": {
			"type": "string",
			"default": "px"
		},
		"labelFontSizeTablet": {
			"type": "number"
		},
		"labelFontSizeMobile": {
			"type": "number"
		},
		"labelFontStyle": {
			"type": "string",
			"default": ""
		},
		"labelColour": {
			"type": "string",
			"default": ""
		},
		"labelFontWeight": {
			"type": "string",
			"default": ""
		},
		"labelMarginBottom": {
			"type": "string",
			"default": ""
		},
		"optionItems": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object",
				"properties": {
					"key": {
						"type": "string"
					},
					"label": {
						"type": "string"
					}
				}
			}
		},
		"defaultSelected": {
			"type": "string",
			"default": ""
		},
		"contentImpact": {
			"type": "array",
			"default": [],
			"items": {
				"type": "string"
			}
		},
		"typeKey": {
			"type": "string",
			"default": ""
		},
		"pillStyle": {
			"type": "string",
			"default": "outlined",
			"enum": [
				"outlined",
				"filled",
				"ghost"
			]
		},
		"pillSize": {
			"type": "string",
			"default": "medium",
			"enum": [
				"small",
				"medium",
				"large"
			]
		},
		"colourPreset": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"soft",
				"solid"
			]
		},
		"showSelectedTick": {
			"type": "boolean",
			"default": true
		},
		"pillBgColour": {
			"type": "string",
			"default": ""
		},
		"pillTextColour": {
			"type": "string",
			"default": ""
		},
		"pillBorderColour": {
			"type": "string",
			"default": ""
		},
		"pillSelectedBgColour": {
			"type": "string",
			"default": ""
		},
		"pillSelectedTextColour": {
			"type": "string",
			"default": ""
		},
		"pillSelectedBorderColour": {
			"type": "string",
			"default": ""
		},
		"pillFontSize": {
			"type": "number"
		},
		"pillFontSizeUnit": {
			"type": "string",
			"default": "px"
		},
		"pillFontSizeTablet": {
			"type": "number"
		},
		"pillFontSizeMobile": {
			"type": "number"
		},
		"pillFontWeight": {
			"type": "string",
			"default": ""
		},
		"pillBorderRadius": {
			"type": "string",
			"default": ""
		},
		"pillSelectedBorderRadius": {
			"type": "string",
			"default": ""
		},
		"pillPadding": {
			"type": "object",
			"default": {}
		},
		"pillPaddingTablet": {
			"type": "object",
			"default": {}
		},
		"pillPaddingMobile": {
			"type": "object",
			"default": {}
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		},
		"borderRadiusTablet": {
			"type": "object",
			"default": {}
		},
		"borderRadiusMobile": {
			"type": "object",
			"default": {}
		},
		"borderWidth": {
			"type": "object",
			"default": {}
		},
		"borderStyle": {
			"type": "string",
			"default": "none",
			"enum": [
				"none",
				"solid",
				"dashed",
				"dotted",
				"double",
				"groove",
				"ridge",
				"inset",
				"outset"
			]
		},
		"borderColour": {
			"type": "string",
			"default": ""
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js",
	"example": {
		"attributes": {
			"label": "Pack size",
			"showLabel": true,
			"pillStyle": "outlined",
			"pillSize": "medium",
			"optionItems": [
				{
					"key": "250g",
					"label": "250g"
				},
				{
					"key": "500g",
					"label": "500g"
				},
				{
					"key": "1kg",
					"label": "1kg"
				}
			],
			"defaultSelected": "500g",
			"typeKey": "pack-size"
		}
	}
}
