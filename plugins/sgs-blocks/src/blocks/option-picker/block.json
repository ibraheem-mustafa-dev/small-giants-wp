{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/option-picker",
	"version": "0.1.10",
	"title": "SGS Option Picker",
	"category": "sgs-interactive",
	"description": "Exclusive single-select pill chooser for pack sizes, flavours, colours, plan tiers, or any option set. Emits a custom DOM event on selection — fully decoupled from any parent block.",
	"keywords": [
		"option",
		"picker",
		"pill",
		"selector",
		"size",
		"variant",
		"radio",
		"choice"
	],
	"textdomain": "sgs-blocks",
	"icon": "admin-generic",
	"render": "file:./render.php",
	"supports": {
		"align": false,
		"html": false,
		"anchor": true,
		"className": true,
		"color": {
			"background": true,
			"text": true,
			"gradients": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true,
			"__experimentalDefaultControls": {
				"margin": false,
				"padding": false
			}
		},
		"__experimentalBorder": {
			"radius": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"scalarStylingLift": true,
			"elements": {
				"root": {
					"label": "Picker (fieldset)",
					"order": 1,
					"clusters": [ "layout", "fill", "text" ],
					"isWrapper": true,
					"attrMap": {
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin",
						"css:max-width": "maxWidth",
						"css:width": "contentWidth",
						"css:border-width": "borderWidth",
						"css:border-style": "borderStyle",
						"css:border-color": "borderColour",
						"css:border-radius": "native:__experimentalBorder.radius",
						"css:background-color": "native:color.background",
						"css:color": "native:color.text"
					},
					"_note": "D294 content-KIND, no-wrapper (render.php:5-33) — the <fieldset> IS the block root (no SGS_Container_Wrapper call). Border radius stays WP-native; width/style/colour are SGS custom object/string attrs (borderWidth/borderStyle/borderColour) per render.php:123-135 — mapped explicitly since no prefix covers bare root attrs. Root has no independent typography (fontSize/weight/etc belong to legend/pill) — those text-cluster members are honest gaps."
				},
				"label": {
					"label": "Group label (legend)",
					"order": 2,
					"clusters": [ "text", "layout" ],
					"prefix": "label",
					"_note": "labelFontSize/labelColour/labelFontWeight/labelFontStyle/labelMarginBottom resolve via the default {prefix}{suffix} convention (labelMarginBottom -> css:margin-bottom, Spec 35 vocabulary fix; render.php:492-495 legend `margin-bottom:...`). line-height/letter-spacing/text-transform/text-decoration/text-align/font-family have no labelX equivalent — honest gaps."
				},
				"pill": {
					"label": "Option pill",
					"order": 3,
					"clusters": [ "text", "fill", "layout" ],
					"prefix": "pill",
					"attrMap": {
						"css:background-color": "pillBgColour"
					},
					"states": {
						"selected": {
							"attrMap": {
								"css:background-color": "pillSelectedBgColour",
								"css:color": "pillSelectedTextColour",
								"css:border-color": "pillSelectedBorderColour",
								"css:border-radius": "pillSelectedBorderRadius"
							}
						}
					},
					"_note": "FR-35-5 — 'selected' (NOT :hover/:active) is the correct state name: style.css:200/246/277 key the selected look off `input[type=radio]:checked ~ .pill`, which is the [aria-current]/is-active family the states vocabulary calls 'selected'. The CSS ALSO shows a `:hover` visual (style.css:192/241/272) but it is a STATIC preset-variant rule with no distinct hover-only attribute behind it (no pillHoverBgColour etc. exists) — correctly NOT declared as a state per FR-35-5 rule 1 (opt-in, attribute-backed only). css:background-color needs explicit attrMap (pillBgColour doesn't match the default Background/Bg/BackgroundColour suffixes); css:border-color (pillBorderColour) and css:border-radius (pillBorderRadius) and css:padding (pillPadding) and css:font-size (pillFontSize) all resolve via the default convention. css:font-weight is an honest gap — no pillFontWeight attr exists."
				}
			},
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				],
				"borderWidth": [
					"borderWidth"
				],
				"borderRadius": [
					"borderRadiusTablet",
					"borderRadiusMobile"
				],
				"pillPadding": [
					"pillPadding",
					"pillPaddingTablet",
					"pillPaddingMobile"
				]
			}
		}
	},
	"selectors": {
		"root": ".sgs-option-picker",
		"typography": ".sgs-option-picker__pill"
	},
	"attributes": {
		"label": {
			"type": "string",
			"default": "Choose an option"
		},
		"showLabel": {
			"type": "boolean",
			"default": true
		},
		"labelFontSize": {
			"type": "number"
		},
		"labelFontSizeUnit": {
			"type": "string",
			"default": "px"
		},
		"labelFontSizeTablet": {
			"type": "number"
		},
		"labelFontSizeMobile": {
			"type": "number"
		},
		"labelFontStyle": {
			"type": "string",
			"default": ""
		},
		"labelColour": {
			"type": "string",
			"default": ""
		},
		"labelFontWeight": {
			"type": "string",
			"default": ""
		},
		"labelMarginBottom": {
			"type": "string",
			"default": ""
		},
		"optionItems": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object",
				"properties": {
					"key": {
						"type": "string"
					},
					"label": {
						"type": "string"
					}
				}
			}
		},
		"defaultSelected": {
			"type": "string",
			"default": ""
		},
		"contentImpact": {
			"type": "array",
			"default": [],
			"items": {
				"type": "string"
			}
		},
		"typeKey": {
			"type": "string",
			"default": ""
		},
		"pillStyle": {
			"type": "string",
			"default": "outlined",
			"enum": [
				"outlined",
				"filled",
				"ghost"
			]
		},
		"pillSize": {
			"type": "string",
			"default": "medium",
			"enum": [
				"small",
				"medium",
				"large"
			]
		},
		"colourPreset": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"soft",
				"solid"
			]
		},
		"showSelectedTick": {
			"type": "boolean",
			"default": true
		},
		"pillBgColour": {
			"type": "string",
			"default": ""
		},
		"pillTextColour": {
			"type": "string",
			"default": ""
		},
		"pillBorderColour": {
			"type": "string",
			"default": ""
		},
		"pillSelectedBgColour": {
			"type": "string",
			"default": ""
		},
		"pillSelectedTextColour": {
			"type": "string",
			"default": ""
		},
		"pillSelectedBorderColour": {
			"type": "string",
			"default": ""
		},
		"pillFontSize": {
			"type": "number"
		},
		"pillFontSizeUnit": {
			"type": "string",
			"default": "px"
		},
		"pillFontSizeTablet": {
			"type": "number"
		},
		"pillFontSizeMobile": {
			"type": "number"
		},
		"pillFontWeight": {
			"type": "string",
			"default": ""
		},
		"pillBorderRadius": {
			"type": "string",
			"default": ""
		},
		"pillSelectedBorderRadius": {
			"type": "string",
			"default": ""
		},
		"pillPadding": {
			"type": "object",
			"default": {}
		},
		"pillPaddingTablet": {
			"type": "object",
			"default": {}
		},
		"pillPaddingMobile": {
			"type": "object",
			"default": {}
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		},
		"borderRadiusTablet": {
			"type": "object",
			"default": {}
		},
		"borderRadiusMobile": {
			"type": "object",
			"default": {}
		},
		"borderWidth": {
			"type": "object",
			"default": {}
		},
		"borderStyle": {
			"type": "string",
			"default": "none",
			"enum": [
				"none",
				"solid",
				"dashed",
				"dotted",
				"double",
				"groove",
				"ridge",
				"inset",
				"outset"
			]
		},
		"borderColour": {
			"type": "string",
			"default": ""
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js",
	"example": {
		"attributes": {
			"label": "Pack size",
			"showLabel": true,
			"pillStyle": "outlined",
			"pillSize": "medium",
			"optionItems": [
				{
					"key": "250g",
					"label": "250g"
				},
				{
					"key": "500g",
					"label": "500g"
				},
				{
					"key": "1kg",
					"label": "1kg"
				}
			],
			"defaultSelected": "500g",
			"typeKey": "pack-size"
		}
	}
}
