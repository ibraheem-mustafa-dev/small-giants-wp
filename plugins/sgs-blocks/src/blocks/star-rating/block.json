{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/star-rating",
	"version": "0.1.0",
	"title": "SGS Star Rating",
	"category": "sgs-content",
	"description": "Star rating display with half-star support and schema.org markup.",
	"keywords": [
		"star",
		"rating",
		"review",
		"score"
	],
	"textdomain": "sgs-blocks",
	"icon": "star-filled",
	"supports": {
		"align": false,
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				]
			}
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-star-rating"
	},
	"styles": [
		{
			"name": "default",
			"label": "Default",
			"isDefault": true
		},
		{
			"name": "trustpilot",
			"label": "Trustpilot (flat green)"
		},
		{
			"name": "trustpilot-official",
			"label": "Trustpilot (official badge)"
		}
	],
	"attributes": {
		"rating": {
			"type": "number",
			"default": 5
		},
		"maxRating": {
			"type": "number",
			"default": 5
		},
		"starSize": {
			"type": "number",
			"default": 24
		},
		"starColour": {
			"type": "string",
			"default": "accent"
		},
		"emptyColour": {
			"type": "string",
			"default": "border-subtle"
		},
		"label": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"showNumeric": {
			"type": "boolean",
			"default": false
		},
		"schemaEnabled": {
			"type": "boolean",
			"default": true
		},
		"schemaItemName": {
			"type": "string",
			"default": ""
		},
		"schemaReviewCount": {
			"type": "number",
			"default": 1
		},
		"displayMode": {
			"type": "string",
			"default": "stars-only",
			"enum": [
				"stars-only",
				"stars-with-value",
				"stars-with-value-and-count"
			]
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"example": {
		"attributes": {
			"rating": 4.5,
			"maxRating": 5,
			"starSize": 24,
			"label": "4.5 out of 5"
		}
	}
}
