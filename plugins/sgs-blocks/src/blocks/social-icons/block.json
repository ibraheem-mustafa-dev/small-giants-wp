{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/social-icons",
	"version": "0.2.0",
	"title": "SGS Social Icons",
	"category": "sgs-content",
	"description": "Row of social media platform icons with links. Supports Facebook, Instagram, LinkedIn, X, YouTube, TikTok, and more. Configurable size, style, and hover colour. Each icon item shape: { platform: string, url: string, label?: string }. The label field is used as the aria-label for accessibility (WCAG 2.2 SC 4.1.2). When label is empty the platform display name is used as the fallback.",
	"keywords": [
		"social",
		"icons",
		"links",
		"facebook",
		"twitter",
		"instagram"
	],
	"textdomain": "sgs-blocks",
	"icon": "share",
	"supports": {
		"align": false,
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"textAlign": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"arrayContentLift": true,
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				]
			},
			"elements": {
				"wrapper": {
					"label": "Wrapper",
					"order": 1,
					"clusters": [ "text", "fill", "layout" ],
					"isWrapper": true,
					"attrMap": {
						"css:color": "native:color.text",
						"css:background-color": "native:color.background",
						"css:text-align": "native:typography.textAlign",
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin",
						"css:gap": "gap"
					},
					"_note": "Root <div> (render.php get_block_wrapper_attributes, style.css .sgs-social-icons — display:flex is hardcoded CSS, no attribute, so no `layer` is declared and the 12 arrangement members are honestly never asked about). No `layout` box-model attrs beyond padding/margin/gap exist (no width/height/max-width/border/box-shadow control) — honest gaps."
				},
				"icon": {
					"label": "Icon",
					"order": 2,
					"clusters": [ "text" ],
					"prefix": "icon",
					"states": {
						"hover": {
							"attrMap": {
								"css:color": "iconColourHover"
							}
						}
					},
					"_note": "Per-item <a class=\"sgs-social-icons__item\"> (render.php:354). Only css:color resolves (default convention icon+Colour=iconColour, render.php --sgs-social-colour custom property). iconSize is a scalar glyph-size control with no cluster member (mirrors sgs/icon-list's iconSize) — an honest orphan, not a gap. No font-size/weight/line-height surface — an icon glyph has no typography."
				}
			}
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-social-icons"
	},
	"attributes": {
		"icons": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object",
				"properties": {
					"platform": {
						"type": "string",
						"role": "icon-slug"
					},
					"url": {
						"type": "string",
						"role": "url-href"
					},
					"label": {
						"type": "string"
					}
				}
			}
		},
		"source": {
			"type": "string",
			"enum": [ "manual", "site-info" ],
			"default": "manual"
		},
		"iconSize": {
			"type": "number",
			"default": 24
		},
		"iconColour": {
			"type": "string",
			"default": "text-muted"
		},
		"iconColourHover": {
			"type": "string",
			"default": "primary"
		},
		"iconStyle": {
			"type": "string",
			"default": "plain"
		},
		"gap": {
			"type": "string",
			"default": "20"
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"example": {
		"attributes": {
			"iconSize": 24,
			"iconStyle": "plain",
			"icons": [
				{
					"platform": "facebook",
					"url": "https://facebook.com"
				},
				{
					"platform": "instagram",
					"url": "https://instagram.com"
				},
				{
					"platform": "linkedin",
					"url": "https://linkedin.com"
				}
			]
		}
	}
}
