{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/trust-bar",
	"version": "0.5.4",
	"title": "SGS Trust Bar",
	"category": "sgs-content",
	"description": "Horizontal strip of trust signals. Three variants: icon-in-circle (default), text-only pill badges, and image-badge (certification logos). Typed mode only: curated items[] repeater. Merged from sgs/certification-bar 2026-05-29 D95.",
	"keywords": [
		"trust",
		"badges",
		"icons",
		"certifications",
		"accreditation",
		"halal",
		"brc",
		"features"
	],
	"textdomain": "sgs-blocks",
	"icon": "awards",
	"supports": {
		"sgs": {
			"imageControls": true,
			"is_section_root": true,
			"containerKind": "section",
			"arrayContentLift": true,
			"variantAttr": "badgeStyle",
			"variants": {
				"icon-circle": [
					"iconCircleSize",
					"iconCircleBackground",
					"iconColour",
					"iconCircleBorderRadius",
					"iconCircleShadow"
				],
				"text-only": [],
				"image-badge": []
			}
		},
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-trust-bar",
		"typography": ".sgs-trust-bar__label"
	},
	"attributes": {
		"badgeStyle": {
			"type": "string",
			"default": "icon-circle",
			"enum": [
				"icon-circle",
				"text-only",
				"image-badge"
			]
		},
		"items": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"icon": {
						"type": "string"
					},
					"iconSvg": {
						"type": "string"
					},
					"label": {
						"type": "string"
					},
					"url": {
						"type": "string",
						"role": "url-href"
					},
					"pending": {
						"type": "boolean"
					},
					"fillStyle": {
						"type": "string",
						"enum": [
							"outline",
							"filled"
						],
						"default": "outline"
					},
					"fillColour": {
						"type": "string"
					},
					"media": {
						"type": "object",
						"properties": {
							"url": {
								"type": "string"
							},
							"alt": {
								"type": "string"
							}
						}
					}
				}
			},
			"default": [
				{
					"icon": "truck",
					"label": "Fast delivery",
					"pending": false
				},
				{
					"icon": "check",
					"label": "Certified quality",
					"pending": false
				},
				{
					"icon": "star",
					"label": "Trusted service",
					"pending": false
				},
				{
					"icon": "heart",
					"label": "Loved by customers",
					"pending": false
				}
			]
		},
		"title": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"titleColour": {
			"type": "string",
			"default": "text-muted"
		},
		"titleFontSize": {
			"type": "number"
		},
		"titleFontSizeUnit": {
			"type": "string",
			"default": "px"
		},
		"titleFontSizeTablet": {
			"type": "number"
		},
		"titleFontSizeMobile": {
			"type": "number"
		},
		"titleFontWeight": {
			"type": "string",
			"default": ""
		},
		"titleFontStyle": {
			"type": "string",
			"default": ""
		},
		"titleLineHeight": {
			"type": "number"
		},
		"titleLineHeightUnit": {
			"type": "string",
			"default": ""
		},
		"labelColour": {
			"type": "string",
			"default": "text"
		},
		"labelFontSize": {
			"type": "number"
		},
		"labelFontSizeUnit": {
			"type": "string",
			"default": "px"
		},
		"labelFontSizeTablet": {
			"type": "number"
		},
		"labelFontSizeMobile": {
			"type": "number"
		},
		"labelFontWeight": {
			"type": "string",
			"default": ""
		},
		"labelFontStyle": {
			"type": "string",
			"default": ""
		},
		"badgeSize": {
			"type": "string",
			"default": "medium",
			"enum": [
				"small",
				"medium",
				"large"
			]
		},
		"iconCircleSize": {
			"type": "number",
			"default": 44
		},
		"iconCircleBackground": {
			"type": "string",
			"default": "surface"
		},
		"iconColour": {
			"type": "string",
			"default": "primary-dark"
		},
		"iconCircleBorderRadius": {
			"type": "string",
			"default": "50%"
		},
		"iconCircleShadow": {
			"type": "string",
			"default": "sm"
		},
		"textColour": {
			"type": "string",
			"default": "text"
		},
		"columns": {
			"type": "number",
			"default": 4
		},
		"gap": {
			"type": "string",
			"default": "20"
		},
		"showPendingInEditor": {
			"type": "boolean",
			"default": true
		},
		"autoScroll": {
			"type": "boolean",
			"default": false
		},
		"autoScrollSpeed": {
			"type": "string",
			"default": "medium",
			"enum": [
				"slow",
				"medium",
				"fast"
			]
		},
		"autoScrollPauseOnHover": {
			"type": "boolean",
			"default": true
		},
		"layout": {
			"type": "string",
			"default": "grid"
		},
		"columnsMobile": {
			"type": "number",
			"default": 2
		},
		"columnsTablet": {
			"type": "number",
			"default": 4
		},
		"gridTemplateColumns": {
			"type": "string",
			"default": "repeat(4, 1fr)"
		},
		"gridTemplateColumnsTablet": {
			"type": "string",
			"default": "repeat(4, 1fr)"
		},
		"gridTemplateColumnsMobile": {
			"type": "string",
			"default": "1fr 1fr"
		},
		"gapTablet": {
			"type": "string",
			"default": ""
		},
		"gapMobile": {
			"type": "string",
			"default": ""
		},
		"backgroundImage": {
			"type": "object"
		},
		"backgroundImageTablet": {
			"type": "object"
		},
		"backgroundImageMobile": {
			"type": "object"
		},
		"backgroundSize": {
			"type": "string",
			"default": "cover",
			"enum": [
				"cover",
				"contain",
				"auto"
			]
		},
		"backgroundPosition": {
			"type": "string",
			"default": "center center"
		},
		"backgroundRepeat": {
			"type": "string",
			"default": "no-repeat",
			"enum": [
				"no-repeat",
				"repeat",
				"repeat-x",
				"repeat-y"
			]
		},
		"backgroundAttachment": {
			"type": "string",
			"default": "scroll",
			"enum": [
				"scroll",
				"fixed"
			]
		},
		"backgroundOverlayColour": {
			"type": "string"
		},
		"backgroundOverlayOpacity": {
			"type": "number",
			"default": 50
		},
		"overlayGradient": {
			"type": "boolean",
			"default": false
		},
		"overlayGradientAngle": {
			"type": "number",
			"default": 180
		},
		"overlayGradientFrom": {
			"type": "string",
			"default": ""
		},
		"overlayGradientTo": {
			"type": "string",
			"default": ""
		},
		"bgVideo": {
			"type": "object"
		},
		"bgVideoMobile": {
			"type": "object"
		},
		"bgParallax": {
			"type": "boolean",
			"default": false
		},
		"bgKenBurns": {
			"type": "boolean",
			"default": false
		},
		"bgAnimationDuration": {
			"type": "number",
			"default": 20
		},
		"shadow": {
			"type": "string"
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		},
		"customWidth": {
			"type": "number",
			"default": 0
		},
		"customWidthUnit": {
			"type": "string",
			"default": "px"
		},
		"minHeight": {
