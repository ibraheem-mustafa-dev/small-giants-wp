{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/trust-bar",
	"version": "0.5.4",
	"title": "SGS Trust Bar",
	"category": "sgs-content",
	"description": "Horizontal strip of trust signals. Three variants: icon-in-circle (default), text-only pill badges, and image-badge (certification logos). Typed mode only: curated items[] repeater. Merged from sgs/certification-bar 2026-05-29 D95.",
	"keywords": [
		"trust",
		"badges",
		"icons",
		"certifications",
		"accreditation",
		"halal",
		"brc",
		"features"
	],
	"textdomain": "sgs-blocks",
	"icon": "awards",
	"supports": {
		"sgs": {
			"imageControls": true,
			"is_section_root": true,
			"containerKind": "section",
			"arrayContentLift": true,
			"scalarStylingLift": true,
			"variantAttr": "badgeStyle",
			"variants": {
				"icon-circle": [
					"iconCircleSize",
					"iconCircleBackground",
					"iconColour",
					"iconCircleBorderRadius",
					"iconCircleShadow"
				],
				"text-only": [],
				"image-badge": [
					"badgeImageBorderRadius",
					"badgeImageSize",
					"badgeImageShadow",
					"badgeImageObjectFit"
				]
			},
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				],
				"contentBandPadding": [
					"contentBandPadding",
					"contentBandPaddingTablet",
					"contentBandPaddingMobile"
				]
			},
			"elements": {
				"wrapper": {
					"label": "Section wrapper",
					"layer": "OUTER",
					"_layer_note": "section-KIND composite rendered via SGS_Container_Wrapper (D294 — keeps the wrapper, genuine grid/section). This element is both the block root and the grid definition, mirroring sgs/card-grid's grid element.",
					"order": 1,
					"clusters": [ "fill", "layout" ],
					"isWrapper": true,
					"attrMap": {
						"css:background-color": "native:color.background",
						"css:background-attachment": "backgroundAttachment",
						"css:background-position": "backgroundPosition",
						"css:background-repeat": "backgroundRepeat",
						"css:background-size": "backgroundSize",
						"css:background-image": "backgroundOverlayColour",
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin",
						"css:max-width": "maxWidth",
						"css:min-height": "minHeight",
						"css:border-width": "native:__experimentalBorder.width",
						"css:border-style": "native:__experimentalBorder.style",
						"css:border-color": "native:__experimentalBorder.color",
						"css:border-radius": "native:__experimentalBorder.radius",
						"css:box-shadow": "shadow",
						"css:gap": "gap",
						"css:grid-template-columns": "gridTemplateColumns",
						"css:grid-template-rows": "gridTemplateRows",
						"css:grid-auto-rows": "gridAutoRows",
						"css:justify-items": "justifyItems",
						"css:justify-content": "justifyContent",
						"css:align-content": "alignContent",
						"css:flex-direction": "flexDirection",
						"css:flex-wrap": "flexWrap"
					},
					"_note": "gridTemplateColumns/Rows, gap, justify-*/align-content/flex-* are consumed by SGS_Container_Wrapper via the universal wrapper mechanism (render.php:214-220 comment). No alignItems/display/overflow/aspect-ratio/width/height/max-height attrs exist — honest gaps."
				},
				"icon-badge": {
					"label": "Icon badge (icon-circle variant)",
					"order": 2,
					"clusters": [ "fill", "layout", "text" ],
					"prefix": "icon",
					"attrMap": {
						"css:background-color": "iconCircleBackground",
						"css:width": "iconCircleSize",
						"css:height": "iconCircleSize",
						"css:border-radius": "iconCircleBorderRadius",
						"css:box-shadow": "iconCircleShadow",
						"css:color": "iconColour"
					},
					"_note": "iconColour (the SVG stroke/fill colour, style.css:80 `color: var(--sgs-trust-badge-icon-colour, ...)`) resolves via css:color (text cluster) — mirrors sgs/icon's own icon element + sgs/business-info's icon element, which use the same functional-icon-colour/css:color convention (Spec 35 vocabulary fix). Only applies when badgeStyle='icon-circle' (supports.sgs.variants)."
				},
				"label": {
					"label": "Badge label",
					"order": 3,
					"clusters": [ "text" ],
					"prefix": "label",
					"_note": "Covers both variants — .sgs-trust-bar__label (icon-circle) and .sgs-trust-bar__badge-label (text-only/image-badge), same labelColour/labelFontSize/labelFontWeight/labelFontStyle attrs (render.php:393)."
				},
				"title": {
					"label": "Title",
					"order": 4,
					"clusters": [ "text" ],
					"prefix": "title"
				},
				"badge-item": {
					"label": "Badge item",
					"order": 5,
					"clusters": [],
					"_note": "Per-item fillStyle/fillColour (image-badge and text-only item content) are repeater-row fields, not independent block-level style controls — no badge-item-specific text/fill/layout attrs exist at the block level."
				}
			}
		},
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-trust-bar",
		"typography": ".sgs-trust-bar__label"
	},
	"attributes": {
		"badgeStyle": {
			"type": "string",
			"default": "icon-circle",
			"enum": [
				"icon-circle",
				"text-only",
				"image-badge"
			]
		},
		"items": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"icon": {
						"type": "string"
					},
					"iconSvg": {
						"type": "string"
					},
					"label": {
						"type": "string"
					},
					"url": {
						"type": "string",
						"role": "url-href"
					},
					"pending": {
						"type": "boolean"
					},
					"fillStyle": {
						"type": "string",
						"enum": [
							"outline",
							"filled"
						],
						"default": "outline"
					},
					"fillColour": {
						"type": "string"
					},
					"media": {
						"type": "object",
						"properties": {
							"url": {
								"type": "string"
							},
							"alt": {
								"type": "string"
							}
						}
					}
				}
			},
			"default": [
				{
					"icon": "truck",
					"label": "Fast delivery",
					"pending": false
				},
				{
					"icon": "check",
					"label": "Certified quality",
					"pending": false
				},
				{
					"icon": "star",
					"label": "Trusted service",
					"pending": false
				},
				{
					"icon": "heart",
					"label": "Loved by customers",
					"pending": false
				}
			]
		},
		"title": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"titleColour": {
			"type": "string",
			"default": "text-muted"
		},
		"titleFontSize": {
			"type": "number"
		},
		"titleFontSizeUnit": {
			"type": "string",
			"default": "px"
		},
		"titleFontSizeTablet": {
			"type": "number"
		},
		"titleFontSizeMobile": {
			"type": "number"
		},
		"titleFontWeight": {
			"type": "string",
			"default": ""
		},
		"titleFontStyle": {
			"type": "string",
			"default": ""
		},
		"titleLineHeight": {
			"type": "number"
		},
		"titleLineHeightUnit": {
			"type": "string",
			"default": ""
		},
		"labelColour": {
			"type": "string",
			"default": "text"
		},
		"labelFontSize": {
			"type": "number"
		},
		"labelFontSizeUnit": {
			"type": "string",
			"default": "px"
		},
		"labelFontSizeTablet": {
			"type": "number"
		},
		"labelFontSizeMobile": {
			"type": "number"
		},
		"labelFontWeight": {
			"type": "string",
			"default": ""
		},
		"labelFontStyle": {
			"type": "string",
			"default": ""
		},
		"badgeSize": {
			"type": "string",
			"default": "medium",
			"enum": [
				"small",
				"medium",
				"large"
			]
		},
		"iconCircleSize": {
			"type": "number",
			"default": 44
		},
		"iconCircleBackground": {
			"type": "string",
			"default": "surface"
		},
		"iconColour": {
			"type": "string",
			"default": "primary-dark"
		},
		"iconCircleBorderRadius": {
			"type": "string",
			"default": "50%"
		},
		"iconCircleShadow": {
			"type": "string",
			"default": "sm"
		},
		"badgeImageBorderRadius": {
			"type": "string",
			"default": ""
		},
		"badgeImageSize": {
			"type": "number",
			"default": 60
		},
		"badgeImageShadow": {
			"type": "string",
			"default": ""
		},
		"badgeImageObjectFit": {
			"type": "string",
			"default": "contain",
			"enum": [
				"cover",
				"contain"
			]
		},
		"textColour": {
			"type": "string",
			"default": "text"
		},
		"columns": {
			"type": "number",
			"default": 4
		},
		"gap": {
			"type": "string",
			"default": "20"
		},
		"autoScroll": {
			"type": "boolean",
			"default": false
		},
		"autoScrollSpeed": {
			"type": "string",
			"default": "medium",
			"enum": [
				"slow",
				"medium",
				"fast"
			]
		},
		"autoScrollPauseOnHover": {
			"type": "boolean",
			"default": true
		},
		"layout": {
			"type": "string",
			"default": "grid"
		},
		"columnsMobile": {
			"type": "number",
			"default": 2
		},
		"columnsTablet": {
			"type": "number",
			"default": 4
		},
		"gridTemplateColumns": {
			"type": "string",
			"default": "repeat(4, 1fr)"
		},
		"gridTemplateColumnsTablet": {
			"type": "string",
			"default": "repeat(4, 1fr)"
		},
		"gridTemplateColumnsMobile": {
			"type": "string",
			"default": "1fr 1fr"
		},
		"gapTablet": {
			"type": "string",
			"default": ""
		},
		"gapMobile": {
			"type": "string",
			"default": ""
		},
		"backgroundImage": {
			"type": "object"
		},
		"backgroundImageTablet": {
			"type": "object"
		},
		"backgroundImageMobile": {
			"type": "object"
		},
		"backgroundSize": {
			"type": "string",
			"default": "cover",
			"enum": [
				"cover",
				"contain",
				"auto"
			]
		},
		"backgroundPosition": {
			"type": "string",
			"default": "center center"
		},
		"backgroundRepeat": {
			"type": "string",
			"default": "no-repeat",
			"enum": [
				"no-repeat",
				"repeat",
				"repeat-x",
				"repeat-y"
			]
		},
		"backgroundAttachment": {
			"type": "string",
			"default": "scroll",
			"enum": [
				"scroll",
				"fixed"
			]
		},
		"backgroundOverlayColour": {
			"type": "string"
		},
		"backgroundOverlayOpacity": {
			"type": "number",
			"default": 50
		},
		"overlayGradient": {
			"type": "boolean",
			"default": false
		},
		"overlayGradientAngle": {
			"type": "number",
			"default": 180
		},
		"overlayGradientFrom": {
			"type": "string",
			"default": ""
		},
		"overlayGradientTo": {
			"type": "string",
			"default": ""
		},
		"bgVideo": {
			"type": "object"
		},
		"bgVideoMobile": {
			"type": "object"
		},
		"bgParallax": {
			"type": "boolean",
			"default": false
		},
		"bgKenBurns": {
			"type": "boolean",
			"default": false
		},
		"bgAnimationDuration": {
			"type": "number",
			"default": 20
		},
		"shadow": {
			"type": "string"
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		},
		"minHeight": {
			"type": "string"
		},
		"minHeightTablet": {
			"type": "string",
			"default": ""
		},
		"minHeightMobile": {
			"type": "string",
			"default": ""
		},
		"verticalAlign": {
			"type": "string",
			"default": "start"
		},
		"shapeDividerTop": {
			"type": "string",
			"default": ""
		},
		"shapeDividerTopColour": {
			"type": "string",
			"default": ""
		},
		"shapeDividerTopHeight": {
			"type": "number",
			"default": 80
		},
		"shapeDividerTopFlip": {
			"type": "boolean",
			"default": false
		},
		"shapeDividerTopInvert": {
			"type": "boolean",
			"default": false
