{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/cta-section",
	"version": "0.2.0",
	"title": "SGS CTA Section",
	"category": "sgs-content",
	"description": "Call-to-action section with headline, supporting text, and buttons.",
	"keywords": [
		"cta",
		"call",
		"action",
		"banner",
		"buttons"
	],
	"textdomain": "sgs-blocks",
	"icon": "megaphone",
	"supports": {
		"sgs": {
			"imageControls": false,
			"is_section_root": true,
			"arrayContentLift": true,
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				],
				"contentBandPadding": [
					"contentBandPadding",
					"contentBandPaddingTablet",
					"contentBandPaddingMobile"
				]
			},
			"elements": {
				"wrapper": {
					"label": "Wrapper",
					"layer": "OUTER",
					"order": 1,
					"clusters": [ "fill", "layout" ],
					"isWrapper": true,
					"attrMap": {
						"css:background-color": "native:color.background",
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin",
						"css:border-width": "native:__experimentalBorder.width",
						"css:border-style": "native:__experimentalBorder.style",
						"css:border-color": "native:__experimentalBorder.color",
						"css:border-radius": "native:__experimentalBorder.radius",
						"css:max-width": "maxWidth",
						"css:min-height": "minHeight",
						"css:box-shadow": "shadow"
					},
					"_note": "block.json's own Selectors API deliberately splits colour: color.background/color.text are scoped to the wrapper root (.wp-block-sgs-cta-section) so buttons/body/ribbon inherit text colour by cascade, while typography (fontSize/lineHeight/etc) is re-selectored to .sgs-cta-section__headline — see the 'headline' element below for that half of the split."
				},
				"headline": {
					"label": "Headline",
					"order": 2,
					"clusters": [ "text" ],
					"attrMap": {
						"css:color": "native:color.text",
						"css:font-size": "native:typography.fontSize",
						"css:font-weight": "native:typography.fontWeight",
						"css:line-height": "native:typography.lineHeight",
						"css:letter-spacing": "native:typography.letterSpacing",
						"css:font-style": "native:typography.fontStyle",
						"css:text-transform": "native:typography.textTransform",
						"css:text-align": "native:typography.textAlign"
					}
				},
				"body": {
					"label": "Body text",
					"order": 3,
					"clusters": [],
					"_note": "The body attribute has no dedicated typography/colour attrs of its own — it inherits the wrapper's native text colour and the theme's body typography by cascade, mirroring quote's 'quote-body' pattern."
				},
				"ribbon": {
					"label": "Ribbon",
					"order": 4,
					"clusters": [],
					"_note": "The ribbon attribute is a plain string with no dedicated style attrs — it renders with fixed component styling, not a per-instance Text/Fill/Layout control set."
				},
				"buttons": {
					"label": "Buttons",
					"order": 5,
					"clusters": [],
					"_note": "Each buttons[] item carries a 'style' preset token (e.g. accent/outline), not per-instance colour/typography/layout attrs — button appearance is driven by the shared button-style tokens, outside the Text/Fill/Layout style clusters."
				},
				"grid": {
					"label": "Grid / flex layout",
					"layer": "GRID",
					"order": 6,
					"clusters": [ "layout", "flow" ],
					"attrMap": {
						"css:gap": "gap",
						"css:grid-template-columns": "gridTemplateColumns",
						"css:grid-template-rows": "gridTemplateRows",
						"css:grid-auto-rows": "gridAutoRows",
						"css:justify-items": "justifyItems",
						"css:justify-content": "justifyContent",
						"css:align-content": "alignContent",
						"css:flex-direction": "flexDirection",
						"css:flex-wrap": "flexWrap"
					},
					"_note": "As on sgs/container: gridTemplateColumns/Rows, justifyItems/Content, flexDirection/Wrap define the grid itself and have no golden-master Text/Fill/Layout equivalent — only gap resolves; the rest are correctly-flagged GAPs."
				},
				"content-band": {
					"label": "Content band",
					"layer": "CONTENT",
					"order": 7,
					"clusters": [ "fill", "layout" ],
					"prefix": "contentBand",
					"attrMap": {
						"css:background-color": "contentBandBackground",
						"css:width": "contentWidth"
					}
				},
				"grid-item": {
					"label": "Grid item (stats)",
					"layer": "GRID_AREA",
					"order": 8,
					"clusters": [ "text", "fill", "layout" ],
					"prefix": "gridItem",
					"attrMap": {
						"css:background-color": "gridItemBackground",
						"css:padding": "gridItemPadding",
						"css:border-radius": "gridItemBorderRadius",
						"css:border-width": "gridItemBorder",
						"css:border-style": "gridItemBorder",
						"css:border-color": "gridItemBorder",
						"css:box-shadow": "gridItemShadow",
						"css:color": "gridItemTextColour"
					}
				},
				"decorative": {
					"label": "Decorative background",
					"order": 9,
					"clusters": [],
					"_note": "Background image/video (backgroundImage*/backgroundMedia/bgVideo*), background SVG (bgSvg*), overlay gradient/colour (overlayGradient*/backgroundOverlay*), parallax/Ken Burns, and shape dividers (shapeDivider*) are governed by dedicated controls outside the Text/Fill/Layout style clusters."
				}
			}
		},
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"letterSpacing": true,
			"textTransform": true,
			"fontWeight": true,
			"fontStyle": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"shadow": {
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-cta-section",
		"border": ".wp-block-sgs-cta-section",
		"color": {
			"background": ".wp-block-sgs-cta-section",
			"text": ".wp-block-sgs-cta-section"
		},
		"spacing": {
			"padding": ".wp-block-sgs-cta-section",
			"margin": ".wp-block-sgs-cta-section"
		},
		"typography": {
			"root": ".sgs-cta-section__headline",
			"fontSize": ".sgs-cta-section__headline",
			"fontFamily": ".sgs-cta-section__headline",
			"fontWeight": ".sgs-cta-section__headline",
			"lineHeight": ".sgs-cta-section__headline",
			"letterSpacing": ".sgs-cta-section__headline",
			"textTransform": ".sgs-cta-section__headline",
			"textDecoration": ".sgs-cta-section__headline"
		}
	},
	"attributes": {
		"headline": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"body": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"buttons": {
			"type": "array",
			"default": []
		},
		"ribbon": {
			"type": "string",
			"default": ""
		},
		"backgroundColor": {
			"type": "string",
			"default": "accent"
		},
		"textColor": {
			"type": "string",
			"default": "text"
		},
		"backgroundImage": {
			"type": "object",
			"default": null
		},
		"_comment_backgroundMedia": "Migrated 2026-05-05 â€” backgroundImage retained for deprecation. New instances should use backgroundMedia (accepts image OR video).",
		"backgroundMedia": {
			"type": "object",
			"default": null
		},
		"backgroundImageOpacity": {
			"type": "number",
			"default": 30
		},
		"stats": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object",
				"properties": {
					"text": {
						"type": "string"
					}
				}
			}
		},
		"gradientPreset": {
			"type": "string",
			"default": ""
		},
		"backgroundColourHover": {
			"type": "string",
			"default": ""
		},
		"textColourHover": {
			"type": "string",
			"default": ""
		},
		"borderColourHover": {
			"type": "string",
			"default": ""
		},
		"transitionDuration": {
			"type": "string",
			"default": "300"
		},
		"transitionEasing": {
			"type": "string",
			"default": "ease-in-out"
		},
		"contentLayout": {
			"type": "string",
			"default": "centred"
		},
		"layout": {
			"type": "string",
			"default": ""
		},
		"columns": {
			"type": "number",
			"default": 2
		},
		"columnsMobile": {
			"type": "number",
			"default": 1
		},
		"columnsTablet": {
			"type": "number",
			"default": 2
		},
		"gridTemplateColumns": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsMobile": {
			"type": "string",
			"default": ""
		},
		"gap": {
			"type": "string",
			"default": ""
		},
		"gapTablet": {
			"type": "string",
			"default": ""
		},
		"gapMobile": {
			"type": "string",
			"default": ""
		},
		"backgroundImageTablet": {
			"type": "object"
		},
		"backgroundImageMobile": {
			"type": "object"
		},
		"backgroundSize": {
			"type": "string",
			"default": "cover",
			"enum": [
				"cover",
				"contain",
				"auto"
			]
		},
		"backgroundPosition": {
			"type": "string",
			"default": "center center"
		},
		"backgroundRepeat": {
			"type": "string",
			"default": "no-repeat",
			"enum": [
				"no-repeat",
				"repeat",
				"repeat-x",
				"repeat-y"
			]
		},
		"backgroundAttachment": {
			"type": "string",
			"default": "scroll",
			"enum": [
				"scroll",
				"fixed"
			]
		},
		"backgroundOverlayColour": {
			"type": "string"
		},
		"backgroundOverlayOpacity": {
			"type": "number",
			"default": 50
		},
		"overlayGradient": {
			"type": "boolean",
			"default": false
		},
		"overlayGradientAngle": {
			"type": "number",
			"default": 180
		},
		"overlayGradientFrom": {
			"type": "string",
			"default": ""
		},
		"overlayGradientTo": {
			"type": "string",
			"default": ""
		},
		"bgVideo": {
			"type": "object"
		},
		"bgVideoMobile": {
			"type": "object"
		},
		"bgParallax": {
			"type": "boolean",
			"default": false
		},
		"bgKenBurns": {
			"type": "boolean",
			"default": false
		},
		"bgAnimationDuration": {
			"type": "number",
			"default": 20
		},
		"shadow": {
			"type": "string"
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		},
		"minHeight": {
			"type": "string"
		},
		"minHeightTablet": {
			"type": "string",
			"default": ""
		},
		"minHeightMobile": {
			"type": "string",
			"default": ""
		},
		"verticalAlign": {
			"type": "string",
			"default": "start"
		},
		"shapeDividerTop": {
			"type": "string",
			"default": ""
		},
		"shapeDividerTopColour": {
			"type": "string",
			"default": ""
		},
		"shapeDividerTopHeight": {
			"type": "number",
			"default": 80
		},
		"shapeDividerTopFlip": {
			"type": "boolean",
			"default": false
		},
		"shapeDividerTopInvert": {
			"type": "boolean",
			"default": false
		},
		"shapeDividerBottom": {
			"type": "string",
			"default": ""
		},
		"shapeDividerBottomColour": {
			"type": "string",
			"default": ""
		},
		"shapeDividerBottomHeight": {
			"type": "number",
			"default": 80
		},
		"shapeDividerBottomFlip": {
			"type": "boolean",
			"default": false
		},
		"shapeDividerBottomInvert": {
			"type": "boolean",
			"default": false
		},
		"bgSvgContent": {
			"type": "string",
			"default": ""
		},
		"bgSvgPosition": {
			"type": "string",
			"default": "background",
			"enum": [
				"background",
				"foreground"
			]
		},
		"bgSvgAnimation": {
			"type": "string",
			"default": "none",
			"enum": [
				"none",
				"pulse",
				"float",
				"wave"
			]
		},
		"bgSvgAnimationSpeed": {
			"type": "string",
			"default": "medium",
			"enum": [
				"slow",
				"medium",
				"fast"
			]
		},
		"bgSvgOpacity": {
			"type": "number",
			"default": 100
		},
		"bgSvgMinHeight": {
			"type": "string",
			"default": ""
		},
		"bgSvgTextShadow": {
			"type": "boolean",
			"default": false
		},
		"gridItemPadding": {
			"type": "string",
			"default": ""
		},
		"gridItemBackground": {
			"type": "string",
			"default": ""
		},
		"gridItemBorderRadius": {
			"type": "string",
			"default": ""
		},
		"gridItemBorder": {
			"type": "string",
			"default": ""
		},
		"gridItemShadow": {
			"type": "string",
			"default": ""
		},
		"gridItemTextColour": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRows": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsMobile": {
			"type": "string",
			"default": ""
		},
		"gridAutoRows": {
			"type": "string",
			"default": ""
		},
		"justifyItems": {
			"type": "string",
			"default": "stretch",
			"enum": [
				"stretch",
				"start",
				"center",
				"end"
			]
		},
		"alignContent": {
			"type": "string",
			"default": "stretch",
			"enum": [
				"stretch",
				"start",
				"center",
				"end",
				"space-between",
				"space-around",
				"space-evenly"
			]
		},
		"justifyContent": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"flex-start",
				"center",
				"flex-end",
				"space-between",
				"space-around"
			]
		},
		"flexDirection": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"row",
				"column"
			]
		},
		"flexWrap": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"wrap",
				"nowrap"
			]
		},
		"templateMode": {
			"type": "string",
			"default": "free",
			"enum": [
				"free",
				"grid-section",
				"card-grid"
			]
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		},
		"contentBandBackground": {
			"type": "string",
			"default": ""
		},
		"contentBandPadding": {
			"type": "object",
			"default": {}
		},
		"contentBandPaddingTablet": {
			"type": "object",
			"default": {}
		},
		"contentBandPaddingMobile": {
			"type": "object",
			"default": {}
		},
		"contentWidthMobile": {
			"type": "string",
			"default": ""
		},
		"contentWidthTablet": {
			"type": "string",
			"default": ""
		},
		"maxWidthMobile": {
			"type": "string",
			"default": ""
		},
		"maxWidthTablet": {
			"type": "string",
			"default": ""
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"example": {
		"attributes": {
			"headline": "Ready to order in bulk?",
			"body": "Get competitive wholesale pricing with next-day delivery across the UK.",
			"layout": "centred",
			"buttons": [
				{
					"text": "Request a Quote",
					"style": "accent",
					"url": ""
				}
			]
		}
	}
}
