{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/cta-section",
	"version": "0.2.0",
	"title": "SGS CTA Section",
	"category": "sgs-content",
	"description": "Call-to-action section with headline, supporting text, and buttons.",
	"keywords": [
		"cta",
		"call",
		"action",
		"banner",
		"buttons"
	],
	"textdomain": "sgs-blocks",
	"icon": "megaphone",
	"supports": {
		"sgs": {
			"imageControls": false,
			"is_section_root": true,
			"arrayContentLift": true
		},
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"letterSpacing": true,
			"textTransform": true,
			"fontWeight": true,
			"fontStyle": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"shadow": true,
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-cta-section",
		"typography": ".sgs-cta-section__headline"
	},
	"attributes": {
		"headline": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"body": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"buttons": {
			"type": "array",
			"default": []
		},
		"ribbon": {
			"type": "string",
			"default": ""
		},
		"backgroundColor": {
			"type": "string",
			"default": "accent"
		},
		"textColor": {
			"type": "string",
			"default": "text"
		},
		"headlineColour": {
			"type": "string",
			"default": "text"
		},
		"bodyColour": {
			"type": "string",
			"default": "text"
		},
		"buttonColour": {
			"type": "string",
			"default": "text-inverse"
		},
		"buttonBackground": {
			"type": "string",
			"default": "primary-dark"
		},
		"backgroundImage": {
			"type": "object",
			"default": null
		},
		"_comment_backgroundMedia": "Migrated 2026-05-05 â€” backgroundImage retained for deprecation. New instances should use backgroundMedia (accepts image OR video).",
		"backgroundMedia": {
			"type": "object",
			"default": null
		},
		"backgroundImageOpacity": {
			"type": "number",
			"default": 30
		},
		"stats": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object",
				"properties": {
					"text": {
						"type": "string"
					}
				}
			}
		},
		"buttonStyle": {
			"type": "string",
			"default": "solid",
			"enum": [
				"solid",
				"outline",
				"ghost",
				"gradient"
			]
		},
		"buttonSize": {
			"type": "string",
			"default": "md",
			"enum": [
				"xs",
				"sm",
				"md",
				"lg",
				"xl"
			]
		},
		"buttonBorderColour": {
			"type": "string"
		},
		"buttonBorderWidth": {
			"type": "number"
		},
		"buttonBorderRadius": {
			"type": "number"
		},
		"gradientPreset": {
			"type": "string",
			"default": ""
		},
		"hoverBackgroundColour": {
			"type": "string",
			"default": ""
		},
		"hoverTextColour": {
			"type": "string",
			"default": ""
		},
		"hoverBorderColour": {
			"type": "string",
			"default": ""
		},
		"transitionDuration": {
			"type": "string",
			"default": "300"
		},
		"transitionEasing": {
			"type": "string",
			"default": "ease-in-out"
		},
		"textAlignMobile": {
			"type": "string",
			"default": ""
		},
		"textAlignTablet": {
			"type": "string",
			"default": ""
