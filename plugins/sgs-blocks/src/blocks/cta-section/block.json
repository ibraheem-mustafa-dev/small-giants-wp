				"no-repeat",
				"repeat",
				"repeat-x",
				"repeat-y"
			]
		},
		"backgroundAttachment": {
			"type": "string",
			"default": "scroll",
			"enum": [
				"scroll",
				"fixed"
			]
		},
		"backgroundOverlayColour": {
			"type": "string"
		},
		"backgroundOverlayOpacity": {
			"type": "number",
			"default": 50
