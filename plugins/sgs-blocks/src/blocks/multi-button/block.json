{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "sgs/multi-button",
  "version": "1.4.0",
  "title": "SGS Button Group",
  "category": "sgs-content",
  "description": "A flexible container for one or more SGS Buttons. Provides per-breakpoint layout, gap, alignment, and wrap controls.",
  "keywords": [
    "button group",
    "cta",
    "buttons",
    "multi button"
  ],
  "icon": "button",
  "textdomain": "sgs-blocks",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "editorStyle": "file:./index.css",
  "render": "file:./render.php",
  "allowedBlocks": [
    "sgs/button"
  ],
  "supports": {
    "anchor": true,
    "customClassName": true,
    "html": false,
    "color": {
      "background": true,
      "gradients": true,
      "text": true,
      "__experimentalSkipSerialization": true
    },
    "__experimentalBorder": {
      "radius": true,
      "width": true,
      "color": true,
      "style": true,
      "__experimentalSkipSerialization": true
    }
  },
  "attributes": {
    "direction": {
      "type": "string",
      "default": "row"
    },
    "directionTablet": {
      "type": "string",
      "default": ""
    },
    "directionMobile": {
      "type": "string",
      "default": "column"
    },
    "gap": {
      "type": "string",
      "default": "12px"
    },
    "gapTablet": {
      "type": "string",
      "default": ""
    },
    "gapMobile": {
      "type": "string",
      "default": "8px"
    },
    "justifyContent": {
      "type": "string",
      "default": "flex-start"
    },
    "justifyContentTablet": {
      "type": "string",
      "default": ""
    },
    "justifyContentMobile": {
      "type": "string",
      "default": ""
    },
    "wrap": {
      "type": "string",
      "default": "nowrap"
    },
    "wrapTablet": {
      "type": "string",
      "default": ""
    },
    "wrapMobile": {
      "type": "string",
      "default": "nowrap"
    },
    "alignItems": {
      "type": "string",
      "default": "center"
    },
    "alignItemsTablet": {
      "type": "string",
      "default": ""
    },
    "alignItemsMobile": {
      "type": "string",
      "default": "stretch"
    },
    "contentWidth": {
      "type": "string",
      "default": ""
    },
    "maxWidth": {
      "type": "string",
      "default": ""
    }
  },
  "example": {
    "attributes": {
      "direction": "row",
      "gap": "12px",
      "justifyContent": "flex-start"
    }
  }
}
