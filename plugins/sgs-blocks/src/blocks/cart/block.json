{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/cart",
	"version": "0.1.0",
	"title": "SGS Cart",
	"category": "sgs-interactive",
	"description": "WooCommerce mini-cart: live item-count badge plus an optional flyout (disclosure) or drawer (dialog) panel with AJAX add/qty/remove via the WooCommerce Store API. Hydrates client-side to bypass full-page cache.",
	"keywords": [
		"cart",
		"basket",
		"woocommerce",
		"shop",
		"mini-cart",
		"ecommerce"
	],
	"textdomain": "sgs-blocks",
	"icon": "cart",
	"supports": {
		"align": [
			"left",
			"center",
			"right"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": false,
			"text": false
		},
		"spacing": {
			"margin": true,
			"padding": false,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"imageControls": false,
			"boxFamilies": {
				"margin": [
					"marginTablet",
					"marginMobile"
				]
			},
			"elements": {
				"wrapper": {
					"label": "Cart wrapper",
					"order": 1,
					"clusters": [ "layout" ],
					"isWrapper": true,
					"attrMap": {
						"css:margin": "native:spacing.margin"
					},
					"_note": "supports.color is explicitly {background:false,text:false} and spacing.padding is false — layout is scoped to margin only (every other layout member is a real gap, not a missing declaration)."
				},
				"icon": {
					"label": "Cart icon",
					"order": 2,
					"clusters": [ "text" ],
					"prefix": "icon",
					"attrMap": {
						"css:color": "iconColour"
					},
					"_note": "iconSize is a real attribute but is not a css:font-size (sets width/height, not text size) — no cluster member exists, so it is an honest ORPHAN (FR-35-4)."
				},
				"badge": {
					"label": "Item-count badge",
					"order": 3,
					"clusters": [ "text", "fill" ],
					"prefix": "badge",
					"attrMap": {
						"css:background-color": "badgeColour",
						"css:color": "badgeTextColour"
					},
					"_note": "badgeColour/badgeTextColour do not follow the default {prefix}{suffix} convention — explicit attrMap required per ROLLOUT REQUIREMENT 1."
				},
				"panel": {
					"label": "Mini-cart panel",
					"order": 4,
					"clusters": [ "fill", "text" ],
					"prefix": "panel",
					"attrMap": {
						"css:background-color": "panelBg",
						"css:color": "panelTextColour"
					},
					"_note": "FR-36-19 Phase 2 — the flyout/drawer panel surface. panelBg/panelTextColour do not follow {prefix}{suffix} — explicit attrMap. Only rendered when displayMode is flyout|drawer."
				}
			}
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-cart"
	},
	"attributes": {
		"displayMode": {
			"type": "string",
			"default": "link",
			"enum": [
				"link",
				"flyout",
				"drawer"
			]
		},
		"iconName": {
			"type": "string",
			"default": "shopping-cart"
		},
		"iconSize": {
			"type": "number",
			"default": 24
		},
		"iconColour": {
			"type": "string",
			"default": "primary"
		},
		"badgeColour": {
			"type": "string",
			"default": "accent"
		},
		"badgeTextColour": {
			"type": "string",
			"default": "accent-text"
		},
		"ariaLabel": {
			"type": "string",
			"default": "View your cart"
		},
		"showZero": {
			"type": "boolean",
			"default": false
		},
		"hideWhenEmpty": {
			"type": "boolean",
			"default": false
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		},
		"panelHeading": {
			"type": "string",
			"default": "Your cart"
		},
		"emptyCartMessage": {
			"type": "string",
			"default": "Your cart is empty"
		},
		"emptyCartCtaLabel": {
			"type": "string",
			"default": "Continue shopping"
		},
		"viewCartLabel": {
			"type": "string",
			"default": "View cart"
		},
		"checkoutLabel": {
			"type": "string",
			"default": "Checkout"
		},
		"autoOpenOnAdd": {
			"type": "boolean",
			"default": true
		},
		"hideOnCartCheckoutPages": {
			"type": "boolean",
			"default": true
		},
		"panelBg": {
			"type": "string",
			"default": "base"
		},
		"panelTextColour": {
			"type": "string",
			"default": "contrast"
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScriptModule": "file:./view.js",
	"example": {
		"attributes": {
			"iconName": "shopping-cart",
			"iconSize": 24,
			"iconColour": "primary",
			"badgeColour": "accent"
		}
	}
}
