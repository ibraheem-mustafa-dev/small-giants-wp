{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/product-faq-item",
	"version": "0.1.0",
	"title": "SGS Product FAQ Item",
	"category": "sgs-content",
	"description": "A single question and answer pair inside a Product FAQ block. The visible content is read by search engines to improve AI search citation and Bing visibility.",
	"keywords": [
		"faq",
		"question",
		"answer",
		"item",
		"product"
	],
	"textdomain": "sgs-blocks",
	"icon": "arrow-down-alt2",
	"parent": [
		"sgs/product-faq"
	],
	"supports": {
		"html": false,
		"reusable": false,
		"color": {
			"background": true,
			"gradients": true,
			"text": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"elements": {
				"item": {
					"label": "FAQ item",
					"order": 1,
					"clusters": [ "fill", "layout" ],
					"isWrapper": true,
					"attrMap": {
						"css:color": "native:color.text",
						"css:background-color": "native:color.background",
						"css:border-width": "native:__experimentalBorder.width",
						"css:border-style": "native:__experimentalBorder.style",
						"css:border-color": "native:__experimentalBorder.color",
						"css:border-radius": "native:__experimentalBorder.radius"
					},
					"_note": "No `text` cluster declared — this block declares no `typography` support at all and no per-element font attrs (question/isOpen are content-only), so a text cluster would resolve zero members and violate ROLLOUT REQUIREMENT 1. Similarly no `spacing` support exists (padding/margin absent) — those layout members are honest gaps."
				}
			}
		}
	},
	"usesContext": [
		"sgs/productFaqIconPosition"
	],
	"attributes": {
		"question": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"isOpen": {
			"type": "boolean",
			"default": false
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"example": {
		"attributes": {
			"question": "What are the ingredients?",
			"isOpen": true
		}
	}
}
