{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "sgs/modal",
  "version": "0.1.0",
  "title": "SGS Modal",
  "category": "sgs-interactive",
  "description": "Trigger button that opens a modal overlay with any content inside. Fully accessible with focus trap and keyboard navigation.",
  "keywords": [
    "modal",
    "popup",
    "dialog",
    "overlay",
    "lightbox"
  ],
  "textdomain": "sgs-blocks",
  "icon": "welcome-view-site",
  "supports": {
    "align": false,
    "anchor": true,
    "html": false,
    "color": {
      "background": false,
      "text": false
    }
  },
  "attributes": {
    "triggerText": {
      "type": "string",
      "default": "Open Modal"
    },
    "triggerStyle": {
      "type": "string",
      "default": "primary",
      "enum": ["primary", "secondary", "text-link"]
    },
    "triggerColour": {
      "type": "string"
    },
    "triggerBackground": {
      "type": "string"
    },
    "maxWidth": {
      "type": "string",
      "default": "medium",
      "enum": ["small", "medium", "large", "full"]
    },
    "closeOnOverlay": {
      "type": "boolean",
      "default": true
    },
    "modalBackground": {
      "type": "string",
      "default": "white"
    },
    "overlayColour": {
      "type": "string",
      "default": "#000000"
    },
    "overlayOpacity": {
      "type": "number",
      "default": 50
    }
  },
  "render": "file:./render.php",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScriptModule": "file:./view.js"
}
