{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/form-field-tiles",
	"version": "0.1.0",
	"title": "Tiles Field",
	"category": "sgs-forms",
	"description": "Visual tile selection with icons.",
	"keywords": [ "tiles", "choice", "visual", "icon" ],
	"textdomain": "sgs-blocks",
	"icon": "grid-view",
	"parent": [ "sgs/form", "sgs/form-step" ],
	"usesContext": [ "sgs/formId" ],
	"supports": {
		"html": false,
		"anchor": false
	},
	"attributes": {
		"fieldName": {
			"type": "string",
			"default": ""
		},
		"label": {
			"type": "string",
			"default": ""
		},
		"placeholder": {
			"type": "string",
			"default": ""
		},
		"helpText": {
			"type": "string",
			"default": ""
		},
		"required": {
			"type": "boolean",
			"default": false
		},
		"width": {
			"type": "string",
			"default": "full"
		},
		"tiles": {
			"type": "array",
			"default": []
		},
		"multiSelect": {
			"type": "boolean",
			"default": false
		},
		"columns": {
			"type": "number",
			"default": 3
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js"
}
