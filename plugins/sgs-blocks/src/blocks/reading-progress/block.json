{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/reading-progress",
	"version": "0.1.0",
	"title": "SGS Reading Progress",
	"category": "sgs-interactive",
	"description": "Displays a reading-progress bar and/or countdown at the top or bottom of the viewport, automatically calculating estimated reading time from the article content. Place once in your article or single-post template — not per page.",
	"keywords": [
		"reading",
		"progress",
		"scroll",
		"timer",
		"article",
		"blog"
	],
	"icon": "book",
	"textdomain": "sgs-blocks",
	"supports": {
		"align": false,
		"anchor": true,
		"html": false,
		"multiple": false,
		"customClassName": false
	},
	"attributes": {
		"displayMode": {
			"type": "string",
			"default": "both",
			"enum": [ "bar", "countdown", "both" ]
		},
		"position": {
			"type": "string",
			"default": "top",
			"enum": [ "top", "bottom" ]
		},
		"targetSelector": {
			"type": "string",
			"default": "main, article, .entry-content"
		},
		"wpm": {
			"type": "number",
			"default": 225
		},
		"barColour": {
			"type": "string",
			"default": "accent"
		},
		"barHeight": {
			"type": "number",
			"default": 4
		},
		"countdownPosition": {
			"type": "string",
			"default": "separate-pill",
			"enum": [ "inline-with-bar", "separate-pill" ]
		},
		"hideOnPages": {
			"type": "array",
			"default": [],
			"items": {
				"type": "number"
			}
		},
		"showWhenFinished": {
			"type": "boolean",
			"default": false
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./editor.css",
	"style": "file:./style.css",
	"viewScriptModule": "file:./view.js",
	"render": "file:./render.php",
	"example": {
		"attributes": {
			"displayMode": "both",
			"position": "top",
			"barColour": "accent",
			"barHeight": 4
		}
	}
}
