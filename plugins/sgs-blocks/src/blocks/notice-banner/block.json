{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/notice-banner",
	"version": "0.9.0",
	"title": "SGS Notice Banner",
	"category": "sgs-content",
	"description": "Inline informational banner for contextual messages like minimum order values, delivery terms, or promotional notices.",
	"keywords": [
		"notice",
		"banner",
		"alert",
		"info",
		"message",
		"announcement"
	],
	"textdomain": "sgs-blocks",
	"icon": "megaphone",
	"supports": {
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"fontStyle": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				]
			},
			"elements": {
				"banner": {
					"label": "Banner",
					"layer": "CONTENT",
					"order": 1,
					"clusters": [ "text", "fill", "layout" ],
					"isWrapper": true,
					"attrMap": {
						"css:color": "native:color.text",
						"css:background-color": "native:color.background",
						"css:font-size": "native:typography.fontSize",
						"css:line-height": "native:typography.lineHeight",
						"css:font-style": "native:typography.fontStyle",
						"css:text-align": "native:typography.textAlign",
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin",
						"css:border-width": "native:__experimentalBorder.width",
						"css:border-style": "native:__experimentalBorder.style",
						"css:border-color": "native:__experimentalBorder.color",
						"css:border-radius": "native:__experimentalBorder.radius",
						"css:max-width": "maxWidth",
						"css:width": "contentWidth"
					},
					"_note": "NO-WRAPPER, content-KIND (D294, render.php:9-21) — dropped SGS_Container_Wrapper, block-private; every declaration scoped to the block's own `.{uid}` style (render.php:200-278). Layer CONTENT names the structural role (this block has no GRID layer)."
				},
				"icon": {
					"label": "Icon",
					"order": 2,
					"clusters": [ "text" ],
					"prefix": "icon",
					"_note": "iconColour resolves via the default {prefix}{suffix} convention (Colour suffix). Emitted as a scoped rule `.{uid} .sgs-notice-banner__icon{color:...}` (render.php:203-207), not inline."
				}
			}
		}
	},
	"selectors": {
		"root": ".sgs-notice-banner",
		"typography": ".sgs-notice-banner__text"
	},
	"attributes": {
		"icon": {
			"type": "string",
			"default": "info"
		},
		"iconSource": {
			"type": "string",
			"default": ""
		},
		"iconName": {
			"type": "string",
			"default": ""
		},
		"showIcon": {
			"type": "boolean",
			"default": true
		},
		"text": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"variant": {
			"type": "string",
			"default": "info"
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		},
		"iconColour": {
			"type": "string",
			"default": ""
		},
		"displayMode": {
			"type": "string",
			"default": "inline",
			"enum": [
				"inline",
				"announcement"
			]
		},
		"stickyPosition": {
			"type": "string",
			"default": "top",
			"enum": [
				"top",
				"bottom"
			]
		},
		"dismissible": {
			"type": "boolean",
			"default": false
		},
		"dismissBehaviour": {
			"type": "string",
			"default": "session",
			"enum": [
				"session",
				"permanent"
			]
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js",
	"example": {
		"attributes": {
			"variant": "info",
			"icon": "info",
			"text": "Minimum order value of £250 applies to all wholesale orders."
		}
	}
}
