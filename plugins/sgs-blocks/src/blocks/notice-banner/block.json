{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/notice-banner",
	"version": "0.9.0",
	"title": "SGS Notice Banner",
	"category": "sgs-content",
	"description": "Inline informational banner for contextual messages like minimum order values, delivery terms, or promotional notices.",
	"keywords": [
		"notice",
		"banner",
		"alert",
		"info",
		"message",
		"announcement"
	],
	"textdomain": "sgs-blocks",
	"icon": "megaphone",
	"supports": {
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"fontStyle": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		}
	},
	"selectors": {
		"root": ".sgs-notice-banner",
		"typography": ".sgs-notice-banner__text"
	},
	"attributes": {
		"icon": {
			"type": "string",
			"default": "info"
		},
		"iconSource": {
			"type": "string",
			"default": ""
		},
		"iconName": {
			"type": "string",
			"default": ""
		},
		"showIcon": {
			"type": "boolean",
			"default": true
		},
		"text": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"variant": {
			"type": "string",
			"default": "info"
		},
		"textColour": {
			"type": "string",
			"default": "text"
		},
		"textFontSize": {
			"type": "string"
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		},
		"iconColour": {
			"type": "string",
			"default": ""
		},
		"displayMode": {
			"type": "string",
			"default": "inline",
			"enum": [
				"inline",
				"announcement"
			]
		},
		"stickyPosition": {
			"type": "string",
			"default": "top",
			"enum": [
				"top",
				"bottom"
			]
		},
		"dismissible": {
			"type": "boolean",
			"default": false
		},
		"dismissBehaviour": {
			"type": "string",
			"default": "session",
			"enum": [
				"session",
				"permanent"
			]
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js",
	"example": {
		"attributes": {
			"variant": "info",
			"icon": "info",
			"text": "Minimum order value of £250 applies to all wholesale orders."
		}
	}
}
