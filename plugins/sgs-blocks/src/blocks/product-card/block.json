{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "sgs/product-card",
    "version": "1.11.0",
    "title": "Product Card",
    "category": "sgs-content",
    "description": "Product card with pack-size variant pills, price and CTA. Typed mode = author content directly (InnerBlocks). Bound mode = render a live WooCommerce or SGS product (price, image, stock, add-to-cart) through the SGS design.",
    "keywords": [
        "product",
        "card",
        "ecommerce",
        "shop",
        "variant",
        "pack",
        "pricing"
    ],
    "textdomain": "sgs-blocks",
    "icon": "products",
    "supports": {
        "sgs": {
            "imageControls": true
        },
        "html": false,
        "align": false,
        "interactivity": true,
        "spacing": {
            "margin": true,
            "padding": false
        }
    },
    "attributes": {
        "sourceMode": {
            "type": "string",
            "default": "typed",
            "enum": [
                "typed",
                "wc-product",
                "sgs-cpt"
            ]
        },
        "productId": {
            "type": "number",
            "default": 0
        },
        "taxDisplayMode": {
            "type": "string",
            "default": "auto",
            "enum": [
                "auto",
                "inc-suffix",
                "ex-plus-vat"
            ]
        },
        "image": {
            "type": "string",
            "default": ""
        },
        "imageAlt": {
            "type": "string",
            "default": "",
            "role": "content"
        },
        "productName": {
            "type": "string",
            "default": ""
        },
        "description": {
            "type": "string",
            "default": "",
            "role": "content"
        },
        "variantStyle": {
            "type": "string",
            "default": "standard",
            "enum": [
                "standard",
                "trial",
                "featured"
            ]
        },
        "trialTag": {
            "type": "string",
            "default": ""
        },
        "featuredTag": {
            "type": "string",
            "default": "",
            "description": "Tag text for featured variant (e.g. Most popular, Best selling, Flagship product). Mirror of trialTag for the featured variant. Rendered as a coloured strip above the card content when variantStyle='featured'."
        },
        "packSizes": {
            "type": "array",
            "default": []
        },
        "priceLarge": {
            "type": "string",
            "default": ""
        },
        "priceNote": {
            "type": "string",
            "default": ""
        },
        "ctaText": {
            "type": "string",
            "default": ""
        },
        "ctaUrl": {
            "type": "string",
            "default": ""
        },
        "cardMaxWidth": {
            "type": "string",
            "default": "",
            "description": "Override the card max-width (e.g. 320px, 100%). Empty = use theme default (380px). Sets --sgs-product-card-max-width inline."
        },
        "widthMode": {
            "type": "string",
            "default": "default",
            "enum": ["default", "wide", "full", "custom"]
        },
        "widthModeMobile": {
            "type": "string",
            "default": ""
        },
        "widthModeTablet": {
            "type": "string",
            "default": ""
        },
        "widthModeDesktop": {
            "type": "string",
            "default": ""
        },
        "customWidth": {
            "type": "number",
            "default": 0
        },
        "customWidthUnit": {
            "type": "string",
            "default": "px"
        },
        "contentWidth": {
            "type": "string",
            "default": ""
        },
        "maxWidth": {
            "type": "string",
            "default": ""
        }
    },
    "editorScript": "file:./index.js",
    "style": "file:./style.css",
    "viewScriptModule": "file:./view.js",
    "render": "file:./render.php",
    "allowedBlocks": [
        "sgs/media",
        "core/heading",
        "sgs/text",
        "sgs/label",
        "sgs/multi-button",
        "sgs/button"
    ],
    "example": {
        "attributes": {
            "productName": "Mama's Munches Zookies",
            "description": "Baked fresh every week and posted the same day.",
            "variantStyle": "standard",
            "packSizes": [
                {
                    "label": "8-pack",
                    "selected": true
                },
                {
                    "label": "12-pack",
                    "selected": false
                },
                {
                    "label": "20-pack",
                    "selected": false
                },
                {
                    "label": "40-pack",
                    "selected": false
                }
            ],
            "priceLarge": "£10.00",
            "priceNote": "8-pack · Free delivery over £35",
            "ctaText": "Add to Cart — £10",
            "ctaUrl": "/product/zookies/"
        }
    }
}
