{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "sgs/back-to-top",
  "version": "0.1.0",
  "title": "SGS Back to Top",
  "category": "sgs-content",
  "description": "Floating back-to-top button that appears on scroll.",
  "keywords": ["back", "top", "scroll", "up", "button"],
  "textdomain": "sgs-blocks",
  "icon": "arrow-up-alt",
  "supports": {
    "align": false,
    "html": false
  },
  "attributes": {
    "buttonColour": { "type": "string", "default": "primary" },
    "iconColour": { "type": "string", "default": "surface" },
    "size": { "type": "number", "default": 48 },
    "offset": { "type": "number", "default": 24 },
    "showAfter": { "type": "number", "default": 300 }
  },
  "render": "file:./render.php",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "viewScriptModule": "file:./view.js"
}
