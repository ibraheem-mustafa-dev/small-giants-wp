{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "sgs/button",
    "version": "1.0.0",
    "title": "SGS Button",
    "category": "sgs-content",
    "description": "A highly-configurable button with preset binding, icon support, hover states, and per-breakpoint controls.",
    "keywords": [
        "button",
        "cta",
        "link",
        "call to action"
    ],
    "textdomain": "sgs-blocks",
    "icon": "button",
    "supports": {
        "anchor": true,
        "customClassName": true,
        "html": false,
        "color": {
            "background": true,
            "text": true,
            "link": false
        },
        "spacing": {
            "margin": true,
            "padding": true
        }
    },
    "attributes": {
        "label": {
            "type": "string",
            "default": "Click Here",
            "role": "content"
        },
        "url": {
            "type": "string",
            "default": "",
            "role": "content"
        },
        "linkTarget": {
            "type": "string",
            "default": "_self"
        },
        "rel": {
            "type": "string",
            "default": ""
        },
        "download": {
            "type": "boolean",
            "default": false
        },
        "tagName": {
            "type": "string",
            "default": "a"
        },
        "isSubmit": {
            "type": "boolean",
            "default": false
        },
        "inheritStyle": {
            "type": "string",
            "default": "primary"
        },
        "widthType": {
            "type": "string",
            "default": "fit"
        },
        "customWidth": {
            "type": "number",
            "default": null
        },
        "customWidthUnit": {
            "type": "string",
            "default": "px"
        },
        "minHeight": {
            "type": "number",
            "default": null
        },
        "minHeightUnit": {
