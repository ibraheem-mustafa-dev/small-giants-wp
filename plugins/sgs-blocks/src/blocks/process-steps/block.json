{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/process-steps",
	"version": "0.2.0",
	"title": "SGS Process Steps",
	"category": "sgs-content",
	"description": "Horizontal timeline showing a multi-step process.",
	"keywords": [
		"process",
		"steps",
		"timeline",
		"how",
		"workflow"
	],
	"textdomain": "sgs-blocks",
	"icon": "editor-ol",
	"supports": {
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"letterSpacing": true,
			"textTransform": true,
			"fontWeight": true,
			"fontStyle": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"shadow": {
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"arrayContentLift": true,
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				],
				"borderWidth": [
					"borderWidth"
				]
			}
		}
	},
	"selectors": {
		"root": ".sgs-process-steps",
		"typography": ".sgs-process-steps__title"
	},
	"attributes": {
		"steps": {
			"type": "array",
			"default": [
				{
					"number": "1",
					"title": "First Step",
					"description": "Description of the first step."
				},
				{
					"number": "2",
					"title": "Second Step",
					"description": "Description of the second step."
				},
				{
					"number": "3",
					"title": "Third Step",
					"description": "Description of the third step."
				}
			],
			"items": {
				"type": "object",
				"properties": {
					"icon": {
						"type": "string"
					},
					"number": {
						"type": "string"
					},
					"title": {
						"type": "string"
					},
					"description": {
						"type": "string"
					}
				}
			}
		},
		"connectorStyle": {
			"type": "string",
			"default": "line"
		},
		"numberStyle": {
			"type": "string",
			"default": "circle"
		},
		"numberColour": {
			"type": "string",
			"default": "text-inverse"
		},
		"numberBackground": {
			"type": "string",
			"default": "primary"
		},
		"titleColour": {
			"type": "string",
			"default": "text"
		},
		"descriptionColour": {
			"type": "string",
			"default": "text-muted"
		},
		"hoverBackgroundColour": {
			"type": "string",
			"default": ""
		},
		"hoverTextColour": {
			"type": "string",
			"default": ""
		},
		"hoverBorderColour": {
			"type": "string",
			"default": ""
		},
		"hoverEffect": {
			"type": "string",
			"default": "none"
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		},
		"borderWidth": {
			"type": "object",
			"default": {}
		},
		"borderStyle": {
			"type": "string",
			"enum": [
				"none",
				"solid",
				"dashed",
				"dotted",
				"double",
				"groove",
				"ridge",
				"inset",
				"outset"
			],
			"default": "none"
		},
		"borderColour": {
			"type": "string",
			"default": ""
		},
		"transitionDuration": {
			"type": "string",
			"default": "300"
		},
		"transitionEasing": {
			"type": "string",
			"default": "ease-in-out"
		},
		"sgsAnimation": {
			"type": "string",
			"default": "fade-up"
		},
		"sgsAnimationDuration": {
			"type": "string",
			"default": "medium"
		},
		"sgsAnimationEasing": {
			"type": "string",
			"default": "ease-out"
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"example": {
		"attributes": {
			"steps": [
				{
					"number": "1",
					"title": "Request a Quote",
					"description": "Fill in our online form with your requirements."
				},
				{
					"number": "2",
					"title": "We Prepare Your Order",
					"description": "Our team picks and packs your items fresh."
				},
				{
					"number": "3",
					"title": "Next-Day Delivery",
					"description": "Your order arrives the following business day."
				}
			]
		}
	}
}
