{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/process-steps",
	"version": "0.2.0",
	"title": "SGS Process Steps",
	"category": "sgs-content",
	"description": "Horizontal timeline showing a multi-step process.",
	"keywords": [
		"process",
		"steps",
		"timeline",
		"how",
		"workflow"
	],
	"textdomain": "sgs-blocks",
	"icon": "editor-ol",
	"supports": {
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"letterSpacing": true,
			"textTransform": true,
			"fontWeight": true,
			"fontStyle": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"shadow": {
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"arrayContentLift": true,
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				],
				"borderWidth": [
					"borderWidth"
				]
			},
			"elements": {
				"wrapper": {
					"label": "Wrapper",
					"order": 1,
					"clusters": [ "text", "fill", "layout", "motion" ],
					"isWrapper": true,
					"attrMap": {
						"css:color": "native:color.text",
						"css:background-color": "native:color.background",
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin",
						"css:border-radius": "native:__experimentalBorder.radius",
						"css:border-width": "borderWidth",
						"css:border-color": "borderColour",
						"css:border-style": "borderStyle",
						"css:box-shadow": "native:shadow",
						"css:transition-duration": "transitionDuration",
						"css:transition-timing-function": "transitionEasing"
					},
					"states": {
						"hover": {
							"attrMap": {
								"css:background-color": "backgroundColourHover",
								"css:color": "textColourHover",
								"css:border-color": "borderColourHover"
							}
						}
					},
					"_note": "No `layer` declared (leaf content block, no grid/flex attrs). `effectHover` is a preset picker choosing WHICH hover treatment applies (Spec 35 FR-35-5 false-friend — contains 'Hover' but is not itself a state-variant style property, so it is NOT mapped into `states.hover` and stays an honest orphan/behaviour toggle). Root native `typography` is declared in block.json but routed via `selectors.typography` to `.sgs-process-steps__title`, NOT this wrapper — see the `title` element, which owns text-cluster typography instead."
				},
				"title": {
					"label": "Step title",
					"order": 2,
					"clusters": [ "text" ],
					"prefix": "title",
					"attrMap": {
						"css:color": "titleColour",
						"css:font-size": "native:typography.fontSize",
						"css:line-height": "native:typography.lineHeight",
						"css:font-weight": "native:typography.fontWeight",
						"css:font-style": "native:typography.fontStyle",
						"css:letter-spacing": "native:typography.letterSpacing",
						"css:text-transform": "native:typography.textTransform",
						"css:text-align": "native:typography.textAlign"
					},
					"_note": "block.json declares `selectors.typography: '.sgs-process-steps__title'`, so the root's native typography paints the step TITLE. titleColour is a separate design-token colour attr (resolves via default convention `title`+`Colour`)."
				},
				"number": {
					"label": "Step number badge",
					"order": 3,
					"clusters": [ "text", "fill" ],
					"prefix": "number",
					"attrMap": {
						"css:color": "numberColour",
						"css:background-color": "numberBackground"
					},
					"_note": "numberStyle (circle/square/none variant) is a structural/variant selector, not a style-cluster member — not mapped. Both colour members resolve via default convention (`number`+`Colour`/`Background`)."
				},
				"description": {
					"label": "Step description",
					"order": 4,
					"clusters": [ "text" ],
					"prefix": "description",
					"attrMap": {
						"css:color": "descriptionColour"
					},
					"_note": "Only colour is independently controlled for the description — font-size/weight/line-height are honest gaps (no per-element typography attrs declared for this element)."
				},
				"connector": {
					"label": "Connector line",
					"order": 5,
					"clusters": [],
					"_note": "connectorStyle (line/none) is a structural variant selector — no colour/fill control exists for the connector on this block (unlike sgs/timeline's connectorColour). Declared for documentation only; orphan-scan-exempt (no prefix)."
				},
				"animation": {
					"label": "Scroll-reveal animation",
					"order": 6,
					"clusters": [ "animation" ],
					"attrMap": {
						"anim:preset": "sgsAnimation",
						"anim:duration": "sgsAnimationDuration",
						"anim:easing": "sgsAnimationEasing"
					},
					"_note": "Spec 35 FR-35-6 — JS scroll-driven motion, a separate mechanism from the `motion` (CSS-transition) cluster on `wrapper`. No stagger/parallax/trigger attrs exist on this block — honest gaps."
				},
				"step": {
					"label": "Process step",
					"order": 7,
					"clusters": [],
					"_note": "Per-step fields (number/title/description/icon) are plain repeater content from the `steps` array — styled block-wide via the number/title/description elements above, no independent per-step override. Mirrors sgs/accordion's `item` and sgs/timeline's `entry`."
				}
			}
		}
	},
	"selectors": {
		"root": ".sgs-process-steps",
		"typography": ".sgs-process-steps__title"
	},
	"attributes": {
		"steps": {
			"type": "array",
			"default": [
				{
					"number": "1",
					"title": "First Step",
					"description": "Description of the first step."
				},
				{
					"number": "2",
					"title": "Second Step",
					"description": "Description of the second step."
				},
				{
					"number": "3",
					"title": "Third Step",
					"description": "Description of the third step."
				}
			],
			"items": {
				"type": "object",
				"properties": {
					"icon": {
						"type": "string"
					},
					"number": {
						"type": "string"
					},
					"title": {
						"type": "string"
					},
					"description": {
						"type": "string"
					}
				}
			}
		},
		"connectorStyle": {
			"type": "string",
			"default": "line"
		},
		"numberStyle": {
			"type": "string",
			"default": "circle"
		},
		"numberColour": {
			"type": "string",
			"default": "text-inverse"
		},
		"numberBackground": {
			"type": "string",
			"default": "primary"
		},
		"titleColour": {
			"type": "string",
			"default": "text"
		},
		"descriptionColour": {
			"type": "string",
			"default": "text-muted"
		},
		"backgroundColourHover": {
			"type": "string",
			"default": ""
		},
		"textColourHover": {
			"type": "string",
			"default": ""
		},
		"borderColourHover": {
			"type": "string",
			"default": ""
		},
		"effectHover": {
			"type": "string",
			"default": "none"
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		},
		"borderWidth": {
			"type": "object",
			"default": {}
		},
		"borderStyle": {
			"type": "string",
			"enum": [
				"none",
				"solid",
				"dashed",
				"dotted",
				"double",
				"groove",
				"ridge",
				"inset",
				"outset"
			],
			"default": "none"
		},
		"borderColour": {
			"type": "string",
			"default": ""
		},
		"transitionDuration": {
			"type": "string",
			"default": "300"
		},
		"transitionEasing": {
			"type": "string",
			"default": "ease-in-out"
		},
		"sgsAnimation": {
			"type": "string",
			"default": "fade-up"
		},
		"sgsAnimationDuration": {
			"type": "string",
			"default": "medium"
		},
		"sgsAnimationEasing": {
			"type": "string",
			"default": "ease-out"
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"example": {
		"attributes": {
			"steps": [
				{
					"number": "1",
					"title": "Request a Quote",
					"description": "Fill in our online form with your requirements."
				},
				{
					"number": "2",
					"title": "We Prepare Your Order",
					"description": "Our team picks and packs your items fresh."
				},
				{
					"number": "3",
					"title": "Next-Day Delivery",
					"description": "Your order arrives the following business day."
				}
			]
		}
	}
}
