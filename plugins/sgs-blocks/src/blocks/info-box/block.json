{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/info-box",
	"version": "0.2.0",
	"title": "SGS Info Box",
	"category": "sgs-content",
	"description": "Feature or benefit card with 5 toggleable, reorderable elements: media, title, subtitle, text, and button.",
	"keywords": [
		"info",
		"feature",
		"card",
		"benefit",
		"box",
		"icon"
	],
	"textdomain": "sgs-blocks",
	"icon": "info-outline",
	"supports": {
		"align": false,
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"link": true,
			"gradients": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"letterSpacing": true,
			"textTransform": true,
			"fontWeight": true,
			"fontStyle": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"shadow": {
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"imageControls": true,
			"containerKind": "content",
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				]
			},
			"elements": {
				"box": {
					"label": "Card box",
					"order": 1,
					"clusters": [ "fill", "layout", "animation" ],
					"isWrapper": true,
					"attrMap": {
						"css:background-color": "native:color.background",
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin",
						"css:max-width": "maxWidth",
						"css:border-width": "native:__experimentalBorder.width",
						"css:border-style": "native:__experimentalBorder.style",
						"css:border-color": "native:__experimentalBorder.color",
						"css:border-radius": "native:__experimentalBorder.radius",
						"css:box-shadow": "native:shadow",
						"anim:preset": "sgsAnimation",
						"anim:duration": "sgsAnimationDuration",
						"anim:easing": "sgsAnimationEasing"
					},
					"states": {
						"hover": {
							"attrMap": {
								"css:background-color": "backgroundColourHover",
								"css:color": "textColourHover",
								"css:border-color": "borderColourHover",
								"css:box-shadow": "shadowHover"
							}
						}
					}
				},
				"content": {
					"label": "Card content",
					"order": 2,
					"clusters": [ "layout" ],
					"attrMap": {
						"css:width": "contentWidth"
					},
					"_note": "Heading/subtitle/description/button are native InnerBlocks children (HC2/D192 — parent owns LAYOUT, child owns TYPOGRAPHY), each carrying its own typography inspector, so this block declares no text cluster for them. contentWidth resolves via css:width (render.php:298 `{$root_sel}{width:{$cw_safe};}` — a real `width` declaration, distinct from the separate maxWidth/css:max-width control, Spec 35 vocabulary fix)."
				},
				"media": {
					"label": "Icon / media",
					"order": 3,
					"clusters": [],
					"_note": "Governed by the universal image-controls extension (supports.sgs.imageControls) plus mediaType/iconPosition selects — outside the Text/Fill/Layout style clusters."
				}
			}
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-info-box",
		"typography": ".sgs-info-box__heading"
	},
	"attributes": {
		"mediaType": {
			"type": "string",
			"default": "icon",
			"enum": [
				"icon",
				"emoji",
				"image"
			]
		},
		"image": {
			"type": "object"
		},
		"iconPosition": {
			"type": "string",
			"default": "top",
			"enum": [
				"top",
				"left",
				"right"
			]
		},
		"icon": {
			"type": "string",
			"default": "star-filled"
		},
		"heading": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"description": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"cardStyle": {
			"type": "string",
			"default": "elevated"
		},
		"effectHover": {
			"type": "string",
			"default": "lift"
		},
		"backgroundColourHover": {
			"type": "string",
			"default": ""
		},
		"textColourHover": {
			"type": "string",
			"default": ""
		},
		"borderColourHover": {
			"type": "string",
			"default": ""
		},
		"transitionDuration": {
			"type": "string",
			"default": "300"
		},
		"transitionEasing": {
			"type": "string",
			"default": "ease-in-out"
		},
		"scaleHover": {
			"type": "string",
			"default": ""
		},
		"shadowHover": {
			"type": "string",
			"default": ""
		},
		"blockLink": {
			"type": "string",
			"default": ""
		},
		"blockLinkTarget": {
			"type": "boolean",
			"default": false
		},
		"grayscaleHover": {
			"type": "boolean",
			"default": false
		},
		"sgsAnimation": {
			"type": "string",
			"default": "fade-up"
		},
		"sgsAnimationDuration": {
			"type": "string",
			"default": "medium"
		},
		"sgsAnimationEasing": {
			"type": "string",
			"default": "default"
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"example": {
		"attributes": {
			"icon": "star",
			"heading": "Your Compelling Headline Goes Here",
			"description": "A brief supporting statement that explains your value proposition.",
			"cardStyle": "elevated"
		}
	}
}
