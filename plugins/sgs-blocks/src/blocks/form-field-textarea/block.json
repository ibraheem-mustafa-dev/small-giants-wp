{
    "$schema":  "https://schemas.wp.org/trunk/block.json",
    "apiVersion":  3,
    "name":  "sgs/form-field-textarea",
    "version":  "0.1.0",
    "title":  "SGS Textarea Field",
    "category":  "sgs-forms",
    "description":  "A multi-line text input field.",
    "keywords":  [
                     "textarea",
                     "text",
                     "message",
                     "comment"
                 ],
    "textdomain":  "sgs-blocks",
    "icon":  "text",
    "parent":  [
                   "sgs/form",
                   "sgs/form-step"
               ],
    "usesContext":  [
                        "sgs/formId"
                    ],
    "supports":  {
                     "html":  false,
                     "anchor":  false
                 },
    "attributes":  {
                       "fieldName":  {
                                         "type":  "string",
                                         "default":  ""
                                     },
                       "label":  {
                                     "type":  "string",
                                     "default":  ""
                                 },
                       "placeholder":  {
                                           "type":  "string",
                                           "default":  ""
                                       },
                       "helpText":  {
                                        "type":  "string",
                                        "default":  ""
                                    },
                       "required":  {
                                        "type":  "boolean",
                                        "default":  false
                                    },
                       "width":  {
                                     "type":  "string",
                                     "default":  "full"
                                 },
                       "rows":  {
                                    "type":  "number",
                                    "default":  4
                                },
                       "conditionalField":  {
                                                "type":  "string",
                                                "default":  ""
                                            },
                       "conditionalOperator":  {
                                                   "type":  "string",
                                                   "default":  "equals"
                                               },
                       "conditionalValue":  {
                                                "type":  "string",
                                                "default":  ""
                                            }
                   },
    "render":  "file:./render.php",
    "editorScript":  "file:./index.js",
    "example":  {
                    "attributes":  {
                                       "label":  "Your Message",
                                       "placeholder":  "Tell us about your requirements…",
                                       "rows":  4
                                   }
                }
}
