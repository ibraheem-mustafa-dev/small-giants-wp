{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/testimonial-slider",
	"version": "0.3.4",
	"title": "SGS Testimonial Slider",
	"category": "sgs-content",
	"description": "Carousel of testimonials with CSS scroll-snap and optional autoplay.",
	"keywords": [
		"testimonial",
		"slider",
		"carousel",
		"reviews",
		"feedback"
	],
	"textdomain": "sgs-blocks",
	"icon": "slides",
	"supports": {
		"sgs": {
			"imageControls": true,
			"containerKind": "layout"
		},
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"letterSpacing": true,
			"textTransform": true,
			"fontWeight": true,
			"fontStyle": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		}
	},
	"providesContext": {
		"sgs/testimonialVariant": "cardStyle"
	},
	"selectors": {
		"root": ".wp-block-sgs-testimonial-slider",
		"typography": ".sgs-testimonial-slider__quote"
	},
	"attributes": {
		"layout": {
			"type": "string",
			"default": "full",
			"enum": [
				"full",
				"split"
			]
		},
		"sideImage": {
			"type": "object"
		},
		"testimonials": {
			"type": "array",
			"default": []
		},
		"autoplay": {
			"type": "boolean",
			"default": true
		},
		"autoplaySpeed": {
			"type": "number",
			"default": 5000
		},
		"showDots": {
			"type": "boolean",
			"default": true
		},
		"showArrows": {
			"type": "boolean",
			"default": true
		},
		"slidesVisible": {
			"type": "number",
			"default": 3
		},
		"cardStyle": {
			"type": "string",
			"default": ""
		},
		"nameFontSize": {
			"type": "string"
		},
		"backgroundColourHover": {
			"type": "string",
			"default": ""
		},
		"textColourHover": {
			"type": "string",
			"default": ""
		},
		"borderColourHover": {
			"type": "string",
			"default": ""
		},
		"effectHover": {
			"type": "string",
			"default": "none"
		},
		"transitionDuration": {
			"type": "string",
			"default": "300"
		},
		"transitionEasing": {
			"type": "string",
			"default": "ease-in-out"
		},
		"columns": {
			"type": "number",
			"default": 2
		},
		"columnsMobile": {
			"type": "number",
			"default": 1
		},
		"columnsTablet": {
			"type": "number",
			"default": 2
		},
		"gridTemplateColumns": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsMobile": {
			"type": "string",
			"default": ""
		},
		"gap": {
			"type": "string",
			"default": ""
		},
		"gapTablet": {
			"type": "string",
			"default": ""
		},
		"gapMobile": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRows": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsMobile": {
			"type": "string",
			"default": ""
		},
		"gridAutoRows": {
			"type": "string",
			"default": ""
		},
		"justifyItems": {
			"type": "string",
			"default": "stretch",
			"enum": [
				"stretch",
				"start",
				"center",
				"end"
			]
		},
		"alignContent": {
			"type": "string",
			"default": "stretch",
			"enum": [
				"stretch",
				"start",
				"center",
				"end",
				"space-between",
				"space-around",
				"space-evenly"
			]
		},
		"templateMode": {
			"type": "string",
			"default": "free",
			"enum": [
				"free",
				"grid-section",
				"card-grid"
			]
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"flexDirection": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"row",
				"column"
			]
		},
		"flexWrap": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"wrap",
				"nowrap"
			]
		},
		"justifyContent": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"flex-start",
				"center",
				"flex-end",
				"space-between",
				"space-around"
			]
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js",
	"render": "file:./render.php",
	"example": {
		"attributes": {
			"showDots": true,
			"showArrows": true,
			"cardStyle": ""
		},
		"innerBlocks": [
			{
				"name": "sgs/testimonial",
				"attributes": {
					"quote": "Exceptional service — our go-to supplier for over three years.",
					"name": "Mark Davidson",
					"role": "Catering Manager",
					"rating": 5
				}
			},
			{
				"name": "sgs/testimonial",
				"attributes": {
					"quote": "Reliable, great value, and the team are always helpful.",
					"name": "Priya Sharma",
					"role": "Restaurant Owner",
					"rating": 5
				}
			}
		]
	}
}
