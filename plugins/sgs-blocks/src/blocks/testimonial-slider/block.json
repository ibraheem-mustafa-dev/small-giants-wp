{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/testimonial-slider",
	"version": "0.3.4",
	"title": "SGS Testimonial Slider",
	"category": "sgs-content",
	"description": "Carousel of testimonials with CSS scroll-snap and optional autoplay.",
	"keywords": [
		"testimonial",
		"slider",
		"carousel",
		"reviews",
		"feedback"
	],
	"textdomain": "sgs-blocks",
	"icon": "slides",
	"supports": {
		"sgs": {
			"imageControls": true,
			"containerKind": "layout",
			"elements": {
				"slider": {
					"label": "Slider",
					"layer": "OUTER",
					"_layer_note": "Root IS the carousel wrapper — SGS_Container_Wrapper kind='layout' renders it (render.php:460-471; DB block_composition.container_kind=layout, wraps_block=sgs/container). MF-3 makes the root OUTER, mirroring card-grid/content-collection.",
					"order": 1,
					"clusters": [ "layout", "fill", "text", "motion" ],
					"isWrapper": true,
					"attrMap": {
						"css:gap": "gap",
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin",
						"css:max-width": "maxWidth",
						"css:border-width": "native:__experimentalBorder.width",
						"css:border-style": "native:__experimentalBorder.style",
						"css:border-color": "native:__experimentalBorder.color",
						"css:border-radius": "native:__experimentalBorder.radius",
						"css:background-color": "native:color.background",
						"css:color": "native:color.text",
						"css:font-size": "native:typography.fontSize",
						"css:line-height": "native:typography.lineHeight",
						"css:letter-spacing": "native:typography.letterSpacing",
						"css:text-transform": "native:typography.textTransform",
						"css:font-weight": "native:typography.fontWeight",
						"css:font-style": "native:typography.fontStyle",
						"css:text-align": "native:typography.textAlign",
						"css:grid-template-columns": "gridTemplateColumns",
						"css:grid-template-rows": "gridTemplateRows",
						"css:grid-auto-rows": "gridAutoRows",
						"css:flex-direction": "flexDirection",
						"css:flex-wrap": "flexWrap",
						"css:justify-content": "justifyContent",
						"css:justify-items": "justifyItems",
						"css:align-content": "alignContent",
						"css:transition-duration": "transitionDuration",
						"css:transition-timing-function": "transitionEasing"
					},
					"states": {
						"hover": {
							"attrMap": {
								"css:background-color": "backgroundColourHover",
								"css:color": "textColourHover",
								"css:border-color": "borderColourHover"
							}
						}
					},
					"_note": "css:align-items is an honest gap (no alignItems attr declared — only alignContent/justifyItems). `nameFontSize` (render.php:68) is a legacy top-level attribute this manifest cannot place under any element prefix — flagged here as a likely dead/orphan control, not fixed (out of scope for this rollout)."
				},
				"side-image": {
					"label": "Side image (split layout)",
					"order": 2,
					"clusters": [],
					"_note": "Governed by the universal image-controls extension (supports.sgs.imageControls) — sideImage is a MediaPicker object with no independent Text/Fill/Layout style attrs (render.php:374-389)."
				},
				"arrow": {
					"label": "Prev/next arrow",
					"order": 3,
					"clusters": [],
					"_note": "showArrows toggles visibility only (render.php:333-341) — no colour/size/style attrs exist per-arrow; styling comes from static style.css theme defaults."
				},
				"dot": {
					"label": "Navigation dot",
					"order": 4,
					"clusters": [],
					"_note": "showDots toggles visibility only (render.php:343-363) — no colour/size attrs exist per-dot."
				}
			},
			"_ownership_note": "OWNERSHIP BOUNDARY (Spec 35): each slide is rendered by iterating $block->inner_blocks and calling $inner_block->render() (render.php:286-301) — a genuine child-block render, not a scalar array. Quote text, author name, role, rating, avatar and card-style all belong ENTIRELY to the child sgs/testimonial block's own manifest and are deliberately NOT declared here — declaring them would cross the delegated-rendering ownership boundary. Only the carousel chrome this block itself emits (slider wrapper, arrows, dots, side-image) is declared above."
		},
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"letterSpacing": true,
			"textTransform": true,
			"fontWeight": true,
			"fontStyle": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true
		}
	},
	"providesContext": {
		"sgs/testimonialVariant": "cardStyle"
	},
	"selectors": {
		"root": ".wp-block-sgs-testimonial-slider",
		"typography": ".sgs-testimonial-slider__quote"
	},
	"attributes": {
		"layout": {
			"type": "string",
			"default": "full",
			"enum": [
				"full",
				"split"
			]
		},
		"sideImage": {
			"type": "object"
		},
		"testimonials": {
			"type": "array",
			"default": []
		},
		"autoplay": {
			"type": "boolean",
			"default": true
		},
		"autoplaySpeed": {
			"type": "number",
			"default": 5000
		},
		"showDots": {
			"type": "boolean",
			"default": true
		},
		"showArrows": {
			"type": "boolean",
			"default": true
		},
		"slidesVisible": {
			"type": "number",
			"default": 3
		},
		"cardStyle": {
			"type": "string",
			"default": ""
		},
		"nameFontSize": {
			"type": "string"
		},
		"backgroundColourHover": {
			"type": "string",
			"default": ""
		},
		"textColourHover": {
			"type": "string",
			"default": ""
		},
		"borderColourHover": {
			"type": "string",
			"default": ""
		},
		"effectHover": {
			"type": "string",
			"default": "none"
		},
		"transitionDuration": {
			"type": "string",
			"default": "300"
		},
		"transitionEasing": {
			"type": "string",
			"default": "ease-in-out"
		},
		"columns": {
			"type": "number",
			"default": 2
		},
		"columnsMobile": {
			"type": "number",
			"default": 1
		},
		"columnsTablet": {
			"type": "number",
			"default": 2
		},
		"gridTemplateColumns": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsMobile": {
			"type": "string",
			"default": ""
		},
		"gap": {
			"type": "string",
			"default": ""
		},
		"gapTablet": {
			"type": "string",
			"default": ""
		},
		"gapMobile": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRows": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsMobile": {
			"type": "string",
			"default": ""
		},
		"gridAutoRows": {
			"type": "string",
			"default": ""
		},
		"justifyItems": {
			"type": "string",
			"default": "stretch",
			"enum": [
				"stretch",
				"start",
				"center",
				"end"
			]
		},
		"alignContent": {
			"type": "string",
			"default": "stretch",
			"enum": [
				"stretch",
				"start",
				"center",
				"end",
				"space-between",
				"space-around",
				"space-evenly"
			]
		},
		"templateMode": {
			"type": "string",
			"default": "free",
			"enum": [
				"free",
				"grid-section",
				"card-grid"
			]
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"flexDirection": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"row",
				"column"
			]
		},
		"flexWrap": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"wrap",
				"nowrap"
			]
		},
		"justifyContent": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"flex-start",
				"center",
				"flex-end",
				"space-between",
				"space-around"
			]
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js",
	"render": "file:./render.php",
	"example": {
		"attributes": {
			"showDots": true,
			"showArrows": true,
			"cardStyle": ""
		},
		"innerBlocks": [
			{
				"name": "sgs/testimonial",
				"attributes": {
					"quote": "Exceptional service — our go-to supplier for over three years.",
					"name": "Mark Davidson",
					"role": "Catering Manager",
					"rating": 5
				}
			},
			{
				"name": "sgs/testimonial",
				"attributes": {
					"quote": "Reliable, great value, and the team are always helpful.",
					"name": "Priya Sharma",
					"role": "Restaurant Owner",
					"rating": 5
				}
			}
		]
	}
}
