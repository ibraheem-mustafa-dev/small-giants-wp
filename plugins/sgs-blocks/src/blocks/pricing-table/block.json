						},
						{
							"text": "24/7 phone support",
							"included": true
						},
						{
							"text": "Custom integrations",
							"included": true
						},
						{
							"text": "Dedicated account manager",
							"included": true
						},
						{
							"text": "SLA guarantee",
							"included": true
						}
					],
					"ctaText": "Contact sales",
					"ctaUrl": "",
					"highlighted": false,
					"iconName": "",
					"ribbonText": "",
					"ribbonColour": "accent",
					"savingsBadgeText": ""
				}
			],
			"items": {
				"type": "object",
				"properties": {
					"name": {
						"type": "string",
						"role": "text-content"
					},
					"price": {
						"type": "string"
					},
					"priceYearly": {
						"type": "string",
						"role": "text-content"
					},
					"description": {
						"type": "string",
						"role": "text-content"
					},
					"ctaText": {
						"type": "string",
						"role": "text-content"
					},
					"ctaUrl": {
						"type": "string",
						"role": "url-href"
					},
					"ribbonText": {
						"type": "string",
						"role": "text-content"
					},
					"savingsBadgeText": {
						"type": "string",
						"role": "text-content"
					},
					"iconName": {
						"type": "string",
						"role": "icon-slug"
					},
					"features": {
						"type": "string"
					},
					"highlighted": {
						"type": "string"
					},
					"period": {
						"type": "string"
					}
				}
			}
		},
		"style": {
			"type": "string",
			"default": "card"
		},
		"titleColour": {
			"type": "string",
			"default": "text"
		},
		"priceColour": {
			"type": "string",
			"default": "text"
		},
		"featureColour": {
			"type": "string",
			"default": "text"
		},
		"ctaStyle": {
			"type": "string",
			"default": "accent"
		},
		"ctaColour": {
			"type": "string"
		},
		"ctaBackground": {
			"type": "string"
		},
		"popularBadgeText": {
			"type": "string",
			"default": "Popular"
		},
		"popularBadgeColour": {
			"type": "string",
			"default": "text"
		},
		"popularBadgeBackground": {
			"type": "string",
			"default": "accent"
		},
		"sgsAnimation": {
			"type": "string",
			"default": "slide-up"
		},
		"sgsAnimationDuration": {
			"type": "string",
			"default": "medium"
		},
		"sgsAnimationEasing": {
			"type": "string",
			"default": "default"
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		},
		"layout": {
			"type": "string",
			"default": ""
		},
		"gap": {
			"type": "string",
			"default": ""
		},
		"gapTablet": {
			"type": "string",
			"default": ""
		},
		"gapMobile": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumns": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateColumnsMobile": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRows": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsTablet": {
			"type": "string",
			"default": ""
		},
		"gridTemplateRowsMobile": {
			"type": "string",
			"default": ""
		},
		"gridAutoRows": {
			"type": "string",
			"default": ""
		},
		"justifyItems": {
			"type": "string",
			"default": "stretch",
			"enum": [
				"stretch",
				"start",
				"center",
				"end"
			]
		},
		"alignContent": {
			"type": "string",
			"default": "stretch",
			"enum": [
				"stretch",
				"start",
				"center",
				"end",
				"space-between",
				"space-around",
				"space-evenly"
			]
		},
		"columnsMobile": {
			"type": "number",
			"default": 1
		},
		"columnsTablet": {
			"type": "number",
			"default": 2
		},
		"flexDirection": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"row",
				"column"
			]
		},
		"flexWrap": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"wrap",
				"nowrap"
			]
		},
		"justifyContent": {
			"type": "string",
			"default": "",
			"enum": [
				"",
				"flex-start",
				"center",
				"flex-end",
				"space-between",
				"space-around"
			]
		},
		"templateMode": {
			"type": "string",
			"default": "free",
			"enum": [
				"free",
				"grid-section",
				"card-grid"
			]
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js",
	"render": "file:./render.php",
	"example": {
		"attributes": {
			"columns": 3,
			"style": "card",
			"billingToggle": true
		}
	}
}
