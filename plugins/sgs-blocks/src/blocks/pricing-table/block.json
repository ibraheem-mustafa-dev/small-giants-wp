{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/pricing-table",
	"version": "0.2.0",
	"title": "SGS Pricing Table",
	"category": "sgs-content",
	"description": "Pricing plans displayed in responsive columns with features, CTAs, monthly/yearly toggle, and optional badges.",
	"keywords": [
		"pricing",
		"plans",
		"table",
		"price",
		"subscription",
		"tiers"
	],
	"textdomain": "sgs-blocks",
	"icon": "table-col-after",
	"supports": {
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-pricing-table",
		"typography": ".sgs-pricing-table__title"
	},
	"attributes": {
		"columns": {
			"type": "number",
			"default": 3
		},
		"billingToggle": {
			"type": "boolean",
			"default": true
		},
		"toggleStyle": {
			"type": "string",
			"default": "text",
			"enum": [ "text", "button" ]
		},
		"billingToggleMonthlyLabel": {
			"type": "string",
			"default": "Monthly"
		},
		"billingToggleYearlyLabel": {
			"type": "string",
			"default": "Yearly"
		},
		"plans": {
			"type": "array",
			"default": [
				{
					"name": "Starter",
					"price": "£9",
					"priceYearly": "£90",
					"period": "monthly",
					"description": "Everything you need to get started.",
					"features": [
						"5 projects",
						"10 GB storage",
						"Email support"
					],
					"ctaText": "Get started",
					"ctaUrl": "",
					"highlighted": false
				},
				{
					"name": "Professional",
					"price": "£29",
					"priceYearly": "£290",
					"period": "monthly",
					"description": "For growing teams who need more.",
					"features": [
						"Unlimited projects",
						"100 GB storage",
						"Priority support",
						"Advanced analytics",
						"Custom domain"
					],
					"ctaText": "Get started",
					"ctaUrl": "",
					"highlighted": true
				},
				{
					"name": "Enterprise",
					"price": "£99",
					"priceYearly": "£990",
					"period": "monthly",
					"description": "For large organisations with custom needs.",
					"features": [
						"Everything in Professional",
						"Unlimited storage",
						"24/7 phone support",
						"Custom integrations",
						"Dedicated account manager",
						"SLA guarantee"
					],
					"ctaText": "Contact sales",
					"ctaUrl": "",
					"highlighted": false
				}
			]
		},
		"style": {
			"type": "string",
			"default": "card"
		},
		"titleColour": {
			"type": "string"
		},
		"priceColour": {
			"type": "string"
		},
		"featureColour": {
			"type": "string"
		},
		"ctaStyle": {
			"type": "string",
			"default": "accent"
		},
		"ctaColour": {
			"type": "string"
		},
		"ctaBackground": {
			"type": "string"
		},
		"popularBadgeText": {
			"type": "string",
			"default": "Popular"
		},
		"popularBadgeColour": {
			"type": "string",
			"default": "white"
		},
		"popularBadgeBackground": {
			"type": "string",
			"default": "accent"
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js",
	"render": "file:./render.php",
	"example": {
		"attributes": {
			"columns": 3,
			"style": "card",
			"billingToggle": true
		}
	}
}
