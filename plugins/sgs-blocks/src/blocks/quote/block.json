{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/quote",
	"version": "0.3.0",
	"title": "Quote",
	"category": "sgs-content",
	"description": "Attributed blockquote — body paragraphs are native InnerBlocks children (mirrors core/quote) and attribution is an optional footer/cite/div string. Emits semantic <blockquote> so converter-pipeline outputs preserve the correct HTML5 structure.",
	"keywords": [
		"quote",
		"blockquote",
		"attribution",
		"pullquote",
		"testimonial"
	],
	"textdomain": "sgs-blocks",
	"icon": "format-quote",
	"render": "file:./render.php",
	"supports": {
		"sgs": {
			"scalarStylingLift": true
		},
		"anchor": true,
		"className": true,
		"html": false,
		"color": {
			"background": true,
			"gradients": true,
			"text": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true
		}
	},
	"attributes": {
		"attribution": {
			"type": "string",
			"default": ""
		},
		"attributionTag": {
			"type": "string",
			"enum": [
				"footer",
				"div",
				"cite"
			],
			"default": "footer"
		},
		"attributionEnabled": {
			"type": "boolean",
			"default": true
		},
		"attributionColour": {
			"type": "string",
			"default": ""
		},
		"attributionFontSize": {
			"type": "number"
		},
		"attributionFontSizeTablet": {
			"type": "number"
		},
		"attributionFontSizeMobile": {
			"type": "number"
		},
		"attributionFontSizeUnit": {
			"type": "string",
			"default": "px"
		},
		"attributionFontWeight": {
			"type": "string",
			"default": ""
		},
		"attributionFontFamily": {
			"type": "string",
			"default": ""
		},
		"attributionFontStyle": {
			"type": "string",
			"enum": [
				"",
				"normal",
				"italic"
			],
			"default": ""
		},
		"attributionTextDecoration": {
			"type": "string",
			"enum": [
				"",
				"none",
				"underline",
				"line-through"
			],
			"default": ""
		},
		"attributionTextTransform": {
			"type": "string",
			"enum": [
				"",
				"none",
				"uppercase",
				"lowercase",
				"capitalize"
			],
			"default": ""
		},
		"attributionLineHeight": {
			"type": "number"
		},
		"attributionLineHeightUnit": {
			"type": "string",
			"default": "em"
		},
		"attributionMarginTop": {
			"type": "number"
		},
		"attributionMarginTopTablet": {
			"type": "number"
		},
		"attributionMarginTopMobile": {
			"type": "number"
		},
		"attributionMarginUnit": {
			"type": "string",
			"default": "px"
		},
		"backgroundColour": {
			"type": "string",
			"default": ""
		},
		"borderRadius": {
			"type": "string",
			"default": ""
		},
		"borderRadiusUnit": {
			"type": "string",
			"default": "px"
		},
		"borderRadiusTL": {
			"type": "string",
			"default": ""
		},
		"borderRadiusTR": {
			"type": "string",
			"default": ""
		},
		"borderRadiusBL": {
			"type": "string",
			"default": ""
		},
		"borderRadiusBR": {
			"type": "string",
			"default": ""
		},
		"borderWidthTop": {
			"type": "string",
			"default": ""
		},
		"borderWidthRight": {
			"type": "string",
			"default": ""
		},
		"borderWidthBottom": {
			"type": "string",
			"default": ""
		},
		"borderWidthLeft": {
			"type": "string",
			"default": ""
		},
		"borderWidthUnit": {
			"type": "string",
			"default": "px"
		},
		"borderStyle": {
			"type": "string",
			"enum": [
				"none",
				"solid",
				"dashed",
				"dotted",
				"double",
				"groove",
				"ridge",
				"inset",
				"outset"
			],
			"default": "none"
		},
		"borderColour": {
			"type": "string",
			"default": ""
		},
		"boxShadow": {
			"type": "string",
			"default": ""
		},
		"boxShadowHover": {
			"type": "string",
			"default": ""
		},
		"hoverScale": {
			"type": "number",
			"default": null
		},
		"hoverColour": {
			"type": "string",
			"default": ""
		},
		"hoverBackground": {
			"type": "string",
			"default": ""
		},
		"marginTop": {
			"type": "string",
			"default": ""
		},
		"marginRight": {
			"type": "string",
			"default": ""
		},
		"marginBottom": {
			"type": "string",
			"default": ""
		},
		"marginLeft": {
			"type": "string",
			"default": ""
		},
		"marginUnit": {
			"type": "string",
			"default": "px"
		},
		"marginTopTablet": {
			"type": "string",
			"default": ""
		},
		"marginRightTablet": {
			"type": "string",
			"default": ""
		},
		"marginBottomTablet": {
			"type": "string",
			"default": ""
		},
		"marginLeftTablet": {
			"type": "string",
			"default": ""
		},
		"marginTopMobile": {
			"type": "string",
			"default": ""
		},
		"marginRightMobile": {
			"type": "string",
			"default": ""
		},
		"marginBottomMobile": {
			"type": "string",
			"default": ""
		},
		"marginLeftMobile": {
			"type": "string",
			"default": ""
		},
		"paddingTop": {
			"type": "string",
			"default": ""
		},
		"paddingRight": {
			"type": "string",
			"default": ""
		},
		"paddingBottom": {
			"type": "string",
			"default": ""
		},
		"paddingLeft": {
			"type": "string",
			"default": ""
		},
		"paddingUnit": {
			"type": "string",
			"default": "px"
		},
		"paddingTopTablet": {
			"type": "string",
			"default": ""
		},
		"paddingRightTablet": {
			"type": "string",
			"default": ""
		},
		"paddingBottomTablet": {
			"type": "string",
			"default": ""
		},
		"paddingLeftTablet": {
			"type": "string",
			"default": ""
		},
		"paddingTopMobile": {
			"type": "string",
			"default": ""
		},
		"paddingRightMobile": {
			"type": "string",
			"default": ""
		},
		"paddingBottomMobile": {
			"type": "string",
			"default": ""
		},
		"paddingLeftMobile": {
			"type": "string",
			"default": ""
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		},
		"maxWidthTablet": {
			"type": "string",
			"default": ""
		},
		"maxWidthMobile": {
			"type": "string",
			"default": ""
		},
		"inheritStyle": {
			"type": "boolean",
			"default": false
		},
		"transitionDuration": {
			"type": "string",
			"default": "300"
		},
		"transitionEasing": {
			"type": "string",
			"default": "ease-in-out"
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"example": {
		"attributes": {
			"attribution": "\u00e2\u20ac\u201d Jane Smith, Customer",
			"attributionColour": "primary",
			"paddingTop": 24,
			"paddingRight": 24,
			"paddingBottom": 24,
			"paddingLeft": 24
		},
		"innerBlocks": [
			{
				"name": "sgs/text",
				"attributes": {
					"text": "A great quotation block lets your content speak for itself."
				}
			},
			{
				"name": "sgs/text",
				"attributes": {
					"text": "Place the source's words here for emphasis and credibility."
				}
			}
		]
	}
}
