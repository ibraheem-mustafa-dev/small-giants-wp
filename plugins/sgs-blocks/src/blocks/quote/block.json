{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/quote",
	"version": "0.3.0",
	"title": "Quote",
	"category": "sgs-content",
	"description": "Attributed blockquote — body paragraphs are native InnerBlocks children (mirrors core/quote) and attribution is an optional footer/cite/div string. Emits semantic <blockquote> so converter-pipeline outputs preserve the correct HTML5 structure.",
	"keywords": [
		"quote",
		"blockquote",
		"attribution",
		"pullquote",
		"testimonial"
	],
	"textdomain": "sgs-blocks",
	"icon": "format-quote",
	"render": "file:./render.php",
	"supports": {
		"sgs": {
			"scalarStylingLift": true,
			"elements": {
				"box": {
					"label": "Quote box",
					"order": 1,
					"clusters": [ "fill", "layout" ],
					"isWrapper": true,
					"attrMap": {
						"css:background-color": "backgroundColour",
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin",
						"css:max-width": "maxWidth",
						"css:border-width": "borderWidth",
						"css:border-style": "borderStyle",
						"css:border-color": "borderColour",
						"css:border-radius": "native:__experimentalBorder.radius",
						"css:box-shadow": "boxShadow"
					}
				},
				"quote-body": {
					"label": "Quote text",
					"order": 2,
					"clusters": [],
					"_note": "Body paragraphs are native InnerBlocks children (mirrors core/quote) — each child carries its own typography inspector, so this block declares no text cluster for them. The root's native typography.fontSize/lineHeight are wrapper-level inherited defaults, not a per-element control set."
				},
				"attribution": {
					"label": "Attribution",
					"order": 3,
					"clusters": [ "text", "layout" ],
					"prefix": "attribution",
					"attrMap": {
						"css:color": "attributionColour",
						"css:margin-top": "attributionMarginTop"
					},
					"_note": "attributionMarginTop/attributionMarginTopTablet/attributionMarginTopMobile (render.php:290-313, `'css' => 'margin-top'`) resolve via the new css:margin-top layout member (Spec 35 vocabulary fix). attributionMarginUnit is a companion unit-selector for the margin-top value (not an independent CSS property) — left unmapped; its literal name does not reduce to the attributionMarginTop base under the checker's Unit-suffix-stripping convention, a naming-shape mismatch outside this fix's scope."
				}
			},
			"boxFamilies": {
				"borderWidth": [
					"borderWidth"
				],
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				]
			}
		},
		"anchor": true,
		"className": true,
		"html": false,
		"color": {
			"background": true,
			"gradients": true,
			"text": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"__experimentalSkipSerialization": true
		}
	},
	"attributes": {
		"attribution": {
			"type": "string",
			"default": ""
		},
		"attributionTag": {
			"type": "string",
			"enum": [
				"footer",
				"div",
				"cite"
			],
			"default": "footer"
		},
		"attributionEnabled": {
			"type": "boolean",
			"default": true
		},
		"attributionColour": {
			"type": "string",
			"default": ""
		},
		"attributionFontSize": {
			"type": "number"
		},
		"attributionFontSizeTablet": {
			"type": "number"
		},
		"attributionFontSizeMobile": {
			"type": "number"
		},
		"attributionFontSizeUnit": {
			"type": "string",
			"default": "px"
		},
		"attributionFontWeight": {
			"type": "string",
			"default": ""
		},
		"attributionFontFamily": {
			"type": "string",
			"default": ""
		},
		"attributionFontStyle": {
			"type": "string",
			"enum": [
				"",
				"normal",
				"italic"
			],
			"default": ""
		},
		"attributionTextDecoration": {
			"type": "string",
			"enum": [
				"",
				"none",
				"underline",
				"line-through"
			],
			"default": ""
		},
		"attributionTextTransform": {
			"type": "string",
			"enum": [
				"",
				"none",
				"uppercase",
				"lowercase",
				"capitalize"
			],
			"default": ""
		},
		"attributionLineHeight": {
			"type": "number"
		},
		"attributionLineHeightUnit": {
			"type": "string",
			"default": "em"
		},
		"attributionMarginTop": {
			"type": "number"
		},
		"attributionMarginTopTablet": {
			"type": "number"
		},
		"attributionMarginTopMobile": {
			"type": "number"
		},
		"attributionMarginUnit": {
			"type": "string",
			"default": "px"
		},
		"backgroundColour": {
			"type": "string",
			"default": ""
		},
		"borderWidth": {
			"type": "object",
			"default": {}
		},
		"borderStyle": {
			"type": "string",
			"enum": [
				"none",
				"solid",
				"dashed",
				"dotted",
				"double",
				"groove",
				"ridge",
				"inset",
				"outset"
			],
			"default": "none"
		},
		"borderColour": {
			"type": "string",
			"default": ""
		},
		"boxShadow": {
			"type": "string",
			"default": ""
		},
		"boxShadowHover": {
			"type": "string",
			"default": ""
		},
		"scaleHover": {
			"type": "number",
			"default": null
		},
		"textColourHover": {
			"type": "string",
			"default": ""
		},
		"backgroundColourHover": {
			"type": "string",
			"default": ""
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		},
		"contentWidth": {
			"type": "string",
			"default": ""
		},
		"maxWidth": {
			"type": "string",
			"default": ""
		},
		"maxWidthTablet": {
			"type": "string",
			"default": ""
		},
		"maxWidthMobile": {
			"type": "string",
			"default": ""
		},
		"inheritStyle": {
			"type": "boolean",
			"default": false
		},
		"transitionDuration": {
			"type": "string",
			"default": "300"
		},
		"transitionEasing": {
			"type": "string",
			"default": "ease-in-out"
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"example": {
		"attributes": {
			"attribution": "â€” Jane Smith, Customer",
			"attributionColour": "primary",
			"style": {
				"spacing": {
					"padding": {
						"top": "24px",
						"right": "24px",
						"bottom": "24px",
						"left": "24px"
					}
				}
			}
		},
		"innerBlocks": [
			{
				"name": "sgs/text",
				"attributes": {
					"text": "A great quotation block lets your content speak for itself."
				}
			},
			{
				"name": "sgs/text",
				"attributes": {
					"text": "Place the source's words here for emphasis and credibility."
				}
			}
		]
	}
}
