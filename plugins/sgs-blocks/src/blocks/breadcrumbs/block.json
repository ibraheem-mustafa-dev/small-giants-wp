{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/breadcrumbs",
	"version": "0.1.0",
	"title": "SGS Breadcrumbs",
	"category": "sgs-content",
	"description": "Auto-generated breadcrumb navigation from page hierarchy.",
	"keywords": [
		"breadcrumbs",
		"navigation",
		"path",
		"hierarchy"
	],
	"textdomain": "sgs-blocks",
	"icon": "admin-links",
	"supports": {
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"link": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				]
			},
			"elements": {
				"wrapper": {
					"label": "Breadcrumb bar",
					"order": 1,
					"clusters": [ "fill", "layout" ],
					"isWrapper": true,
					"attrMap": {
						"css:background-color": "native:color.background",
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin"
					},
					"_note": "No selectors.typography is declared (only selectors.root), so the block-level typography.fontSize serialises as an inherited default across link/separator/current rather than a per-crumb control — no text cluster claimed here for size."
				},
				"link": {
					"label": "Crumb link",
					"order": 2,
					"clusters": [ "text" ],
					"prefix": "link"
				},
				"separator": {
					"label": "Separator",
					"order": 3,
					"clusters": [ "text" ],
					"prefix": "separator"
				},
				"current": {
					"label": "Current page",
					"order": 4,
					"clusters": [ "text" ],
					"prefix": "current"
				}
			}
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-breadcrumbs"
	},
	"attributes": {
		"separator": {
			"type": "string",
			"default": "/"
		},
		"showHome": {
			"type": "boolean",
			"default": true
		},
		"homeLabel": {
			"type": "string",
			"default": "Home"
		},
		"linkColour": {
			"type": "string",
			"default": "text-muted"
		},
		"separatorColour": {
			"type": "string",
			"default": "text-muted"
		},
		"currentColour": {
			"type": "string",
			"default": "text"
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"example": {
		"attributes": {
			"separator": "/",
			"showHome": true,
			"homeLabel": "Home"
		}
	}
}
