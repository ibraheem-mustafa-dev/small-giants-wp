{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/breadcrumbs",
	"version": "0.1.0",
	"title": "SGS Breadcrumbs",
	"category": "sgs-content",
	"description": "Auto-generated breadcrumb navigation from page hierarchy.",
	"keywords": [
		"breadcrumbs",
		"navigation",
		"path",
		"hierarchy"
	],
	"textdomain": "sgs-blocks",
	"icon": "admin-links",
	"supports": {
		"align": [
			"wide",
			"full"
		],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"link": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				]
			}
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-breadcrumbs"
	},
	"attributes": {
		"separator": {
			"type": "string",
			"default": "/"
		},
		"showHome": {
			"type": "boolean",
			"default": true
		},
		"homeLabel": {
			"type": "string",
			"default": "Home"
		},
		"linkColour": {
			"type": "string",
			"default": "text-muted"
		},
		"separatorColour": {
			"type": "string",
			"default": "text-muted"
		},
		"currentColour": {
			"type": "string",
			"default": "text"
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"example": {
		"attributes": {
			"separator": "/",
			"showHome": true,
			"homeLabel": "Home"
		}
	}
}
