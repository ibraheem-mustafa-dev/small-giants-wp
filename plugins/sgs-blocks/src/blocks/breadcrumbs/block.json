{
    "$schema":  "https://schemas.wp.org/trunk/block.json",
    "apiVersion":  3,
    "name":  "sgs/breadcrumbs",
    "version":  "0.1.0",
    "title":  "SGS Breadcrumbs",
    "category":  "sgs-content",
    "description":  "Auto-generated breadcrumb navigation from page hierarchy.",
    "keywords":  [
                     "breadcrumbs",
                     "navigation",
                     "path",
                     "hierarchy"
                 ],
    "textdomain":  "sgs-blocks",
    "icon":  "admin-links",
    "supports":  {
                     "align":  [
                                   "wide",
                                   "full"
                               ],
                     "anchor":  true,
                     "html":  false,
                     "color":  {
                                   "background":  true,
                                   "text":  true,
                                   "link":  true
                               },
                     "typography":  {
                                        "fontSize":  true
                                    },
                     "spacing":  {
                                     "margin":  true,
                                     "padding":  true
                                 }
                 },
    "attributes":  {
                       "separator":  {
                                         "type":  "string",
                                         "default":  "/"
                                     },
                       "showHome":  {
                                        "type":  "boolean",
                                        "default":  true
                                    },
                       "homeLabel":  {
                                         "type":  "string",
                                         "default":  "Home"
                                     }
                   },
    "editorScript":  "file:./index.js",
    "editorStyle":  "file:./index.css",
    "style":  "file:./style-index.css",
    "render":  "file:./render.php",
    "example":  {
                    "attributes":  {
                                       "separator":  "/",
                                       "showHome":  true,
                                       "homeLabel":  "Home"
                                   }
                }
}