{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/business-info",
	"version": "0.1.0",
	"title": "Business Info",
	"category": "sgs-content",
	"description": "Display business details from Settings > Business Details.",
	"keywords": [
		"business",
		"contact",
		"phone",
		"email",
		"address",
		"hours",
		"social",
		"copyright"
	],
	"textdomain": "sgs-blocks",
	"icon": "building",
	"attributes": {
		"displayType": {
			"type": "string",
			"default": "phone",
			"enum": [
				"phone",
				"email",
				"address",
				"hours",
				"socials",
				"copyright",
				"description",
				"map"
			]
		},
		"showIcon": {
			"type": "boolean",
			"default": true
		},
		"linkPhone": {
			"type": "boolean",
			"default": true
		},
		"linkEmail": {
			"type": "boolean",
			"default": true
		},
		"iconColour": {
			"type": "string",
			"default": "primary"
		},
		"textColour": {
			"type": "string",
			"default": "text"
		},
		"labelColour": {
			"type": "string",
			"default": "text-muted"
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		}
	},
	"supports": {
		"html": false,
		"anchor": true,
		"color": {
			"text": true,
			"background": true,
			"link": true,
			"__experimentalSkipSerialization": true
		},
		"typography": {
			"fontSize": true,
			"fontFamily": true,
			"__experimentalSkipSerialization": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"boxFamilies": {
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				]
			}
		}
	},
	"selectors": {
		"root": ".wp-block-sgs-business-info"
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
