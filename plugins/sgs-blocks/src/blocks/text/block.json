{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "sgs/text",
	"version": "0.1.1",
	"title": "Text",
	"category": "sgs-content",
	"description": "Single-element body text block. Renders a <p> with full SGS typography, spacing, colour, border, shadow, and hover controls.",
	"keywords": [
		"text",
		"paragraph",
		"body",
		"copy"
	],
	"textdomain": "sgs-blocks",
	"icon": "editor-paragraph",
	"render": "file:./render.php",
	"supports": {
		"anchor": true,
		"className": true,
		"html": false,
		"color": false,
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalSkipSerialization": true
		},
		"__experimentalBorder": {
			"radius": true,
			"__experimentalSkipSerialization": true
		},
		"sgs": {
			"boxFamilies": {
				"borderWidth": [
					"borderWidth"
				],
				"padding": [
					"paddingTablet",
					"paddingMobile"
				],
				"margin": [
					"marginTablet",
					"marginMobile"
				]
			},
			"elements": {
				"text": {
					"label": "Text",
					"order": 1,
					"clusters": [ "text", "fill", "layout", "motion" ],
					"isWrapper": true,
					"attrMap": {
						"css:font-size": "fontSize",
						"css:font-weight": "fontWeight",
						"css:line-height": "lineHeight",
						"css:letter-spacing": "letterSpacing",
						"css:font-style": "fontStyle",
						"css:text-transform": "textTransform",
						"css:text-decoration": "textDecoration",
						"css:color": "textColour",
						"css:text-align": "textAlign",
						"css:font-family": "fontFamily",
						"css:background-color": "backgroundColour",
						"css:padding": "native:spacing.padding",
						"css:margin": "native:spacing.margin",
						"css:border-width": "borderWidth",
						"css:border-style": "borderStyle",
						"css:border-color": "borderColour",
						"css:border-radius": "native:__experimentalBorder.radius",
						"css:box-shadow": "boxShadow",
						"css:width": "customWidth",
						"css:max-width": "maxWidth",
						"css:transition-duration": "transitionDuration",
						"css:transition-timing-function": "transitionEasing"
					},
					"states": {
						"hover": {
							"attrMap": {
								"css:color": "textColourHover",
								"css:background-color": "backgroundColourHover",
								"css:box-shadow": "boxShadowHover"
							}
						}
					},
					"_note": "Single-semantic-element block — the <p> root IS the wrapper. `color` support is `false` in this block's supports (no native color path), so css:color/background-color map to the SGS custom textColour/backgroundColour attrs directly, not native:. No `layer` — no children to arrange. scaleHover has no Spec 35 vocabulary member and is left unclaimed."
				},
				"first-letter": {
					"label": "Drop cap (first letter)",
					"order": 2,
					"clusters": [ "text" ],
					"attrMap": {
						"css:font-size": "firstLetterFontSize",
						"css:font-weight": "firstLetterFontWeight",
						"css:color": "firstLetterColour"
					},
					"_note": "Opt-in via the `dropCap` boolean (render.php:463-480) — emits a scoped `::first-letter` pseudo-element rule, a genuinely distinct visual element from the body text. line-height/letter-spacing/font-style/text-transform/text-decoration/text-align/font-family have no first-letter-specific attribute — honest gaps, the drop-cap render hardcodes float:left/line-height:0.8/margins rather than exposing them as controls."
				}
			}
		}
	},
	"attributes": {
		"text": {
			"type": "string",
			"default": "",
			"role": "content"
		},
		"textColour": {
			"type": "string",
			"default": ""
		},
		"fontSize": {
			"type": [ "number", "string" ]
		},
		"fontSizeUnit": {
			"type": "string",
			"default": "px"
		},
		"fontSizeTablet": {
			"type": "number"
		},
		"fontSizeMobile": {
			"type": "number"
		},
		"fontWeight": {
			"type": "string",
			"default": ""
		},
		"lineHeight": {
			"type": "number"
		},
		"lineHeightUnit": {
			"type": "string",
			"default": "em"
		},
		"lineHeightTablet": {
			"type": "number"
		},
		"lineHeightMobile": {
			"type": "number"
		},
		"letterSpacing": {
			"type": "number"
		},
		"letterSpacingUnit": {
			"type": "string",
			"default": "em"
		},
		"letterSpacingTablet": {
			"type": "string",
			"default": ""
		},
		"letterSpacingMobile": {
			"type": "string",
			"default": ""
		},
		"fontStyle": {
			"type": "string",
			"enum": [
				"",
				"normal",
				"italic"
			],
			"default": ""
		},
		"textDecoration": {
			"type": "string",
			"enum": [
				"",
				"none",
				"underline",
				"line-through"
			],
			"default": ""
		},
		"textTransform": {
			"type": "string",
			"enum": [
				"",
				"none",
				"uppercase",
				"lowercase",
				"capitalize"
			],
			"default": ""
		},
		"fontFamily": {
			"type": "string",
			"default": ""
		},
		"marginTablet": {
			"type": "object",
			"default": {}
		},
		"marginMobile": {
			"type": "object",
			"default": {}
		},
		"paddingTablet": {
			"type": "object",
			"default": {}
		},
		"paddingMobile": {
			"type": "object",
			"default": {}
		},
		"textAlign": {
			"type": "string",
			"enum": [
				"",
				"left",
				"center",
				"right",
				"justify"
			],
			"default": ""
		},
		"maxWidth": {
			"type": "number"
		},
		"maxWidthUnit": {
			"type": "string",
			"default": "px"
		},
		"dropCap": {
			"type": "boolean",
			"default": false
		},
		"firstLetterColour": {
			"type": "string",
			"default": ""
		},
		"firstLetterFontSize": {
			"type": "number"
		},
		"firstLetterFontSizeUnit": {
			"type": "string",
			"default": "em"
		},
		"firstLetterFontWeight": {
			"type": "string",
			"default": ""
		},
		"backgroundColour": {
			"type": "string",
			"default": ""
		},
		"borderWidth": {
			"type": "object",
			"default": {}
		},
		"borderStyle": {
			"type": "string",
			"enum": [
				"none",
				"solid",
				"dashed",
				"dotted",
				"double",
				"groove",
				"ridge",
				"inset",
				"outset"
			],
			"default": "none"
		},
		"borderColour": {
			"type": "string",
			"default": ""
		},
		"boxShadow": {
			"type": "string",
			"default": ""
		},
		"boxShadowHover": {
			"type": "string",
			"default": ""
		},
		"scaleHover": {
			"type": "number"
		},
		"textColourHover": {
			"type": "string",
			"default": ""
		},
		"backgroundColourHover": {
			"type": "string",
			"default": ""
		},
		"customWidth": {
			"type": "string",
			"default": ""
		},
		"customWidthUnit": {
			"type": "string",
			"default": "px"
		},
		"inheritStyle": {
			"type": "boolean",
			"default": false
		},
		"transitionDuration": {
			"type": "number",
			"default": 300
		},
		"transitionEasing": {
			"type": "string",
			"enum": [
				"ease",
				"ease-in",
				"ease-out",
				"ease-in-out",
				"linear"
			],
			"default": "ease"
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"example": {
		"attributes": {
			"text": "This is a sample paragraph demonstrating the SGS Text block with full typography controls.",
			"fontSize": 16,
			"textColour": "text"
		}
	}
}
