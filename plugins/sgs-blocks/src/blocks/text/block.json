{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "sgs/text",
    "version": "0.1.0",
    "title": "Text",
    "category": "sgs-content",
    "description": "Single-element body text block. Emits one configurable HTML tag with full SGS typography, spacing, colour, border, shadow, and hover controls. Replaces core/paragraph in the converter pipeline so inline-style attributes reach the rendered DOM.",
    "keywords": [
        "text",
        "paragraph",
        "body",
        "copy"
    ],
    "textdomain": "sgs-blocks",
    "icon": "editor-paragraph",
    "render": "file:./render.php",
    "supports": {
        "anchor": true,
        "className": true,
        "html": false,
        "color": false
    },
    "attributes": {
        "text": {
            "type": "string",
            "default": "",
            "role": "content"
        },
        "tag": {
            "type": "string",
            "enum": [
                "p",
                "span",
                "div",
                "blockquote",
                "em",
                "strong"
            ],
            "default": "p"
        },
        "textColour": {
            "type": "string",
            "default": ""
        },
        "fontSize": {
            "type": "number"
        },
        "fontSizeUnit": {
            "type": "string",
            "default": "px"
        },
        "fontSizeTablet": {
            "type": "number"
        },
        "fontSizeMobile": {
            "type": "number"
        },
        "fontWeight": {
            "type": "string",
            "default": ""
        },
        "lineHeight": {
            "type": "number"
        },
        "lineHeightUnit": {
            "type": "string",
            "default": "em"
        },
        "lineHeightTablet": {
            "type": "number"
        },
        "lineHeightMobile": {
            "type": "number"
        },
        "letterSpacing": {
            "type": "number"
        },
        "letterSpacingUnit": {
            "type": "string",
            "default": "em"
        },
        "letterSpacingTablet": {
            "type": "string",
            "default": ""
        },
        "letterSpacingMobile": {
            "type": "string",
            "default": ""
        },
        "fontStyle": {
            "type": "string",
            "enum": [
                "",
                "normal",
                "italic"
            ],
            "default": ""
        },
        "textDecoration": {
            "type": "string",
            "enum": [
                "",
                "none",
                "underline",
                "line-through"
            ],
            "default": ""
        },
        "textTransform": {
            "type": "string",
            "enum": [
                "",
                "none",
                "uppercase",
                "lowercase",
                "capitalize"
            ],
            "default": ""
        },
        "fontFamily": {
            "type": "string",
            "default": ""
        },
        "marginTop": {
            "type": "number"
        },
        "marginRight": {
            "type": "number"
        },
        "marginBottom": {
            "type": "number"
        },
        "marginLeft": {
            "type": "number"
        },
        "marginUnit": {
            "type": "string",
            "default": "px"
        },
        "marginTopTablet": {
            "type": "number"
        },
        "marginRightTablet": {
            "type": "number"
        },
        "marginBottomTablet": {
            "type": "number"
        },
        "marginLeftTablet": {
            "type": "number"
        },
        "marginTopMobile": {
            "type": "number"
        },
        "marginRightMobile": {
            "type": "number"
        },
        "marginBottomMobile": {
            "type": "number"
        },
        "marginLeftMobile": {
            "type": "number"
        },
        "paddingTop": {
            "type": "number"
        },
        "paddingRight": {
            "type": "number"
        },
        "paddingBottom": {
            "type": "number"
        },
        "paddingLeft": {
            "type": "number"
        },
        "paddingUnit": {
            "type": "string",
            "default": "px"
        },
        "paddingTopTablet": {
            "type": "number"
        },
        "paddingRightTablet": {
            "type": "number"
        },
        "paddingBottomTablet": {
            "type": "number"
        },
        "paddingLeftTablet": {
            "type": "number"
        },
        "paddingTopMobile": {
            "type": "number"
        },
        "paddingRightMobile": {
            "type": "number"
        },
        "paddingBottomMobile": {
            "type": "number"
        },
        "paddingLeftMobile": {
            "type": "number"
        },
        "textAlign": {
            "type": "string",
            "enum": [
                "",
                "left",
                "center",
                "right",
                "justify"
            ],
            "default": ""
        },
        "maxWidth": {
            "type": "number"
        },
        "maxWidthUnit": {
            "type": "string",
            "default": "px"
        },
        "dropCap": {
            "type": "boolean",
            "default": false
        },
        "firstLetterColour": {
            "type": "string",
            "default": ""
        },
        "firstLetterFontSize": {
            "type": "number"
        },
        "firstLetterFontSizeUnit": {
            "type": "string",
            "default": "em"
        },
        "firstLetterFontWeight": {
            "type": "string",
            "default": ""
        },
        "backgroundColour": {
            "type": "string",
            "default": ""
        },
        "borderRadius": {
            "type": "string",
            "default": ""
        },
        "borderRadiusUnit": {
            "type": "string",
            "default": "px"
        },
        "borderRadiusTL": {
            "type": "string",
            "default": ""
        },
        "borderRadiusTR": {
            "type": "string",
            "default": ""
        },
        "borderRadiusBL": {
            "type": "string",
            "default": ""
        },
        "borderRadiusBR": {
            "type": "string",
            "default": ""
        },
        "borderWidthTop": {
            "type": "string",
            "default": ""
        },
        "borderWidthRight": {
            "type": "string",
            "default": ""
        },
        "borderWidthBottom": {
            "type": "string",
            "default": ""
        },
        "borderWidthLeft": {
            "type": "string",
            "default": ""
        },
        "borderWidthUnit": {
            "type": "string",
            "default": "px"
        },
        "borderStyle": {
            "type": "string",
            "enum": [
                "none",
                "solid",
                "dashed",
                "dotted",
                "double",
                "groove",
                "ridge",
                "inset",
                "outset"
            ],
            "default": "none"
        },
        "borderColour": {
            "type": "string",
            "default": ""
        },
        "boxShadow": {
            "type": "string",
            "default": ""
        },
        "boxShadowHover": {
            "type": "string",
            "default": ""
        },
        "hoverScale": {
            "type": "number"
        },
        "hoverColour": {
            "type": "string",
            "default": ""
        },
        "hoverBackground": {
            "type": "string",
            "default": ""
        },
        "variantStyle": {
            "type": "string",
            "enum": [
                "default",
                "quote",
                "caption",
                "lead"
            ],
            "default": "default"
        },
        "customWidth": {
            "type": "string",
            "default": ""
        },
        "customWidthUnit": {
            "type": "string",
            "default": "px"
        },
        "inheritStyle": {
            "type": "boolean",
            "default": false
        },
        "transitionDuration": {
            "type": "number",
            "default": 300
        },
        "transitionEasing": {
            "type": "string",
            "enum": [
                "ease",
                "ease-in",
                "ease-out",
                "ease-in-out",
                "linear"
            ],
            "default": "ease"
        }
    },
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": "file:./style-index.css",
    "example": {
        "attributes": {
            "text": "This is a sample paragraph demonstrating the SGS Text block with full typography controls.",
            "fontSize": 16,
            "textColour": "text"
        }
    }
}
