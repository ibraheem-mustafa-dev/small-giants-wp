{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "sgs/form-field-number",
    "version": "0.1.0",
    "title": "SGS Number Field",
    "category": "sgs-forms",
    "description": "A number input field with min/max/step controls.",
    "keywords": [
        "number",
        "integer",
        "quantity",
        "field"
    ],
    "textdomain": "sgs-blocks",
    "icon": "calculator",
    "parent": [
        "sgs/form",
        "sgs/form-step"
    ],
    "usesContext": [
        "sgs/formId"
    ],
    "supports": {
        "html": false,
        "anchor": false,
        "spacing": {
            "margin": true,
            "padding": true
        },
        "color": {
            "text": true,
            "background": true
        }
    },
    "attributes": {
        "fieldName": {
            "type": "string",
            "default": ""
        },
        "label": {
            "type": "string",
            "default": ""
        },
        "placeholder": {
            "type": "string",
            "default": ""
        },
        "helpText": {
            "type": "string",
            "default": ""
        },
        "required": {
            "type": "boolean",
            "default": false
        },
        "width": {
            "type": "string",
            "default": "full"
        },
        "min": {
            "type": "string",
            "default": ""
        },
        "max": {
            "type": "string",
            "default": ""
        },
        "step": {
            "type": "string",
            "default": "1"
        },
        "conditionalField": {
            "type": "string",
            "default": ""
        },
        "conditionalOperator": {
            "type": "string",
            "default": "equals"
        },
        "conditionalValue": {
            "type": "string",
            "default": ""
        },
        "minLength": {
            "type": "number",
            "default": 0
        },
        "maxLength": {
            "type": "number",
            "default": 0
        },
        "pattern": {
            "type": "string",
            "default": ""
        },
        "customError": {
            "type": "string",
            "default": ""
        }
    },
    "render": "file:./render.php",
    "editorScript": "file:./index.js",
    "example": {
        "attributes": {
            "label": "Order Quantity (cases)",
            "min": 1,
            "max": 1000
        }
    }
}