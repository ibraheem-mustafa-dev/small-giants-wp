{
    "name": "small-giants/sgs-blocks",
    "description": "SGS Blocks — custom Gutenberg block library",
    "type": "wordpress-plugin",
    "require": {
        "php": ">=8.2",
        "league/csv": "^9.28",
        "nesbot/carbon": "^3.11",
        "spatie/color": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "SGS\\Blocks\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
