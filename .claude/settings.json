{
  "permissions": {
    "defaultMode": "plan"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Users/Bean/Projects/small-giants-wp/.claude/hooks/drift-check-dispatcher.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Users/Bean/Projects/small-giants-wp/.claude/hooks/no-header-footer-block.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Users/Bean/Projects/small-giants-wp/.claude/hooks/memory-cap-guard.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Users/Bean/Projects/small-giants-wp/.claude/hooks/git-path-scope-guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python C:/Users/Bean/Projects/small-giants-wp/.claude/hooks/f5-commit-gate.py",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
