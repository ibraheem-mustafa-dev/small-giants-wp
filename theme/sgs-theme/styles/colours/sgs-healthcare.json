{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "SGS Healthcare Colours",
	"description": "Colour-only axis — deep teal and fresh green. Combine with any typography preset.",
	"settings": {
		"color": {
			"palette": [
				{
					"slug": "primary",
					"color": "#1A5F6B",
					"name": "Primary (Deep Teal)"
				},
				{
					"slug": "primary-dark",
					"color": "#124550",
					"name": "Primary Dark"
				},
				{
					"slug": "accent",
					"color": "#4CAF88",
					"name": "Accent (Fresh Green)"
				},
				{
					"slug": "accent-light",
					"color": "#D4F0E4",
					"name": "Accent Light"
				},
				{
					"slug": "error",
					"color": "#DC2626",
					"name": "Error"
				},
				{
					"slug": "surface",
					"color": "#FFFFFF",
					"name": "Surface (White)"
				},
				{
					"slug": "surface-alt",
					"color": "#F0F9F7",
					"name": "Surface Alt (Teal Tint)"
				},
				{
					"slug": "footer-bg",
					"color": "#1A5F6B",
					"name": "Footer Background"
				},
				{
					"slug": "text-primary",
					"color": "#1A2E35",
					"name": "Text Primary"
				},
				{
					"slug": "text-secondary",
					"color": "#4A6670",
					"name": "Text Secondary"
				},
				{
					"slug": "text-muted",
					"color": "#7A9BA6",
					"name": "Text Muted"
				},
				{
					"slug": "text-inverse",
					"color": "#FFFFFF",
					"name": "Text Inverse (White)"
				},
				{
					"slug": "border-subtle",
					"color": "#4CAF88",
					"name": "Border Subtle (Green)"
				},
				{
					"slug": "border-light",
					"color": "#E5E7EB",
					"name": "Border Light"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--surface)",
			"text": "var(--wp--preset--color--text-primary)"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--accent)"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--accent)",
					"text": "var(--wp--preset--color--text-inverse)"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--primary)",
						"text": "var(--wp--preset--color--text-inverse)"
					}
				}
			},
			"h1": { "color": { "text": "var(--wp--preset--color--text-primary)" } },
			"h2": { "color": { "text": "var(--wp--preset--color--text-primary)" } },
			"h3": { "color": { "text": "var(--wp--preset--color--text-primary)" } },
			"h4": { "color": { "text": "var(--wp--preset--color--text-primary)" } },
			"h5": { "color": { "text": "var(--wp--preset--color--accent)" } },
			"h6": { "color": { "text": "var(--wp--preset--color--text-secondary)" } }
		}
	}
}
