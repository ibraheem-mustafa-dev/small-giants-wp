{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "SGS Mosque & Islamic Orgs Colours",
	"description": "Colour-only axis — deep Islamic green and warm gold. Combine with any typography preset.",
	"settings": {
		"color": {
			"palette": [
				{
					"slug": "primary",
					"color": "#1A3D2B",
					"name": "Primary (Deep Islamic Green)"
				},
				{
					"slug": "primary-dark",
					"color": "#102519",
					"name": "Primary Dark"
				},
				{
					"slug": "accent",
					"color": "#C9A035",
					"name": "Accent (Warm Gold)"
				},
				{
					"slug": "accent-light",
					"color": "#F5E6B8",
					"name": "Accent Light"
				},
				{
					"slug": "error",
					"color": "#DC2626",
					"name": "Error"
				},
				{
					"slug": "surface",
					"color": "#FFFFFF",
					"name": "Surface (White)"
				},
				{
					"slug": "surface-alt",
					"color": "#F5FBF7",
					"name": "Surface Alt (Light Green Tint)"
				},
				{
					"slug": "footer-bg",
					"color": "#1A3D2B",
					"name": "Footer Background"
				},
				{
					"slug": "text-primary",
					"color": "#1A2E22",
					"name": "Text Primary"
				},
				{
					"slug": "text-secondary",
					"color": "#4A6055",
					"name": "Text Secondary"
				},
				{
					"slug": "text-muted",
					"color": "#7A9A88",
					"name": "Text Muted"
				},
				{
					"slug": "text-inverse",
					"color": "#FFFFFF",
					"name": "Text Inverse (White)"
				},
				{
					"slug": "border-subtle",
					"color": "#C9A035",
					"name": "Border Subtle (Gold)"
				},
				{
					"slug": "border-light",
					"color": "#E5E7EB",
					"name": "Border Light"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--surface)",
			"text": "var(--wp--preset--color--text-primary)"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--accent)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--primary)"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--accent)",
					"text": "var(--wp--preset--color--primary)"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--primary)",
						"text": "var(--wp--preset--color--text-inverse)"
					}
				}
			},
			"h5": { "color": { "text": "var(--wp--preset--color--accent)" } },
			"h6": { "color": { "text": "var(--wp--preset--color--text-secondary)" } }
		}
	}
}
