{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Indus Foods",
	"settings": {
		"color": {
			"palette": [
				{ "slug": "primary", "color": "#1A3A5C", "name": "Primary" },
				{ "slug": "primary-dark", "color": "#0F2440", "name": "Primary Dark" },
				{ "slug": "accent", "color": "#D4A843", "name": "Accent" },
				{ "slug": "accent-light", "color": "#F5ECD5", "name": "Accent Light" },
				{ "slug": "success", "color": "#2E7D4F", "name": "Success" },
				{ "slug": "whatsapp", "color": "#25D366", "name": "WhatsApp" },
				{ "slug": "surface", "color": "#FFFFFF", "name": "Surface" },
				{ "slug": "surface-alt", "color": "#F5F6F8", "name": "Surface Alt" },
				{ "slug": "text", "color": "#1E1E1E", "name": "Text" },
				{ "slug": "text-muted", "color": "#555555", "name": "Text Muted" },
				{ "slug": "text-inverse", "color": "#C8D5E0", "name": "Text Inverse" },
				{ "slug": "border-subtle", "color": "#2A4A6C", "name": "Border Subtle" }
			]
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var:preset|font-family|dm-sans"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|display",
					"fontWeight": "400"
				},
				"color": {
					"text": "var:preset|color|primary"
				}
			},
			"link": {
				"color": {
					"text": "var:preset|color|primary"
				},
				":hover": {
					"color": {
						"text": "var:preset|color|primary-dark"
					}
				}
			},
			"button": {
				"color": {
					"background": "var:preset|color|accent",
					"text": "var:preset|color|text"
				},
				":hover": {
					"color": {
						"background": "var:preset|color|primary-dark",
						"text": "var:preset|color|surface"
					}
				},
				":focus": {
					"outline": {
						"color": "var:preset|color|accent"
					}
				}
			}
		},
		"blocks": {
			"core/site-title": {
				"typography": {
					"fontFamily": "var:preset|font-family|display"
				}
			}
		}
	}
}
