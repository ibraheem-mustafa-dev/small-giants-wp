{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "SGS Healthcare",
	"slug": "sgs-healthcare",
	"settings": {
		"color": {
			"palette": [
				{
					"slug": "primary",
					"color": "#1A5F6B",
					"name": "Primary (Deep Teal)"
				},
				{
					"slug": "primary-dark",
					"color": "#124550",
					"name": "Primary Dark"
				},
				{
					"slug": "accent",
					"color": "#4CAF88",
					"name": "Accent (Fresh Green)"
				},
				{
					"slug": "accent-light",
					"color": "#D4F0E4",
					"name": "Accent Light"
				},
				{
					"slug": "surface",
					"color": "#FFFFFF",
					"name": "Surface (White)"
				},
				{
					"slug": "surface-alt",
					"color": "#F0F9F7",
					"name": "Surface Alt (Teal Tint)"
				},
				{
					"slug": "footer-bg",
					"color": "#1A5F6B",
					"name": "Footer Background"
				},
				{
					"slug": "text-primary",
					"color": "#1A2E35",
					"name": "Text Primary"
				},
				{
					"slug": "text-secondary",
					"color": "#4A6670",
					"name": "Text Secondary"
				},
				{
					"slug": "text-muted",
					"color": "#7A9BA6",
					"name": "Text Muted"
				},
				{
					"slug": "text-inverse",
					"color": "#FFFFFF",
					"name": "Text Inverse (White)"
				},
				{
					"slug": "border-subtle",
					"color": "#4CAF88",
					"name": "Border Subtle (Green)"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "'DM Serif Display', Georgia, serif",
					"slug": "heading",
					"name": "Heading (DM Serif Display)"
				},
				{
					"fontFamily": "'DM Sans', system-ui, sans-serif",
					"slug": "body",
					"name": "Body (DM Sans)"
				},
				{
					"fontFamily": "'DM Sans', system-ui, sans-serif",
					"slug": "mono",
					"name": "Mono (DM Sans)"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "clamp(0.75rem, 1.5vw, 0.875rem)",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "clamp(0.875rem, 2vw, 1rem)",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "clamp(1rem, 2.5vw, 1.25rem)",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "clamp(1.25rem, 3vw, 1.75rem)",
					"name": "X Large"
				},
				{
					"slug": "xx-large",
					"size": "clamp(1.75rem, 4vw, 2.5rem)",
					"name": "XX Large"
				},
				{
					"slug": "xxx-large",
					"size": "clamp(2.25rem, 5.5vw, 3.5rem)",
					"name": "XXX Large"
				}
			]
		},
		"spacing": {
			"spacingSizes": [
				{ "slug": "20", "size": "0.5rem",  "name": "2" },
				{ "slug": "30", "size": "0.75rem", "name": "3" },
				{ "slug": "40", "size": "1rem",    "name": "4" },
				{ "slug": "50", "size": "1.5rem",  "name": "5" },
				{ "slug": "60", "size": "2rem",    "name": "6" },
				{ "slug": "70", "size": "3rem",    "name": "7" },
				{ "slug": "80", "size": "4rem",    "name": "8" },
				{ "slug": "90", "size": "5.5rem",  "name": "9" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--surface)",
			"text": "var(--wp--preset--color--text-primary)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.65"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "400",
					"fontSize": "var(--wp--preset--font-size--xxx-large)",
					"lineHeight": "1.1",
					"letterSpacing": "-0.02em"
				},
				"color": {
					"text": "var(--wp--preset--color--text-primary)"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "400",
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"lineHeight": "1.15",
					"letterSpacing": "-0.015em"
				},
				"color": {
					"text": "var(--wp--preset--color--text-primary)"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "400",
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"lineHeight": "1.2",
					"letterSpacing": "-0.01em"
				},
				"color": {
					"text": "var(--wp--preset--color--text-primary)"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "400",
					"fontSize": "var(--wp--preset--font-size--large)",
					"lineHeight": "1.25"
				},
				"color": {
					"text": "var(--wp--preset--color--text-primary)"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontWeight": "600",
					"fontSize": "var(--wp--preset--font-size--medium)",
					"lineHeight": "1.3",
					"letterSpacing": "0.05em",
					"textTransform": "uppercase"
				},
				"color": {
					"text": "var(--wp--preset--color--accent)"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontWeight": "600",
					"fontSize": "var(--wp--preset--font-size--small)",
					"letterSpacing": "0.06em",
					"textTransform": "uppercase"
				},
				"color": {
					"text": "var(--wp--preset--color--text-secondary)"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--accent)"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--accent)",
					"text": "var(--wp--preset--color--text-inverse)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontWeight": "600",
					"fontSize": "var(--wp--preset--font-size--medium)",
					"letterSpacing": "0.04em"
				},
				"border": {
					"radius": "4px"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--primary)",
						"text": "var(--wp--preset--color--text-inverse)"
					}
				}
			}
		}
	}
}
