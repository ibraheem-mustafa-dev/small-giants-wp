{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Eye Care Ward End Typography",
	"description": "Typography-only axis — DM Serif Display headings, DM Sans body, fluid type scale. Combine with any colour preset.",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "'DM Serif Display', Georgia, serif",
					"slug": "heading",
					"name": "Heading (DM Serif Display)"
				},
				{
					"fontFamily": "'DM Sans', system-ui, sans-serif",
					"slug": "body",
					"name": "Body (DM Sans)"
				},
				{
					"fontFamily": "'DM Sans', system-ui, sans-serif",
					"slug": "mono",
					"name": "Mono (DM Sans)"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "clamp(0.75rem, 1.5vw, 0.875rem)",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "clamp(0.875rem, 2vw, 1rem)",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "clamp(1rem, 2.5vw, 1.25rem)",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "clamp(1.25rem, 3vw, 1.75rem)",
					"name": "X Large"
				},
				{
					"slug": "xx-large",
					"size": "clamp(1.75rem, 4vw, 2.5rem)",
					"name": "XX Large"
				},
				{
					"slug": "xxx-large",
					"size": "clamp(2.25rem, 5.5vw, 3.5rem)",
					"name": "XXX Large"
				}
			]
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.65"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "400",
					"fontSize": "var(--wp--preset--font-size--xxx-large)",
					"lineHeight": "1.1",
					"letterSpacing": "-0.02em"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "400",
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"lineHeight": "1.15",
					"letterSpacing": "-0.015em"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "400",
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"lineHeight": "1.2",
					"letterSpacing": "-0.01em"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "400",
					"fontSize": "var(--wp--preset--font-size--large)",
					"lineHeight": "1.25"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontWeight": "600",
					"fontSize": "var(--wp--preset--font-size--medium)",
					"lineHeight": "1.3",
					"letterSpacing": "0.05em",
					"textTransform": "uppercase"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontWeight": "600",
					"fontSize": "var(--wp--preset--font-size--small)",
					"letterSpacing": "0.06em",
					"textTransform": "uppercase"
				}
			},
			"button": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontWeight": "600",
					"fontSize": "var(--wp--preset--font-size--medium)",
					"letterSpacing": "0.04em"
				},
				"border": {
					"radius": "4px"
				}
			}
		}
	}
}
