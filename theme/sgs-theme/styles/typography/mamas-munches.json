{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Mama's Munches Typography",
	"description": "Typography-only axis — Fraunces headings, Inter body. Combine with any colour preset.",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "Fraunces, 'DM Serif Display', Georgia, serif",
					"slug": "heading",
					"name": "Heading (Fraunces)",
					"fontFace": [
						{
							"fontFamily": "Fraunces",
							"fontWeight": "100 900",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/fraunces/Fraunces[opsz,wght].woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Inter, system-ui, -apple-system, sans-serif",
					"slug": "body",
					"name": "Body (Inter)",
					"fontFace": [
						{
							"fontFamily": "Inter",
							"fontWeight": "100 900",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/inter-variable-latin.woff2"
							]
						}
					]
				}
			]
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var:preset|font-family|body",
			"fontSize": "1rem",
			"lineHeight": "1.65",
			"fontWeight": "400"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontFamily": "var:preset|font-family|heading",
					"fontWeight": "700",
					"lineHeight": "1.15",
					"letterSpacing": "-0.022em"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var:preset|font-family|heading",
					"fontWeight": "600",
					"lineHeight": "1.2",
					"letterSpacing": "-0.015em"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var:preset|font-family|heading",
					"fontWeight": "500",
					"lineHeight": "1.2"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var:preset|font-family|body",
					"fontWeight": "600",
					"lineHeight": "1.3"
				}
			},
			"button": {
				"typography": {
					"fontFamily": "var:preset|font-family|body",
					"fontWeight": "600",
					"fontSize": "0.95rem"
				},
				"spacing": {
					"padding": {
						"top": "14px",
						"bottom": "14px",
						"left": "24px",
						"right": "24px"
					}
				}
			}
		}
	}
}
