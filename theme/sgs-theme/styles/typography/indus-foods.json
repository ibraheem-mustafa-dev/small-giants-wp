{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Indus Foods Typography",
	"description": "Typography-only axis — Montserrat headings, Source Sans 3 body. Combine with any colour preset.",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "Montserrat, system-ui, sans-serif",
					"slug": "heading",
					"name": "Heading",
					"fontFace": [
						{
							"fontFamily": "Montserrat",
							"fontWeight": "100 900",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/montserrat-variable-latin.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "'Source Sans 3', system-ui, sans-serif",
					"slug": "body",
					"name": "Body",
					"fontFace": [
						{
							"fontFamily": "Source Sans 3",
							"fontWeight": "200 900",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/source-sans-3-variable-latin.woff2"
							]
						}
					]
				}
			]
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var:preset|font-family|body"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|heading",
					"fontWeight": "700"
				}
			},
			"button": {
				"typography": {
					"fontWeight": "600",
					"fontSize": "var:preset|font-size|medium",
					"textDecoration": "none"
				}
			},
			"link": {}
		},
		"blocks": {
			"core/site-title": {
				"typography": {
					"fontFamily": "var:preset|font-family|heading"
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var:preset|font-size|medium",
					"fontWeight": "600"
				}
			}
		}
	}
}
