{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Mama's Munches",
	"settings": {
		"color": {
			"palette": [
				{
					"slug": "primary",
					"color": "#E68A95",
					"name": "Primary (Coral Pink)"
				},
				{
					"slug": "primary-dark",
					"color": "#C56A7A",
					"name": "Primary Dark (Coral Hover)"
				},
				{
					"slug": "surface-pink",
					"color": "#F5C2C8",
					"name": "Soft Pink (Hero / Trust Bar)"
				},
				{
					"slug": "surface",
					"color": "#FBF3DC",
					"name": "Surface (Cream)"
				},
				{
					"slug": "surface-alt",
					"color": "#FFF9F0",
					"name": "Surface Alt (Warm Off-white)"
				},
				{
					"slug": "accent",
					"color": "#F5D050",
					"name": "Accent (Warm Yellow)"
				},
				{
					"slug": "accent-text",
					"color": "#7A6500",
					"name": "Accent Text (WCAG AA on White)"
				},
				{
					"slug": "text",
					"color": "#3A2E26",
					"name": "Text (Choc-chip Charcoal)"
				},
				{
					"slug": "text-muted",
					"color": "#6B5C50",
					"name": "Text Muted (Warm Mid-brown)"
				},
				{
					"slug": "text-inverse",
					"color": "#FFFAF5",
					"name": "Text Inverse (Off-white)"
				},
				{
					"slug": "cookie-brown",
					"color": "#8B6F4E",
					"name": "Cookie Brown (Decorative)"
				},
				{
					"slug": "border-subtle",
					"color": "#E8D5C0",
					"name": "Border (Warm Beige)"
				},
				{
					"slug": "success",
					"color": "#2E7D4F",
					"name": "Success"
				},
				{
					"slug": "footer-bg",
					"color": "#3A2E26",
					"name": "Footer Background"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "Fraunces, 'DM Serif Display', Georgia, serif",
					"slug": "heading",
					"name": "Heading (Fraunces)",
					"fontFace": [
						{
							"fontFamily": "Fraunces",
							"fontWeight": "100 900",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/fraunces/Fraunces[opsz,wght].woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Inter, system-ui, -apple-system, sans-serif",
					"slug": "body",
					"name": "Body (Inter)",
					"fontFace": [
						{
							"fontFamily": "Inter",
							"fontWeight": "100 900",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/inter-variable-latin.woff2"
							]
						}
					]
				}
			]
		},
		"custom": {
			"buttonPresets": {
				"primary": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--text)",
					"border": "var(--wp--preset--color--primary)",
					"border-width": "2px",
					"border-radius": "24px",
					"padding": "14px 28px 14px 28px",
					"font-size": "15px",
					"font-weight": "600",
					"min-height": "48px",
					"hover-background": "var(--wp--preset--color--text)",
					"hover-text": "var(--wp--preset--color--text-inverse)",
					"hover-border": "var(--wp--preset--color--text)"
				},
				"secondary": {
					"background": "transparent",
					"text": "var(--wp--preset--color--text)",
					"border": "var(--wp--preset--color--primary)",
					"border-width": "2px",
					"border-radius": "24px",
					"padding": "14px 28px 14px 28px",
					"font-size": "15px",
					"font-weight": "600",
					"min-height": "48px",
					"hover-background": "var(--wp--preset--color--text)",
					"hover-text": "var(--wp--preset--color--text-inverse)",
					"hover-border": "var(--wp--preset--color--text)"
				}
			}
		}
	},
	"styles": {
		"css": "*:focus-visible { outline: 2px solid var(--wp--preset--color--text); outline-offset: 2px; border-radius: 4px; } .sgs-button.is-style-primary { background-color: var(--wp--preset--color--primary) !important; color: var(--wp--preset--color--text) !important; border-color: var(--wp--preset--color--primary) !important; line-height: 1.6 !important; } .sgs-button.is-style-primary:hover { background-color: var(--wp--preset--color--text) !important; color: var(--wp--preset--color--text-inverse) !important; border-color: var(--wp--preset--color--text) !important; } .sgs-button.is-style-secondary { background-color: transparent !important; color: var(--wp--preset--color--text) !important; border-color: var(--wp--preset--color--primary) !important; line-height: 1.6 !important; } .sgs-button.is-style-secondary:hover { background-color: var(--wp--preset--color--text) !important; color: var(--wp--preset--color--text-inverse) !important; border-color: var(--wp--preset--color--text) !important; }",
		"blocks": {
			"sgs/hero": {
				"css": ".sgs-hero__label{display:block;font-family:var(--wp--preset--font-family--body);font-size:clamp(0.75rem,1.5vw,0.875rem);font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--wp--preset--color--primary);margin-bottom:0.5rem;line-height:1.2}.sgs-hero__headline{text-wrap:balance}"
			}
		},
		"typography": {
			"fontFamily": "var:preset|font-family|body",
			"fontSize": "1rem",
			"lineHeight": "1.65",
			"fontWeight": "400"
		},
		"color": {
			"background": "var:preset|color|surface",
			"text": "var:preset|color|text"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontFamily": "var:preset|font-family|heading",
					"fontWeight": "700",
					"lineHeight": "1.15",
					"letterSpacing": "-0.022em"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var:preset|font-family|heading",
					"fontWeight": "600",
					"lineHeight": "1.2",
					"letterSpacing": "-0.015em"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var:preset|font-family|heading",
					"fontWeight": "500",
					"lineHeight": "1.2"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var:preset|font-family|body",
					"fontWeight": "600",
					"lineHeight": "1.3"
				}
			},
			"link": {
				"color": {
					"text": "var:preset|color|primary-dark"
				},
				":hover": {
					"color": {
						"text": "var:preset|color|text"
					}
				}
			},
			"button": {
				"color": {
					"background": "var:preset|color|primary",
					"text": "var:preset|color|text"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|body",
					"fontWeight": "600",
					"fontSize": "0.95rem"
				},
				"border": {
					"radius": "10px",
					"width": "2px",
					"color": "var:preset|color|primary",
					"style": "solid"
				},
				"spacing": {
					"padding": {
						"top": "14px",
						"bottom": "14px",
						"left": "24px",
						"right": "24px"
					}
				},
				":hover": {
					"color": {
						"background": "var:preset|color|text",
						"text": "var:preset|color|text-inverse"
					},
					"border": {
						"color": "var:preset|color|text"
					}
				}
			}
		}
	}
}
