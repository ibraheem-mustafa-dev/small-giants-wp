{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Mama's Munches",
	"settings": {
		"color": {
			"palette": [
				{
					"slug": "primary",
					"color": "#E68A95",
					"name": "Primary (Coral Pink)"
				},
				{
					"slug": "primary-dark",
					"color": "#C56A7A",
					"name": "Primary Dark (Coral Hover)"
				},
				{
					"slug": "surface-pink",
					"color": "#F5C2C8",
					"name": "Soft Pink (Hero / Trust Bar)"
				},
				{
					"slug": "surface",
					"color": "#FBF3DC",
					"name": "Surface (Cream)"
				},
				{
					"slug": "surface-alt",
					"color": "#FFF9F0",
					"name": "Surface Alt (Warm Off-white)"
				},
				{
					"slug": "accent",
					"color": "#F5D050",
					"name": "Accent (Warm Yellow)"
				},
				{
					"slug": "accent-text",
					"color": "#7A6500",
					"name": "Accent Text (WCAG AA on White)"
				},
				{
					"slug": "text",
					"color": "#3A2E26",
					"name": "Text (Choc-chip Charcoal)"
				},
				{
					"slug": "text-muted",
					"color": "#6B5C50",
					"name": "Text Muted (Warm Mid-brown)"
				},
				{
					"slug": "text-inverse",
					"color": "#FFFAF5",
					"name": "Text Inverse (Off-white)"
				},
				{
					"slug": "cookie-brown",
					"color": "#8B6F4E",
					"name": "Cookie Brown (Decorative)"
				},
				{
					"slug": "border-subtle",
					"color": "#E8D5C0",
					"name": "Border (Warm Beige)"
				},
				{
					"slug": "success",
					"color": "#2E7D4F",
					"name": "Success"
				},
				{
					"slug": "footer-bg",
					"color": "#3A2E26",
					"name": "Footer Background"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "Fraunces, 'DM Serif Display', Georgia, serif",
					"slug": "heading",
					"name": "Heading (Fraunces)",
					"fontFace": [
						{
							"fontFamily": "Fraunces",
							"fontWeight": "300 900",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"https://fonts.gstatic.com/s/fraunces/v36/6NUu8FOgNbSMuT4z3uQTcceFmfgM92t8KAQbaHUZTvkQQF7lvi0.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Inter, system-ui, -apple-system, sans-serif",
					"slug": "body",
					"name": "Body (Inter)",
					"fontFace": [
						{
							"fontFamily": "Inter",
							"fontWeight": "100 900",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/inter-variable-latin.woff2"
							]
						}
					]
				}
			]
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var:preset|font-family|body",
			"fontSize": "1rem",
			"lineHeight": "1.65",
			"fontWeight": "400"
		},
		"color": {
			"background": "var:preset|color|surface",
			"text": "var:preset|color|text"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontFamily": "var:preset|font-family|heading",
					"fontWeight": "700",
					"lineHeight": "1.15",
					"letterSpacing": "-0.02em"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var:preset|font-family|heading",
					"fontWeight": "600",
					"lineHeight": "1.2",
					"letterSpacing": "-0.015em"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var:preset|font-family|heading",
					"fontWeight": "500",
					"lineHeight": "1.25"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var:preset|font-family|body",
					"fontWeight": "600",
					"lineHeight": "1.3"
				}
			},
			"link": {
				"color": {
					"text": "var:preset|color|primary-dark"
				},
				":hover": {
					"color": {
						"text": "var:preset|color|text"
					}
				}
			},
			"button": {
				"color": {
					"background": "var:preset|color|primary",
					"text": "var:preset|color|text"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|body",
					"fontWeight": "600",
					"fontSize": "0.95rem"
				},
				"border": {
					"radius": "10px",
					"width": "2px",
					"color": "var:preset|color|primary",
					"style": "solid"
				},
				"spacing": {
					"padding": {
						"top": "14px",
						"bottom": "14px",
						"left": "24px",
						"right": "24px"
					}
				},
				":hover": {
					"color": {
						"background": "var:preset|color|text",
						"text": "var:preset|color|text-inverse"
					},
					"border": {
						"color": "var:preset|color|text"
					}
				}
			}
		}
	}
}
